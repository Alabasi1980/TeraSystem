{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tera.control-room/schemas/handback.schema.json",
  "title": "Tera Control Room — Handback v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "agent_id",
    "status",
    "summary",
    "files_changed",
    "commands_executed",
    "known_issues",
    "recommended_next_action"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "task_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["COMPLETED", "FAILED", "PARTIAL_SUCCESS"]
    },
    "summary": { "type": "string", "minLength": 5 },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "commands_executed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code"],
        "properties": {
          "command": { "type": "string" },
          "exit_code": { "type": "number" }
        }
      }
    },
    "known_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_next_action": {
      "type": "string",
      "enum": ["REVIEW", "RETRY", "ESCALATE"]
    }
  }
}