<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════ -->
    <!--  DesignTokens.xaml                          -->
    <!--  Central design token dictionary             -->
    <!--  Source: 28_UI_UX_GUIDELINES.md §3            -->
    <!-- ════════════════════════════════════════════ -->

    <!-- ─── 3.1 Colors ─── -->
    <!-- Backgrounds & Surfaces -->
    <Color x:Key="AppBackgroundColor">#F6F8FB</Color>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />

    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />

    <!-- Primary -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />

    <Color x:Key="PrimaryHoverColor">#1D4ED8</Color>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#111827</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />

    <Color x:Key="TextSecondaryColor">#6B7280</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />

    <Color x:Key="TextMutedColor">#9CA3AF</Color>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />

    <!-- Borders -->
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />

    <Color x:Key="BorderLightColor">#F3F4F6</Color>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}" />

    <Color x:Key="BorderFieldColor">#D1D5DB</Color>
    <SolidColorBrush x:Key="BorderFieldBrush" Color="{StaticResource BorderFieldColor}" />

    <!-- Success -->
    <Color x:Key="SuccessColor">#16A34A</Color>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />

    <Color x:Key="SuccessBgColor">#DCFCE7</Color>
    <SolidColorBrush x:Key="SuccessBgBrush" Color="{StaticResource SuccessBgColor}" />

    <!-- Warning -->
    <Color x:Key="WarningColor">#D97706</Color>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <Color x:Key="WarningBgColor">#FEF3C7</Color>
    <SolidColorBrush x:Key="WarningBgBrush" Color="{StaticResource WarningBgColor}" />

    <!-- Danger -->
    <Color x:Key="DangerColor">#DC2626</Color>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

    <Color x:Key="DangerBgColor">#FEE2E2</Color>
    <SolidColorBrush x:Key="DangerBgBrush" Color="{StaticResource DangerBgColor}" />

    <!-- Info -->
    <Color x:Key="InfoColor">#2563EB</Color>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <Color x:Key="InfoBgColor">#DBEAFE</Color>
    <SolidColorBrush x:Key="InfoBgBrush" Color="{StaticResource InfoBgColor}" />

    <!-- BestPrice -->
    <Color x:Key="BestPriceColor">#16A34A</Color>
    <SolidColorBrush x:Key="BestPriceBrush" Color="{StaticResource BestPriceColor}" />

    <Color x:Key="BestPriceBgColor">#F0FDF4</Color>
    <SolidColorBrush x:Key="BestPriceBgBrush" Color="{StaticResource BestPriceBgColor}" />

    <!-- Disabled & Alternating -->
    <Color x:Key="DisabledBgColor">#F9FAFB</Color>
    <SolidColorBrush x:Key="DisabledBgBrush" Color="{StaticResource DisabledBgColor}" />

    <Color x:Key="AlternatingRowColor">#F9FAFB</Color>
    <SolidColorBrush x:Key="AlternatingRowBrush" Color="{StaticResource AlternatingRowColor}" />

    <!-- ─── 3.2 Typography ─── -->
    <FontFamily x:Key="DefaultFontFamily">Segoe UI</FontFamily>

    <sys:Double x:Key="PageTitleFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">22</sys:Double>
    <FontWeight x:Key="PageTitleFontWeight">Bold</FontWeight>

    <sys:Double x:Key="SectionTitleFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <FontWeight x:Key="SectionTitleFontWeight">SemiBold</FontWeight>

    <sys:Double x:Key="BodyFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <FontWeight x:Key="BodyFontWeight">Regular</FontWeight>

    <sys:Double x:Key="LabelFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>
    <FontWeight x:Key="LabelFontWeight">Regular</FontWeight>

    <sys:Double x:Key="HelperFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <FontWeight x:Key="HelperFontWeight">Regular</FontWeight>

    <sys:Double x:Key="BadgeFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <FontWeight x:Key="BadgeFontWeight">SemiBold</FontWeight>

    <!-- ─── 3.3 Spacing ─── -->
    <Thickness x:Key="Space2">2</Thickness>
    <Thickness x:Key="Space4">4</Thickness>
    <Thickness x:Key="Space8">8</Thickness>
    <Thickness x:Key="Space12">12</Thickness>
    <Thickness x:Key="Space16">16</Thickness>
    <Thickness x:Key="Space20">20</Thickness>
    <Thickness x:Key="Space24">24</Thickness>
    <Thickness x:Key="Space32">32</Thickness>

    <!-- Spacing as Double for margins that need uniform values -->
    <sys:Double x:Key="Space2px" xmlns:sys="clr-namespace:System;assembly=mscorlib">2</sys:Double>
    <sys:Double x:Key="Space4px" xmlns:sys="clr-namespace:System;assembly=mscorlib">4</sys:Double>
    <sys:Double x:Key="Space8px" xmlns:sys="clr-namespace:System;assembly=mscorlib">8</sys:Double>
    <sys:Double x:Key="Space12px" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="Space16px" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="Space20px" xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Double>
    <sys:Double x:Key="Space24px" xmlns:sys="clr-namespace:System;assembly=mscorlib">24</sys:Double>
    <sys:Double x:Key="Space32px" xmlns:sys="clr-namespace:System;assembly=mscorlib">32</sys:Double>

    <!-- ─── 3.4 Radii ─── -->
    <CornerRadius x:Key="RadiusCard">10</CornerRadius>
    <CornerRadius x:Key="RadiusButton">8</CornerRadius>
    <CornerRadius x:Key="RadiusField">6</CornerRadius>
    <CornerRadius x:Key="RadiusBadge">4</CornerRadius>

    <!-- ─── 3.5 Shadows ─── -->
    <DropShadowEffect x:Key="ShadowCardEffect"
                      BlurRadius="8"
                      Opacity="0.06"
                      ShadowDepth="2"
                      Color="#000000" />

    <DropShadowEffect x:Key="ShadowPopupEffect"
                      BlurRadius="12"
                      Opacity="0.1"
                      ShadowDepth="4"
                      Color="#000000" />

</ResourceDictionary>
