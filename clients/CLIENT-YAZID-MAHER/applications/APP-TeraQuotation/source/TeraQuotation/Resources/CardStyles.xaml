<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════ -->
    <!--  CardStyles.xaml                            -->
    <!--  Card container styles for the app          -->
    <!--  Source: 28_UI_UX_GUIDELINES.md §5.3         -->
    <!-- ════════════════════════════════════════════ -->

    <!-- ─── Base Card Border Style ─── -->
    <!-- Background: White, Border: 1px #E5E7EB, Radius: 10 -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" Opacity="0.06" ShadowDepth="2" Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── Card with Padding ─── -->
    <Style x:Key="CardWithPaddingStyle"
           TargetType="Border"
           BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="{StaticResource Space20}" />
    </Style>

    <!-- ─── Status Card Variants ─── -->
    <!-- Success Card -->
    <Style x:Key="SuccessCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource SuccessBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
    </Style>

    <!-- Warning Card -->
    <Style x:Key="WarningCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource WarningBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
    </Style>

    <!-- Danger Card -->
    <Style x:Key="DangerCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource DangerBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
    </Style>

    <!-- Info Card -->
    <Style x:Key="InfoCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource InfoBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}" />
    </Style>

    <!-- BestPrice Card -->
    <Style x:Key="BestPriceCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource BestPriceBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BestPriceBrush}" />
    </Style>

    <!-- ─── Card Title TextBlock Style ─── -->
    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource SectionTitleFontSize}" />
        <Setter Property="FontWeight" Value="{StaticResource SectionTitleFontWeight}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="FlowDirection" Value="RightToLeft" />
    </Style>

    <!-- ─── Card Header Panel Style ─── -->
    <Style x:Key="CardHeaderStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

</ResourceDictionary>
