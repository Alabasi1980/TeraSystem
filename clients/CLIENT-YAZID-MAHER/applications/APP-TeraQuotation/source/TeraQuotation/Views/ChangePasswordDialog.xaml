<Window x:Class="TeraQuotation.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تغيير كلمة المرور"
        Width="400" Height="460"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="20">
        <Border Style="{StaticResource CardStyle}"
                Padding="28">
            <StackPanel VerticalAlignment="Center">
                <!-- Title -->
                <TextBlock Text="تغيير كلمة المرور"
                           FontSize="{StaticResource SectionTitleFontSize}"
                           FontWeight="{StaticResource SectionTitleFontWeight}"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Current password -->
                <TextBlock Text="كلمة المرور الحالية"
                           Style="{StaticResource FieldLabelStyle}"/>
                <PasswordBox x:Name="CurrentPwd"
                             Style="{StaticResource PasswordBoxStyle}"
                             Margin="0,0,0,16"
                             PasswordChanged="OnPasswordChanged"/>

                <!-- New password -->
                <TextBlock Text="كلمة المرور الجديدة"
                           Style="{StaticResource FieldLabelStyle}"/>
                <PasswordBox x:Name="NewPwd"
                             Style="{StaticResource PasswordBoxStyle}"
                             Margin="0,0,0,16"
                             PasswordChanged="OnPasswordChanged"/>

                <!-- Confirm new password -->
                <TextBlock Text="تأكيد كلمة المرور الجديدة"
                           Style="{StaticResource FieldLabelStyle}"/>
                <PasswordBox x:Name="ConfirmPwd"
                             Style="{StaticResource PasswordBoxStyle}"
                             Margin="0,0,0,8"
                             PasswordChanged="OnPasswordChanged"/>

                <!-- Message (error / success) with dynamic color -->
                <TextBlock Text="{Binding ErrorMessage}"
                           HorizontalAlignment="Center"
                           Margin="0,12"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ValidationErrorStyle}">
                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
                    <Button x:Name="ChangeBtn"
                            Content="حفظ"
                            Click="ChangeBtn_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="24,8"
                            Margin="0,0,12,0"/>
                    <Button Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="24,8"/>
                </StackPanel>

                <!-- Loading indicator -->
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Margin="0,16,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Foreground="{StaticResource PrimaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
