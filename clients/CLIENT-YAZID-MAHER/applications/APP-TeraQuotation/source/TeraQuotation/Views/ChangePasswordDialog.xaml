<Window x:Class="TeraQuotation.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تغيير كلمة المرور"
        Width="380" Height="420"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6" />
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Border Margin="20" Background="White" CornerRadius="12" Padding="30">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="تغيير كلمة المرور" FontSize="20" FontWeight="Bold"
                           Foreground="#1A73E8" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Current password -->
                <TextBlock Text="كلمة المرور الحالية" FontSize="13" Foreground="#444" Margin="0,0,0,4"/>
                <PasswordBox x:Name="CurrentPwd" FontSize="14" Padding="10,8"
                             BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,10"
                             PasswordChanged="OnPasswordChanged"/>

                <!-- New password -->
                <TextBlock Text="كلمة المرور الجديدة" FontSize="13" Foreground="#444" Margin="0,0,0,4"/>
                <PasswordBox x:Name="NewPwd" FontSize="14" Padding="10,8"
                             BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,10"
                             PasswordChanged="OnPasswordChanged"/>

                <!-- Confirm -->
                <TextBlock Text="تأكيد كلمة المرور الجديدة" FontSize="13" Foreground="#444" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ConfirmPwd" FontSize="14" Padding="10,8"
                             BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,10"
                             PasswordChanged="OnPasswordChanged"/>

                <!-- Message (error / success) with dynamic color -->
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="13" HorizontalAlignment="Center" Margin="0,8"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#D32F2F" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="#2E7D32" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="ChangeBtn" Content="تغيير"
                            Click="ChangeBtn_Click"
                            Style="{StaticResource RoundedButton}"
                            Background="#1A73E8" Foreground="White" FontSize="14" FontWeight="Bold"
                            Padding="20,10" Margin="0,0,10,0"/>
                    <Button Content="إلغاء" Command="{Binding CancelCommand}"
                            Style="{StaticResource RoundedButton}"
                            Background="#E0E0E0" Foreground="#333" FontSize="14"
                            Padding="20,10"/>
                </StackPanel>

                <!-- Loading indicator -->
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,10,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Foreground="#1A73E8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
