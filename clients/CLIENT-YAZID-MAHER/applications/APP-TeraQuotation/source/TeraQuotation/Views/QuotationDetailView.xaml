<UserControl x:Class="TeraQuotation.Views.QuotationDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:TeraQuotation.ViewModels"
             d:DataContext="{d:DesignInstance vm:QuotationDetailViewModel}"
             FlowDirection="RightToLeft"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ Row 0: Header ══════════ -->
        <Border Grid.Row="0"
                Style="{StaticResource CardWithPaddingStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="← عودة إلى القائمة"
                        Command="{Binding GoToListCommand}"
                        Style="{StaticResource GhostButtonStyle}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0">
                    <TextBlock FontSize="{StaticResource PageTitleFontSize}"
                               FontWeight="{StaticResource PageTitleFontWeight}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center">
                        <Run Text="عرض سعر"/>
                        <Run Text="-"/>
                        <Run Text="{Binding QuoteNumber}"/>
                    </TextBlock>
                </StackPanel>

                <ContentControl Grid.Column="2"
                                Content="{Binding Status}"
                                ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══════════ Row 1: Quote Info (Card) ══════════ -->
        <Border Grid.Row="1"
                Style="{StaticResource CardWithPaddingStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="رقم العرض:" Grid.Column="0"
                           Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="{Binding QuoteNumber}" IsReadOnly="True"
                         Grid.Column="1" Margin="5"
                         Style="{StaticResource ReadOnlyTextBoxStyle}"/>

                <TextBlock Text="التاريخ:" Grid.Column="2"
                           Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center" Margin="20,5,5,5"/>
                <DatePicker SelectedDate="{Binding QuoteDate}"
                            Grid.Column="3" Margin="5"
                            Style="{StaticResource DatePickerStyle}"/>

                <TextBlock Text="الوصف:" Grid.Column="4"
                           Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center" Margin="20,5,5,5"/>
                <TextBox Text="{Binding Description}"
                         Grid.Column="5" Margin="5"
                         Style="{StaticResource TextBoxStyle}"/>
            </Grid>
        </Border>

        <!-- ══════════ Row 2: Status + Supplier Info (Card) ══════════ -->
        <Border Grid.Row="2"
                Style="{StaticResource CardWithPaddingStyle}"
                Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="الحالة:" Grid.Column="0"
                               Style="{StaticResource FieldLabelStyle}"
                               VerticalAlignment="Center"/>
                    <ContentControl Grid.Column="1"
                                    Content="{Binding Status}"
                                    ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                    VerticalAlignment="Center"/>

                    <TextBlock Text="الحالة التالية:" Grid.Column="2"
                               Style="{StaticResource FieldLabelStyle}"
                               Margin="20,0,0,0"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="5">
                        <ComboBox ItemsSource="{Binding AvailableStatuses}"
                                  SelectedItem="{Binding SelectedNextStatus}"
                                  Width="160"
                                  Style="{StaticResource ComboBoxStyle}"
                                  IsEnabled="{Binding AvailableStatuses.Count, Converter={StaticResource InverseNullToBoolConverter}}"/>
                        <Button Content="تطبيق"
                                Command="{Binding AdvanceStatusCommand}"
                                Style="{StaticResource SmallButtonStyle}"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,4" Background="{StaticResource BorderLightBrush}"/>

                <!-- Suppliers -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="الموردون:"
                               Style="{StaticResource FieldLabelStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <ItemsControl ItemsSource="{Binding SelectedSuppliers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource InfoBgBrush}"
                                        CornerRadius="{StaticResource RadiusBadge}"
                                        Padding="8,3" Margin="2"
                                        BorderThickness="0">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="{StaticResource BadgeFontSize}"
                                               FontWeight="{StaticResource BadgeFontWeight}"
                                               Foreground="{StaticResource InfoBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════════ Row 3: Materials Summary (Card) ══════════ -->
        <Border Grid.Row="3"
                Style="{StaticResource CardWithPaddingStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="المواد المطلوبة"
                           Style="{StaticResource CardTitleStyle}"/>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding Items}"
                              Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderLightBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               FontSize="{StaticResource BodyFontSize}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>

                                    <TextBlock Grid.Column="1"
                                               FontSize="{StaticResource BodyFontSize}"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="{Binding Quantity, StringFormat={}{0:N0}}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Unit}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock Grid.Row="1"
                           Text="لا توجد مواد في هذا العرض."
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ══════════ Row 4: Action Buttons (Sticky) ══════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        FlowDirection="RightToLeft">

                <Button Content="حفظ التغييرات"
                        Command="{Binding SaveAsyncCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>

                <Button Content="طباعة بدون أسعار"
                        Command="{Binding PrintWithoutPricesCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0"/>

                <Button Content="طباعة نهائية"
                        Command="{Binding PrintFinalCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0"/>

                <Button Content="تصدير PDF"
                        Command="{Binding ExportPdfCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0"/>

                <Button Content="إرسال عبر Outlook"
                        Command="{Binding SendViaOutlookCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
