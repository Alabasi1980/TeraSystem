<UserControl x:Class="TeraQuotation.Views.QuotationListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:TeraQuotation.ViewModels"
             xmlns:conv="clr-namespace:TeraQuotation.Converters"
             d:DataContext="{d:DesignInstance vm:QuotationListViewModel}"
             FlowDirection="RightToLeft"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== Header ========== -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="قائمة عروض الأسعار" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="عرض جديد" Command="{Binding NewQuotationCommand}"
                    Margin="20,0,0,0" Padding="14,8"
                    Background="#1A73E8" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold"/>
            <Button Content="الصفحة الرئيسية" Command="{Binding HomeCommand}"
                    Margin="10,0,0,0" Padding="10,5" Background="#EEE" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>

        <!-- ========== Search + Filter bar ========== -->
        <Border Grid.Row="1" Margin="0,0,0,15" Padding="10"
                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="بحث:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="220" Margin="0,0,15,0" Padding="4"/>
                <Button Content="بحث" Command="{Binding SearchCommand}"
                        Padding="12,5" Margin="0,0,15,0"/>

                <TextBlock Text="الحالة:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter, UpdateSourceTrigger=PropertyChanged}"
                          Width="160" Margin="0,0,15,0"
                          SelectedIndex="0"/>
                <Button Content="تصفية" Command="{Binding SearchCommand}"
                        Padding="12,5"/>
            </StackPanel>
        </Border>

        <!-- ========== DataGrid ========== -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Quotations}"
                  SelectedItem="{Binding SelectedQuotation}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5"
                  RowDetailsVisibilityMode="Collapsed"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <!-- رقم العرض -->
                <DataGridTextColumn Header="رقم العرض"
                                    Binding="{Binding QuoteNumber}"
                                    Width="130"/>

                <!-- التاريخ -->
                <DataGridTextColumn Header="التاريخ"
                                    Binding="{Binding Date, StringFormat='{}{0:yyyy/MM/dd}'}"
                                    Width="110"/>

                <!-- الوصف -->
                <DataGridTextColumn Header="الوصف"
                                    Binding="{Binding Description}"
                                    Width="*"/>

                <!-- الحالة (ملونة) -->
                <DataGridTemplateColumn Header="الحالة" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}"
                                       Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- فتح -->
                <DataGridTemplateColumn Header="إجراء" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="فتح"
                                    Command="{Binding DataContext.OpenQuotationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Padding="8,3"
                                    Background="#1A73E8"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
