<UserControl x:Class="TeraQuotation.Views.QuotationListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:TeraQuotation.ViewModels"
             d:DataContext="{d:DesignInstance vm:QuotationListViewModel}"
             FlowDirection="RightToLeft"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== Header ========== -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="قائمة عروض الأسعار"
                       FontSize="{StaticResource PageTitleFontSize}"
                       FontWeight="{StaticResource PageTitleFontWeight}"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <Button Content="عرض جديد" Command="{Binding NewQuotationCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="20,0,0,0"/>
            <Button Content="الصفحة الرئيسية" Command="{Binding HomeCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="10,0,0,0"/>
        </StackPanel>

        <!-- ========== Search + Filter bar (Card) ========== -->
        <Border Grid.Row="1" Margin="0,0,0,15" Padding="16"
                Style="{StaticResource CardStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="بحث:" Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="220" Margin="0,0,15,0"
                         Style="{StaticResource TextBoxStyle}"/>
                <Button Content="بحث" Command="{Binding SearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,15,0"/>

                <TextBlock Text="الحالة:" Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter, UpdateSourceTrigger=PropertyChanged}"
                          Width="160" Margin="0,0,15,0"
                          Style="{StaticResource ComboBoxStyle}"
                          SelectedIndex="0"/>
                <Button Content="تصفية" Command="{Binding SearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- ========== DataGrid with Empty State ========== -->
        <Grid Grid.Row="2">
            <DataGrid ItemsSource="{Binding Quotations}"
                      SelectedItem="{Binding SelectedQuotation}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      IsReadOnly="True"
                      AlternatingRowBackground="{StaticResource AlternatingRowBrush}"
                      RowHeight="42"
                      RowDetailsVisibilityMode="Collapsed"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      HeadersVisibility="Column"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}">
                <DataGrid.Columns>
                    <!-- رقم العرض -->
                    <DataGridTextColumn Header="رقم العرض"
                                        Binding="{Binding QuoteNumber}"
                                        Width="130"/>

                    <!-- التاريخ -->
                    <DataGridTextColumn Header="التاريخ"
                                        Binding="{Binding Date, StringFormat='{}{0:yyyy/MM/dd}'}"
                                        Width="110"/>

                    <!-- الوصف -->
                    <DataGridTextColumn Header="الوصف"
                                        Binding="{Binding Description}"
                                        Width="*"/>

                    <!-- الحالة (Badge) -->
                    <DataGridTemplateColumn Header="الحالة" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding Status}"
                                                ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- فتح -->
                    <DataGridTemplateColumn Header="إجراء" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="فتح"
                                        Command="{Binding DataContext.OpenQuotationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="32"
                                        Padding="12,4"
                                        FontSize="{StaticResource LabelFontSize}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty State Overlay -->
            <ContentControl HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Quotations.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
                <Border Background="Transparent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="40">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="400">
                        <!-- Icon Placeholder -->
                        <Border Width="64" Height="64"
                                CornerRadius="32"
                                Background="{StaticResource BorderLightBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                            <TextBlock Text="📋"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="لا توجد عروض أسعار بعد"
                                   FontSize="{StaticResource SectionTitleFontSize}"
                                   FontWeight="{StaticResource SectionTitleFontWeight}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,8"
                                   FlowDirection="RightToLeft" />
                        <TextBlock Text="اضغط 'عرض جديد' لإنشاء أول عرض"
                                   FontSize="{StaticResource BodyFontSize}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FlowDirection="RightToLeft" />
                    </StackPanel>
                </Border>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
