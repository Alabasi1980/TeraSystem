<UserControl x:Class="TeraQuotation.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:reports="clr-namespace:TeraQuotation.Models.Reports"
             FlowDirection="RightToLeft"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="التقارير" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="الصفحة الرئيسية" Command="{Binding HomeCommand}"
                    Margin="20,0,0,0" Padding="14,7"
                    Background="#1A73E8" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Row 1: Report Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,20">
            <Button Content="📊 تقرير الموردين" Command="{Binding LoadSupplierReportCommand}"
                    Padding="16,10" Margin="0,0,10,0"
                    Background="#2E7D32" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold" FontSize="14">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="🔧 تقرير القطع" Command="{Binding LoadItemReportCommand}"
                    Padding="16,10" Margin="0,0,10,0"
                    Background="#1565C0" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold" FontSize="14">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="📈 إحصائيات" Command="{Binding LoadStatsReportCommand}"
                    Padding="16,10" Margin="0,0,10,0"
                    Background="#6A1B9A" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold" FontSize="14">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="💾 نسخ احتياطي" Command="{Binding BackupCommand}"
                    Padding="16,10" Margin="0,0,10,0"
                    Background="#E65100" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold" FontSize="14">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Row 2: Results Area (scrollable) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- ============ Supplier Report ============ -->
                <StackPanel Visibility="{Binding IsSupplierReport, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ReportTitle}" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <DataGrid ItemsSource="{Binding CurrentReport}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserReorderColumns="False" CanUserSortColumns="True"
                              RowHeight="35" AlternatingRowBackground="#F5F5F5"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="المورد" Binding="{Binding SupplierName}" Width="*" />
                            <DataGridTextColumn Header="عدد العروض" Binding="{Binding QuotationCount}" Width="120" />
                            <DataGridTextColumn Header="القطع" Binding="{Binding Items.Count, StringFormat='{}{0} قطعة'}" Width="120" />
                        </DataGrid.Columns>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding Items}" Margin="30,5">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                                    CornerRadius="4" Padding="6,2" Margin="3">
                                                <TextBlock Text="{Binding}" FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                </StackPanel>

                <!-- ============ Item Report ============ -->
                <StackPanel Visibility="{Binding IsItemReport, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ReportTitle}" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <DataGrid ItemsSource="{Binding CurrentReport}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserReorderColumns="False" CanUserSortColumns="True"
                              RowHeight="35" AlternatingRowBackground="#F5F5F5"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="القطعة" Binding="{Binding ItemName}" Width="*" />
                            <DataGridTextColumn Header="عدد مرات الظهور" Binding="{Binding UsageCount}" Width="140" />
                            <DataGridTextColumn Header="أرقام العروض" Binding="{Binding QuotationNumbers.Count, StringFormat='{}{0} عرض'}" Width="120" />
                        </DataGrid.Columns>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding QuotationNumbers}" Margin="30,5">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                                    CornerRadius="4" Padding="6,2" Margin="3">
                                                <TextBlock Text="{Binding}" FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                </StackPanel>

                <!-- ============ Stats Report ============ -->
                <StackPanel Visibility="{Binding IsStatsReport, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ReportTitle}" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,15" />

                    <!-- Summary Cards Row -->
                    <WrapPanel Margin="0,0,0,20">
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,15" MinWidth="140"
                                Background="#E8F5E9">
                            <StackPanel>
                                <TextBlock Text="📋 المجموع" FontSize="13" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.Total}" FontSize="28"
                                           FontWeight="Bold" Foreground="#2E7D32" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,15" MinWidth="140"
                                Background="#FFF3E0">
                            <StackPanel>
                                <TextBlock Text="📝 مسودة" FontSize="13" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.Draft}" FontSize="28"
                                           FontWeight="Bold" Foreground="#E65100" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,15" MinWidth="140"
                                Background="#E3F2FD">
                            <StackPanel>
                                <TextBlock Text="💰 تم تحديث الأسعار" FontSize="13" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.UpdatedWithPrices}" FontSize="28"
                                           FontWeight="Bold" Foreground="#1565C0" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,15" MinWidth="140"
                                Background="#F3E5F5">
                            <StackPanel>
                                <TextBlock Text="🖨️ مطبوع" FontSize="13" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.Printed}" FontSize="28"
                                           FontWeight="Bold" Foreground="#6A1B9A" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,15" MinWidth="140"
                                Background="#E0F7FA">
                            <StackPanel>
                                <TextBlock Text="📄 PDF" FontSize="13" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.PdfExported}" FontSize="28"
                                           FontWeight="Bold" Foreground="#00838F" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,15" MinWidth="140"
                                Background="#FCE4EC">
                            <StackPanel>
                                <TextBlock Text="📧 أرسل عبر Outlook" FontSize="13" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.SentViaOutlook}" FontSize="28"
                                           FontWeight="Bold" Foreground="#C62828" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,15" MinWidth="140"
                                Background="#E8F5E9">
                            <StackPanel>
                                <TextBlock Text="📅 هذا الأسبوع" FontSize="13" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.ThisWeek}" FontSize="28"
                                           FontWeight="Bold" Foreground="#2E7D32" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,15" MinWidth="140"
                                Background="#E3F2FD">
                            <StackPanel>
                                <TextBlock Text="📅 هذا الشهر" FontSize="13" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.ThisMonth}" FontSize="28"
                                           FontWeight="Bold" Foreground="#1565C0" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- Top Supplier & Top Item -->
                    <WrapPanel>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,0" MinWidth="250"
                                Background="#F1F8E9">
                            <StackPanel>
                                <TextBlock Text="🏆 أفضل مورد" FontSize="14" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.TopSupplier, TargetNullValue='—'}"
                                           FontSize="22" FontWeight="Bold" Foreground="#558B2F" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="20,15" Margin="0,0,15,0" MinWidth="250"
                                Background="#FFF8E1">
                            <StackPanel>
                                <TextBlock Text="🏆 أفضل قطعة" FontSize="14" Foreground="#666" />
                                <TextBlock Text="{Binding CurrentReport.TopItem, TargetNullValue='—'}"
                                           FontSize="22" FontWeight="Bold" Foreground="#F57F17" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <!-- ============ Backup ============ -->
                <StackPanel Visibility="{Binding IsBackupVisible, Converter={StaticResource BoolToVis}}">
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                            Padding="25" Background="#F1F8E9">
                        <StackPanel>
                            <TextBlock Text="💾 النسخ الاحتياطي" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,0,0,15" />
                            <TextBlock Text="{Binding BackupMessage}" FontSize="14"
                                       TextWrapping="Wrap" Margin="0,0,0,15" />
                            <Button Content="🔄 استعادة نسخة احتياطية" Command="{Binding RestoreCommand}"
                                    Padding="16,10" Background="#1565C0" Foreground="White"
                                    BorderThickness="0" HorizontalAlignment="Right"
                                    Cursor="Hand" FontWeight="Bold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6" />
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
