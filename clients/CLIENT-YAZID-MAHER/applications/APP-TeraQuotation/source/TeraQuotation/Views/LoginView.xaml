<UserControl x:Class="TeraQuotation.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:TeraQuotation.ViewModels"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}"
             FlowDirection="RightToLeft"
             mc:Ignorable="d">
    <Grid Background="#F5F5F5">
        <Border Width="380" Height="420"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel VerticalAlignment="Center" Margin="40">
                <!-- Title -->
                <TextBlock Text="TeraQuotation"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1A73E8"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="نظام إدارة عروض الأسعار"
                           FontSize="14"
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- First time setup mode -->
                <TextBlock Text="تعيين كلمة المرور"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Visibility="{Binding IsFirstTime, Converter={StaticResource BoolToVis}}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Normal login mode -->
                <TextBlock Text="تسجيل الدخول"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Visibility="{Binding IsFirstTime, Converter={StaticResource InverseBoolToVis}}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Password field -->
                <TextBlock Text="كلمة المرور"
                           FontSize="13"
                           Foreground="#444"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordInput"
                             FontSize="14"
                             Padding="10,8"
                             BorderBrush="#CCC"
                             BorderThickness="1"
                             VerticalContentAlignment="Center"/>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#D32F2F"
                           FontSize="13"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>

                <!-- Login button (normal mode) -->
                <Button Content="دخول"
                        Click="Login_Click"
                        Visibility="{Binding IsFirstTime, Converter={StaticResource InverseBoolToVis}}"
                        Background="#1A73E8"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Bold"
                        Padding="10,12"
                        Margin="0,16,0,0"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <!-- Set password button (first time mode) -->
                <Button Content="تعيين كلمة المرور"
                        Click="SetPassword_Click"
                        Visibility="{Binding IsFirstTime, Converter={StaticResource BoolToVis}}"
                        Background="#1A73E8"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Bold"
                        Padding="10,12"
                        Margin="0,16,0,0"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <!-- Loading indicator -->
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Margin="0,12,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Foreground="#1A73E8"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
