<UserControl x:Class="TeraQuotation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             FlowDirection="RightToLeft"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="الإعدادات"
                       FontSize="{StaticResource PageTitleFontSize}"
                       FontWeight="{StaticResource PageTitleFontWeight}"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="إدارة الموردين والقطع والترويسة والتوقيعات"
                       FontSize="{StaticResource HelperFontSize}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,12" />

            <!-- Action buttons row -->
            <StackPanel Orientation="Horizontal">
                <Button Content="إنشاء عرض سعر جديد"
                        Command="{Binding GoToQuotationFormCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,10,0" />
                <Button Content="التقارير"
                        Command="{Binding GoToReportsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0" />
                <Button Content="تغيير كلمة المرور"
                        Command="{Binding ChangePasswordCommand}"
                        Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </StackPanel>

        <!-- TabControl with 4 tabs -->
        <TabControl Grid.Row="1">

            <!-- =========== Tab 1: Suppliers =========== -->
            <TabItem Header="الموردين">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Add form -->
                    <Border Grid.Row="0"
                            Style="{StaticResource CardStyle}"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Name field -->
                            <TextBlock Text="اسم المورد:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Row="0" Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0" />
                            <TextBox Text="{Binding NewSupplierName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Row="0" Grid.Column="1"
                                     Margin="8,0,12,0" />

                            <!-- Contact field -->
                            <TextBlock Text="معلومات الاتصال:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Row="0" Grid.Column="2"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding NewSupplierContact, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Row="0" Grid.Column="3"
                                     Margin="8,0,12,0" />

                            <!-- Add button -->
                            <Button Content="إضافة مورد"
                                    Command="{Binding AddSupplierCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Grid.Row="0" Grid.Column="4"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Data area -->
                    <Grid Grid.Row="1">
                        <!-- Empty state (visible when Suppliers.Count == 0) -->
                        <TextBlock Text="لا يوجد موردون بعد. أضف مورداً جديداً."
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Suppliers.Count, FallbackValue=-1}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Suppliers DataGrid -->
                        <DataGrid ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding SelectedSupplier}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeRows="False"
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="{StaticResource AlternatingRowBrush}"
                                  FontSize="{StaticResource BodyFontSize}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  BorderThickness="1"
                                  HeadersVisibility="Column"
                                  RowHeight="40"
                                  MinHeight="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الاسم"
                                                    Binding="{Binding Name}"
                                                    Width="*"
                                                    FontWeight="Bold" />
                                <DataGridTextColumn Header="معلومات الاتصال"
                                                    Binding="{Binding ContactInfo}"
                                                    Width="Auto"
                                                    MinWidth="120" />
                                <DataGridTextColumn Header="ملاحظات"
                                                    Binding="{Binding Notes}"
                                                    Width="Auto"
                                                    MinWidth="120" />
                                <DataGridTemplateColumn Header="إجراء" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="حذف"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Height="30"
                                                    Padding="10,2"
                                                    FontSize="{StaticResource LabelFontSize}"
                                                    Command="{Binding DataContext.DeleteSupplierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- =========== Tab 2: Items =========== -->
            <TabItem Header="القطع">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Search row -->
                    <Border Grid.Row="0"
                            Style="{StaticResource CardStyle}"
                            Padding="16"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="بحث:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0" />
                            <TextBox Text="{Binding ItemSearch, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Width="240"
                                     Margin="8,0,10,0" />
                            <Button Content="بحث"
                                    Command="{Binding SearchItemsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <!-- Add form -->
                    <Border Grid.Row="1"
                            Style="{StaticResource CardStyle}"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Name field -->
                            <TextBlock Text="اسم القطعة:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Column="0"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Column="1"
                                     Margin="8,0,12,0" />

                            <!-- Description field -->
                            <TextBlock Text="الوصف:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Column="2"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding NewItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Column="3"
                                     Margin="8,0,12,0" />

                            <!-- Unit field -->
                            <TextBlock Text="الوحدة:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Column="4"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding NewItemUnit, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Column="5"
                                     Margin="8,0,12,0" />

                            <!-- Add button -->
                            <Button Content="إضافة قطعة"
                                    Command="{Binding AddItemCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Grid.Column="6"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Data area -->
                    <Grid Grid.Row="2">
                        <!-- Empty state -->
                        <TextBlock Text="لا توجد قطع في الكتالوج بعد. أضف قطعة جديدة."
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Items.Count, FallbackValue=-1}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Items DataGrid -->
                        <DataGrid ItemsSource="{Binding Items}"
                                  SelectedItem="{Binding SelectedItem}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeRows="False"
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="{StaticResource AlternatingRowBrush}"
                                  FontSize="{StaticResource BodyFontSize}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  BorderThickness="1"
                                  HeadersVisibility="Column"
                                  RowHeight="40"
                                  MinHeight="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الاسم"
                                                    Binding="{Binding Name}"
                                                    Width="*"
                                                    FontWeight="Bold" />
                                <DataGridTextColumn Header="الوصف"
                                                    Binding="{Binding Description}"
                                                    Width="Auto"
                                                    MinWidth="150" />
                                <DataGridTextColumn Header="الوحدة"
                                                    Binding="{Binding Unit}"
                                                    Width="Auto"
                                                    MinWidth="80" />
                                <DataGridTemplateColumn Header="إجراء" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="حذف"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Height="30"
                                                    Padding="10,2"
                                                    FontSize="{StaticResource LabelFontSize}"
                                                    Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- =========== Tab 3: Signatures =========== -->
            <TabItem Header="التوقيعات">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Add form -->
                    <Border Grid.Row="0"
                            Style="{StaticResource CardStyle}"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="اسم التوقيع:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding NewSignatureName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Width="300"
                                     Margin="8,0,12,0" />
                            <Button Content="إضافة توقيع"
                                    Command="{Binding AddSignatureCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <!-- Data area -->
                    <Grid Grid.Row="1">
                        <!-- Empty state -->
                        <TextBlock Text="لا توجد توقيعات بعد. أضف توقيعاً جديداً."
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Signatures.Count, FallbackValue=-1}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Signatures ListBox -->
                        <ListBox ItemsSource="{Binding Signatures}"
                                 SelectedItem="{Binding SelectedSignature}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 FontSize="{StaticResource BodyFontSize}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 MinHeight="150">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}"
                                            Padding="12,8"
                                            Margin="4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       Width="300"
                                                       VerticalAlignment="Center"
                                                       FontSize="{StaticResource BodyFontSize}"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <Button Content="▲"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Background="{StaticResource BorderLightBrush}"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Width="32"
                                                    Margin="3,0"
                                                    Command="{Binding DataContext.MoveUpSignatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}" />
                                            <Button Content="▼"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Background="{StaticResource BorderLightBrush}"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    Width="32"
                                                    Margin="3,0"
                                                    Command="{Binding DataContext.MoveDownSignatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}" />
                                            <Button Content="حذف"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Height="30"
                                                    Padding="14,2"
                                                    FontSize="{StaticResource LabelFontSize}"
                                                    Margin="10,0,0,0"
                                                    Command="{Binding DataContext.DeleteSignatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- =========== Tab 4: Letterhead =========== -->
            <TabItem Header="الترويسة">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardStyle}"
                            Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Section title -->
                            <TextBlock Text="بيانات الشركة"
                                       Style="{StaticResource CardTitleStyle}"
                                       Grid.Row="0" Grid.ColumnSpan="2" />

                            <!-- Company Name -->
                            <TextBlock Text="اسم الشركة:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Row="1" Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0" />
                            <TextBox Text="{Binding CompanyName}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Row="1" Grid.Column="1"
                                     Margin="0,0,0,12" />

                            <!-- Address -->
                            <TextBlock Text="العنوان:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Row="2" Grid.Column="0"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding CompanyAddress}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Row="2" Grid.Column="1"
                                     Margin="0,0,0,12" />

                            <!-- Phone -->
                            <TextBlock Text="الهاتف:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Row="3" Grid.Column="0"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding CompanyPhone}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Row="3" Grid.Column="1"
                                     Margin="0,0,0,12" />

                            <!-- Email -->
                            <TextBlock Text="البريد:"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Grid.Row="4" Grid.Column="0"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding CompanyEmail}"
                                     Style="{StaticResource TextBoxStyle}"
                                     Grid.Row="4" Grid.Column="1"
                                     Margin="0,0,0,12" />

                            <!-- Save button -->
                            <Button Content="حفظ الإعدادات"
                                    Command="{Binding SaveLetterheadCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Grid.Row="5" Grid.ColumnSpan="2"
                                    HorizontalAlignment="Left"
                                    Margin="0,8,0,0" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
