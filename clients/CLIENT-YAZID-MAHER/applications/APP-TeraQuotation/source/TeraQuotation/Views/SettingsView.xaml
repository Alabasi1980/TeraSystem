<UserControl x:Class="TeraQuotation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             FlowDirection="RightToLeft"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="الإعدادات" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="إنشاء عرض سعر جديد" Command="{Binding GoToQuotationFormCommand}"
                    Margin="20,0,0,0" Padding="12,6"
                    Background="#1A73E8" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="📊 التقارير" Command="{Binding GoToReportsCommand}"
                    Margin="10,0,0,0" Padding="12,6"
                    Background="#2E7D32" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="🔑 تغيير كلمة المرور" Command="{Binding ChangePasswordCommand}"
                    Margin="10,0,0,0" Padding="12,6"
                    Background="#FF9800" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- TabControl with 4 tabs -->
        <TabControl Grid.Row="1">
            <!-- =========== Tab 1: Suppliers =========== -->
            <TabItem Header="الموردين">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <TextBox Text="{Binding NewSupplierName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Margin="0,0,10,0" />
                        <TextBox Text="{Binding NewSupplierContact, UpdateSourceTrigger=PropertyChanged}"
                                 Width="150" Margin="0,0,10,0" />
                        <Button Content="إضافة" Command="{Binding AddSupplierCommand}" Padding="10,5" />
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              CanUserDeleteRows="False" CanUserReorderColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="معلومات الاتصال" Binding="{Binding ContactInfo}" Width="Auto" MinWidth="120" />
                            <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="Auto" MinWidth="120" />
                            <DataGridTemplateColumn Header="إجراء" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="حذف"
                                                Command="{Binding DataContext.DeleteSupplierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- =========== Tab 2: Items =========== -->
            <TabItem Header="القطع">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Search row -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <TextBox Text="{Binding ItemSearch, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Margin="0,0,10,0" />
                        <Button Content="بحث" Command="{Binding SearchItemsCommand}" Padding="10,5" />
                    </StackPanel>

                    <!-- Add form -->
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                        <TextBox Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Margin="0,0,10,0" />
                        <TextBox Text="{Binding NewItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Margin="0,0,10,0" />
                        <TextBox Text="{Binding NewItemUnit, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" Margin="0,0,10,0" />
                        <Button Content="إضافة قطعة" Command="{Binding AddItemCommand}" Padding="10,5" />
                    </StackPanel>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              CanUserDeleteRows="False" CanUserReorderColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="الوصف" Binding="{Binding Description}" Width="Auto" MinWidth="150" />
                            <DataGridTextColumn Header="الوحدة" Binding="{Binding Unit}" Width="Auto" MinWidth="80" />
                            <DataGridTemplateColumn Header="إجراء" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="حذف"
                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- =========== Tab 3: Signatures =========== -->
            <TabItem Header="التوقيعات">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <TextBox Text="{Binding NewSignatureName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300" Margin="0,0,10,0" />
                        <Button Content="إضافة توقيع" Command="{Binding AddSignatureCommand}" Padding="10,5" />
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Signatures}"
                             SelectedItem="{Binding SelectedSignature}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="{Binding Name}" Width="300" VerticalAlignment="Center" />
                                    <Button Content="▲" Width="32" Margin="3,0"
                                            Command="{Binding DataContext.MoveUpSignatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}" />
                                    <Button Content="▼" Width="32" Margin="3,0"
                                            Command="{Binding DataContext.MoveDownSignatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}" />
                                    <Button Content="حذف" Margin="10,0,0,0" Padding="8,2"
                                            Command="{Binding DataContext.DeleteSignatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- =========== Tab 4: Letterhead =========== -->
            <TabItem Header="الترويسة">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="بيانات الشركة" FontSize="18" FontWeight="SemiBold"
                               Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15" />

                    <TextBlock Text="اسم الشركة:" Grid.Row="1" Grid.Column="0"
                               Margin="10" VerticalAlignment="Center" />
                    <TextBox Text="{Binding CompanyName}" Grid.Row="1" Grid.Column="1"
                             Margin="10" Padding="5" />

                    <TextBlock Text="العنوان:" Grid.Row="2" Grid.Column="0"
                               Margin="10" VerticalAlignment="Center" />
                    <TextBox Text="{Binding CompanyAddress}" Grid.Row="2" Grid.Column="1"
                             Margin="10" Padding="5" />

                    <TextBlock Text="الهاتف:" Grid.Row="3" Grid.Column="0"
                               Margin="10" VerticalAlignment="Center" />
                    <TextBox Text="{Binding CompanyPhone}" Grid.Row="3" Grid.Column="1"
                             Margin="10" Padding="5" />

                    <TextBlock Text="البريد:" Grid.Row="4" Grid.Column="0"
                               Margin="10" VerticalAlignment="Center" />
                    <TextBox Text="{Binding CompanyEmail}" Grid.Row="4" Grid.Column="1"
                             Margin="10" Padding="5" />

                    <Button Content="حفظ الإعدادات" Command="{Binding SaveLetterheadCommand}"
                            Grid.Row="5" Grid.ColumnSpan="2"
                            HorizontalAlignment="Left" Margin="10,15" Padding="18,10"
                            Background="#1A73E8" Foreground="White" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
