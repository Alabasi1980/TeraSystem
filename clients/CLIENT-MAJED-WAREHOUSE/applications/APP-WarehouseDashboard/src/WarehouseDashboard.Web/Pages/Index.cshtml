@page "{slug?}"
@model WarehouseDashboard.Web.Pages.IndexModel
@{ 
    ViewData["Title"] = Model.CurrentDashboard?.Name ?? "لوحة المعلومات";
    Layout = "_DashboardLayout";

    string NormalizeDescription(string? value)
        => string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim();

    var normalizedCards = Model.Cards
        .Select(c => new
        {
            Card = c,
            Description = NormalizeDescription(c.Description)
        })
        .ToList();
}

@Html.AntiForgeryToken()

@* CSS moved to wwwroot/css/dashboard.css (loaded via _DashboardLayout.cshtml) *@

<div class="wd-page-head">
    <div style="display:flex;align-items:center;gap:8px;">
        <h2 class="wd-page-title">@(Model.CurrentDashboard?.Name ?? "لوحة المعلومات")</h2>
        <button type="button" class="wd-btn wd-btn--ghost wd-btn--sm" id="wd-focus-toggle" title="وضع التركيز" aria-label="وضع التركيز">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 3H5a2 2 0 00-2 2v3"/><path d="M21 8V5a2 2 0 00-2-2h-3"/><path d="M16 21h3a2 2 0 002-2v-3"/><path d="M3 16v3a2 2 0 002 2h3"/>
            </svg>
        </button>
    </div>
    <span class="wd-card__type">@Model.Cards.Count بطاقة نشطة</span>
</div>

@if (Model.AllDashboards.Count > 1)
{
    <nav class="wd-tab-bar" aria-label="التنقل بين الداشبوردات">
        @foreach (var dash in Model.AllDashboards)
        {
            var isActive = dash.Id == Model.CurrentDashboard?.Id;
            var href = string.IsNullOrEmpty(dash.Slug) ? "/" : "/" + dash.Slug;
            <a href="@href"
               class="wd-tab @(isActive ? "wd-tab--active" : "")"
               aria-current="@(isActive ? "page" : "false")">
                <span class="wd-tab__icon">@dash.Icon</span>
                <span class="wd-tab__label">@dash.Name</span>
            </a>
        }
    </nav>
}

@if (Model.ConfigError)
{
    <div class="wd-card wd-empty" style="grid-column: 1 / -1;">
        <div class="wd-empty__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        <h3>تعذر الاتصال بقاعدة بيانات الإعدادات</h3>
        <p>تأكد من ضبط متغيّر البيئة SQL_PASSWORD وأن خادم SQL متاح، ثم أعد التحميل.</p>
    </div>
}
else if (Model.Cards.Count == 0)
{
    <div class="wd-card wd-empty" style="grid-column: 1 / -1;">
        <div class="wd-empty__icon" style="width:84px;height:84px;border-radius:var(--radius-xl);background:rgba(31,78,121,0.06);">
            <svg xmlns="http://www.w3.org/2000/svg" width="84" height="84" viewBox="0 0 84 84" fill="none">
                <!-- Background subtle grid container -->
                <rect x="12" y="12" width="60" height="60" rx="8" fill="rgba(31,78,121,0.06)" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.12"/>
                <!-- Card 1 (top-left, large) -->
                <rect x="18" y="18" width="36" height="24" rx="5" fill="currentColor" fill-opacity="0.1" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.2"/>
                <rect x="22" y="22" width="16" height="3" rx="1.5" fill="currentColor" fill-opacity="0.25"/>
                <rect x="22" y="28" width="28" height="2" rx="1" fill="currentColor" fill-opacity="0.12"/>
                <rect x="22" y="33" width="20" height="2" rx="1" fill="currentColor" fill-opacity="0.12"/>
                <!-- Card 2 (top-right, small) -->
                <rect x="58" y="18" width="18" height="24" rx="5" fill="currentColor" fill-opacity="0.08" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.2"/>
                <rect x="62" y="22" width="10" height="3" rx="1.5" fill="currentColor" fill-opacity="0.2"/>
                <!-- Card 3 (bottom, wide) -->
                <rect x="18" y="46" width="58" height="20" rx="5" fill="currentColor" fill-opacity="0.08" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.2"/>
                <rect x="22" y="50" width="16" height="3" rx="1.5" fill="currentColor" fill-opacity="0.2"/>
                <rect x="22" y="56" width="48" height="2" rx="1" fill="currentColor" fill-opacity="0.12"/>
            </svg>
        </div>
        <h3>لا توجد بطاقات معروضة</h3>
        <p>لم يتم تكوين أي بطاقة نشطة بعد. أضف بطاقات من لوحة الإدارة.</p>
    </div>
}
else
{
    <div class="wd-filterbar" role="search">
        <div class="wd-filterbar__search">
            <span class="wd-filterbar__icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </span>
            <input type="search" id="wd-search" placeholder="ابحث بعنوان البطاقة…" autocomplete="off"
                   aria-label="بحث في البطاقات" />
        </div>
        <select id="wd-type-filter" class="wd-filterbar__select" aria-label="تصفية حسب نوع الرسم البياني">
            <option value="All">كل الأنواع</option>
            <option value="Bar">أعمدة (Bar)</option>
            <option value="Line">خطي (Line)</option>
            <option value="Pie">دائري (Pie)</option>
            <option value="KPI">مؤشر (KPI)</option>
            <option value="Table">جدول (Table)</option>
            <option value="Gauge">مقياس (Gauge)</option>
        </select>
        <div class="wd-filterbar__presets" role="group" aria-label="اختيارات التاريخ السريعة">
            <button class="wd-preset-btn active" data-preset="today">اليوم</button>
            <button class="wd-preset-btn" data-preset="yesterday">أمس</button>
            <button class="wd-preset-btn" data-preset="7days">آخر 7 أيام</button>
            <button class="wd-preset-btn" data-preset="30days">آخر 30 يوم</button>
            <button class="wd-preset-btn" data-preset="month">هذا الشهر</button>
            <button class="wd-preset-btn" data-preset="lastMonth">الشهر الماضي</button>
            <button class="wd-preset-btn" data-preset="custom">مخصص</button>
        </div>
        <div class="wd-filterbar__custom-dates wd-hidden" id="wd-custom-dates">
            <input type="date" id="wd-date-from" class="wd-filterbar__date-input" aria-label="من تاريخ" />
            <span class="wd-filterbar__date-sep">—</span>
            <input type="date" id="wd-date-to" class="wd-filterbar__date-input" aria-label="إلى تاريخ" />
        </div>
        <button type="button" id="wd-layout-edit-toggle" class="wd-btn--ghost wd-btn--sm" style="flex-shrink:0;white-space:nowrap;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            تعديل التخطيط
        </button>
        <span class="wd-filterbar__count" id="wd-filter-count"></span>
    </div>

    <span class="wd-last-updated" id="wd-last-updated">آخر تحديث: الآن</span>

    <div class="wd-dashboard-grid" id="wd-dashboard-grid">
        @for (var i = 0; i < normalizedCards.Count; i++)
        {
            var c = normalizedCards[i].Card;
            var description = normalizedCards[i].Description;
            var w = Math.Max(1, Math.Min(c.GridWidth, 12));
            var h = Math.Max(1, Math.Min(c.GridHeight, 6));
            var colStart = Math.Max(1, Math.Min(c.GridPositionX < 1 ? 1 : c.GridPositionX, 13 - w));
            var rowStart = Math.Max(1, c.GridPositionY);
                var cardHeight = Math.Max(200, h * 90 + (h - 1) * 24);
                var canDrill = Model.CardsWithDrill.Contains(c.Id);
                <article class="wd-card wd-span-@w wd-row-@h@(canDrill ? " wd-card--drillable" : "")"
                         style="height: @(cardHeight)px; animation-delay: @(i * 70)ms;"
                         id="card-@c.Id"
                         data-card-id="@c.Id"
                         data-description="@description"
                         data-color-palette="@c.ColorPalette"
                         data-refresh-interval="@c.RefreshInterval"
                         data-grid-height="@h"
                         data-grid-x="@colStart"
                         data-grid-y="@rowStart"
                         data-grid-w="@w"
                         data-grid-h="@h"
                         data-title="@c.Title"
                         data-chart-type="@c.ChartType">
                    <div class="wd-card__header">
                        <div class="wd-card__title-wrap">
                            <h3 class="wd-card__title">@c.Title</h3>
                            @if (c.AssistantEnabled)
                            {
                                <button class="card-assistant-btn" 
                                        onclick='openAssistantPanel(@c.Id, @Html.Raw(Json.Serialize(c.Title)))'
                                        title="تحليل البطاقة" aria-label="فتح مساعد تحليل البطاقة">
                                    💡
                                </button>
                            }
                            @if (!string.IsNullOrEmpty(description))
                            {
                                <span class="wd-card__hint"
                                      tabindex="0"
                                      title="@description"
                                      data-tooltip="@description"
                                      aria-label="وصف البطاقة: @description">
                                    <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                        <circle cx="10" cy="10" r="7"></circle>
                                        <path d="M10 8.2h.01"></path>
                                        <path d="M10 11v3"></path>
                                    </svg>
                                </span>
                            }
                        </div>
                        <div class="wd-card__controls">
                            @if (canDrill)
                            {
                                <button type="button" class="wd-card__drill-btn"
                                        title="فتح التعمّق"
                                        aria-label="فتح التعمّق"
                                        onclick="event.stopPropagation();wdOpenDrill(@c.Id)">تفاصيل</button>
                            }
                            <div class="wd-card__resize" role="group" aria-label="تغيير حجم البطاقة" hidden aria-hidden="true">
                                <button class="wd-resize-btn @(w <= 3 ? "active" : "")" data-size="small" title="صغير" type="button">S</button>
                                <button class="wd-resize-btn @(w > 3 && w <= 7 ? "active" : "")" data-size="medium" title="متوسط" type="button">M</button>
                                <button class="wd-resize-btn @(w > 7 ? "active" : "")" data-size="large" title="كبير" type="button">L</button>
                            </div>
                            <button class="wd-card__refresh" title="تحديث البطاقة" type="button" aria-label="تحديث البطاقة">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M23 4v6h-6"/><path d="M1 20v-6h6"/>
                                    <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
                                </svg>
                            </button>
                            <span class="wd-card__type">@c.ChartType</span>
                        </div>
                    </div>
                    @* Date filter mode indicator (TASK-CARD-UX-006) *@
                    @if (c.DateFilterMode == "fixed")
                    {
                        var from = string.IsNullOrEmpty(c.FixedStartDate) ? "?" : c.FixedStartDate;
                        var to = string.IsNullOrEmpty(c.FixedEndDate) ? "?" : c.FixedEndDate;
                        <span class="wd-card__date-mode wd-card__date-mode--fixed">@from ← @to</span>
                    }
                    else if (c.DateFilterMode == "relative")
                    {
                        <span class="wd-card__date-mode wd-card__date-mode--relative">آخر @c.RelativeDays أيام</span>
                    }
                    <div class="wd-card__body">
                        <div class="wd-skeleton-wrap" aria-hidden="true">
                            <div class="wd-skel wd-skel--tall"></div>
                        </div>
                    </div>
                </article>
            }
        </div>

        <div class="wd-filter-empty wd-hidden" id="wd-filter-empty" aria-live="polite">
            <div class="wd-filter-empty__icon" aria-hidden="true">
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </div>
            <h3>لا توجد بطاقات مطابقة</h3>
            <p>جرّب تعديل كلمة البحث أو نوع الرسم البياني.</p>
        </div>

        @* Drill-down Modal (TASK-DRILL-SMARTTABLE-001) — Smart Table with sort/search/pagination *@
        <div id="wd-drill-modal" class="wd-modal" hidden aria-modal="true" role="dialog">
            <div class="wd-modal__overlay" tabindex="-1"></div>
            <div class="wd-modal__panel wd-modal__panel--xl">
                <div class="wd-modal__header">
                    <h3 class="wd-modal__title" id="wd-drill-modal-title">
                        <span class="wd-modal__title-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="18" y1="20" x2="18" y2="10"/>
                                <line x1="12" y1="20" x2="12" y2="4"/>
                                <line x1="6" y1="20" x2="6" y2="14"/>
                            </svg>
                        </span>
                        <span id="wd-drill-modal-title-text"></span>
                    </h3>
                    <button class="wd-modal__close" aria-label="إغلاق" type="button">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                        </svg>
                    </button>
                </div>
                <div class="wd-modal__breadcrumb" id="wd-drill-modal-breadcrumb"></div>
                @* Toolbar: search, info, page size (hidden by default, shown for table) *@
                <div id="wd-drill-toolbar" class="wd-drill-toolbar" hidden>
                    <div class="wd-drill-toolbar__search">
                        <input type="text" id="wd-drill-search" placeholder="بحث في الجدول..." aria-label="بحث في الجدول">
                        <span class="wd-drill-toolbar__search-icon" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                            </svg>
                        </span>
                    </div>
                    <span class="wd-drill-toolbar__info" id="wd-drill-info"></span>
                    <select id="wd-drill-page-size" class="wd-drill-toolbar__pagesize" aria-label="عدد الصفوف في الصفحة">
                        <option value="25">25 صف</option>
                        <option value="50" selected>50 صف</option>
                        <option value="100">100 صف</option>
                    </select>
                </div>
                <div class="wd-modal__body" id="wd-drill-modal-body"></div>
                @* Pagination bar (hidden by default, shown for table) *@
                <div id="wd-drill-pagination" class="wd-drill-pagination" hidden>
                    <span class="wd-drill-pagination__info" id="wd-page-info"></span>
                    <div class="wd-drill-pagination__controls">
                        <button type="button" id="wd-page-prev" class="wd-drill-pagination__btn" title="الصفحة السابقة" aria-label="الصفحة السابقة">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                        </button>
                        <span id="wd-page-btns" class="wd-drill-pagination__controls"></span>
                        <button type="button" id="wd-page-next" class="wd-drill-pagination__btn" title="الصفحة التالية" aria-label="الصفحة التالية">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                        </button>
                    </div>
                </div>
                <div class="wd-modal__footer" id="wd-drill-modal-footer"></div>
            </div>
        </div>
    }
@section Scripts {
    <script>
        window.SYNC_API_BASE = '@Model.SyncApiBaseUrl';
        window.WD_CARDS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(normalizedCards.Select(cardInfo => new {
            id = cardInfo.Card.Id,
            title = cardInfo.Card.Title,
            description = cardInfo.Description,
            chartType = cardInfo.Card.ChartType,
            colorPalette = cardInfo.Card.ColorPalette,
            refreshInterval = cardInfo.Card.RefreshInterval,
            gridPositionX = cardInfo.Card.GridPositionX,
            gridPositionY = cardInfo.Card.GridPositionY,
            gridWidth = cardInfo.Card.GridWidth,
            gridHeight = cardInfo.Card.GridHeight
        })));
    </script>
    <script src="~/js/dashboard-page.js"></script>
}
