@page
@model WarehouseDashboard.Web.Pages.IndexModel
@{
    ViewData["Title"] = "لوحة المعلومات";
    Layout = "_DashboardLayout";
}

<style>
    /* ===== Filter bar (TASK-COD-014) — tokens from blue-theme.css ===== */
    .wd-filterbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--sp-3);
        margin-bottom: var(--sp-6);
        padding: var(--sp-4);
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
    }
    .wd-filterbar__search {
        position: relative;
        flex: 1 1 260px;
        min-width: 0;
    }
    .wd-filterbar__icon {
        position: absolute;
        inset-inline-end: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--c-text-muted);
        pointer-events: none;
        font-size: 15px;
    }
    .wd-filterbar__search input {
        width: 100%;
        font-family: var(--font-ar);
        font-size: 14px;
        color: var(--c-text);
        background: var(--c-bg);
        border: 1px solid var(--c-border);
        border-radius: var(--radius-md);
        padding: 10px 38px 10px 14px;
        transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
    }
    .wd-filterbar__search input::placeholder { color: var(--c-text-muted); }
    .wd-filterbar__search input:focus {
        outline: none;
        border-color: var(--c-primary);
        box-shadow: 0 0 0 3px rgba(31, 78, 121, 0.18);
    }
    .wd-filterbar__select {
        font-family: var(--font-ar);
        font-size: 14px;
        font-weight: 600;
        color: var(--c-text);
        background: var(--c-bg);
        border: 1px solid var(--c-border);
        border-radius: var(--radius-md);
        padding: 10px 14px;
        cursor: pointer;
        transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
    }
    .wd-filterbar__select:focus {
        outline: none;
        border-color: var(--c-primary);
        box-shadow: 0 0 0 3px rgba(31, 78, 121, 0.18);
    }
    .wd-filterbar__count {
        font-size: 13px;
        font-weight: 600;
        color: var(--c-text-muted);
        margin-inline-start: auto;
        white-space: nowrap;
    }

    /* ===== No-results empty state (TASK-COD-014) ===== */
    .wd-filter-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--sp-3);
        padding: var(--sp-12) var(--sp-6);
        text-align: center;
        animation: wdFadeUp var(--dur-norm) var(--ease) both;
    }
    .wd-filter-empty__icon {
        width: 72px; height: 72px;
        border-radius: var(--radius-full);
        background: var(--c-surface-muted);
        color: var(--c-text-muted);
        display: flex; align-items: center; justify-content: center;
        font-size: 34px;
    }
    .wd-filter-empty h3 { margin: 0; font-size: 18px; color: var(--c-text); }
    .wd-filter-empty p { margin: 0; color: var(--c-text-muted); }

    /* ===== Filtering collapse transition (TASK-COD-014) ===== */
    .wd-card {
        transition: box-shadow var(--dur-norm) var(--ease),
                    transform var(--dur-norm) var(--ease),
                    opacity var(--dur-norm) var(--ease);
    }
    .wd-card.wd-card--fade {
        opacity: 0;
        transform: scale(0.92);
        pointer-events: none;
    }
    .wd-card.wd-hidden { display: none !important; }

    /* Info toast variant (TASK-COD-014 no-results hint) — token from blue-theme.css */
    .wd-toast--info { border-inline-start-color: var(--c-info); }
    .wd-toast--info .wd-toast__icon { background: var(--c-info); }

    /* ===== Advanced KPI Styles (TASK-KPI-005) ===== */
    .wd-kpi {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        gap: var(--sp-2);
        padding: var(--sp-3);
    }

    .wd-kpi__value {
        font-size: 32px;
        font-weight: 700;
        color: var(--c-text);
        line-height: 1.2;
    }

    .wd-kpi__label {
        font-size: 13px;
        color: var(--c-text-muted);
        font-weight: 500;
    }

    /* Change badge */
    .wd-kpi__change {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: var(--radius-full);
        font-size: 13px;
        font-weight: 600;
        line-height: 1;
    }

    .wd-kpi__change--up {
        background: rgba(16, 185, 129, 0.12);
        color: #059669;
    }

    .wd-kpi__change--down {
        background: rgba(239, 68, 68, 0.12);
        color: #DC2626;
    }

    .wd-kpi__change--flat {
        background: rgba(107, 114, 128, 0.12);
        color: #6B7280;
    }

    /* Sparkline container */
    .wd-kpi__sparkline {
        width: 100%;
        height: 60px;
        margin-top: var(--sp-1);
    }

    /* Grand total */
    .wd-kpi__total {
        font-size: 12px;
        color: var(--c-text-muted);
        font-weight: 500;
        margin-top: var(--sp-1);
        padding-top: var(--sp-1);
        border-top: 1px solid var(--c-border);
        width: 100%;
        text-align: center;
    }

    /* ===== Drillable card affordance (TASK-COD-012) ===== */
    .wd-card--drillable { position: relative; }
    .wd-card--drillable:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }
    .wd-card--drillable:focus-visible { outline: 2px solid var(--c-secondary); outline-offset: 2px; }
    .wd-card__drill-hint {
        position: absolute;
        inset-inline-end: 12px;
        bottom: 10px;
        width: 26px; height: 26px;
        display: flex; align-items: center; justify-content: center;
        border-radius: var(--radius-full);
        background: var(--c-primary);
        color: #fff;
        font-size: 18px; font-weight: 700;
        box-shadow: var(--shadow-sm);
        opacity: 0;
        transform: translateX(-4px);
        transition: opacity var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease);
    }
    .wd-card--drillable:hover .wd-card__drill-hint,
    .wd-card--drillable:focus-visible .wd-card__drill-hint { opacity: 1; transform: translateX(0); }

    /* ===== Feature: Focus Mode ===== */
    .wd-dashboard--focus .wd-topbar,
    .wd-dashboard--focus .wd-page-head,
    .wd-dashboard--focus .wd-filterbar,
    .wd-dashboard--focus .wd-footer-area { display: none; }

    .wd-dashboard--focus .wd-content {
        max-width: 100%; padding: var(--sp-3);
    }

    .wd-dashboard--focus .wd-card {
        box-shadow: var(--shadow-lg);
    }

    /* ===== Feature: Last Updated Timestamp ===== */
    .wd-last-updated {
        display: block;
        font-size: 12px;
        color: var(--c-text-muted);
        text-align: end;
        margin-top: var(--sp-2);
        margin-bottom: var(--sp-1);
        font-weight: 500;
    }
</style>

<div class="wd-page-head">
    <div style="display:flex;align-items:center;gap:8px;">
        <h2 class="wd-page-title">لوحة المعلومات</h2>
        <button type="button" class="wd-btn wd-btn--ghost wd-btn--sm" id="wd-focus-toggle" title="وضع التركيز" aria-label="وضع التركيز">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 3H5a2 2 0 00-2 2v3"/><path d="M21 8V5a2 2 0 00-2-2h-3"/><path d="M16 21h3a2 2 0 002-2v-3"/><path d="M3 16v3a2 2 0 002 2h3"/>
            </svg>
        </button>
    </div>
    <span class="wd-card__type">@Model.Cards.Count بطاقة نشطة</span>
</div>

@if (Model.ConfigError)
{
    <div class="wd-card wd-empty" style="grid-column: 1 / -1;">
        <div class="wd-empty__icon">⚠</div>
        <h3>تعذر الاتصال بقاعدة بيانات الإعدادات</h3>
        <p>تأكد من ضبط متغيّر البيئة SQL_PASSWORD وأن خادم SQL متاح، ثم أعد التحميل.</p>
    </div>
}
else if (Model.Cards.Count == 0)
{
    <div class="wd-card wd-empty" style="grid-column: 1 / -1;">
        <div class="wd-empty__icon" style="width:84px;height:84px;border-radius:var(--radius-xl);background:rgba(31,78,121,0.06);">
            <svg xmlns="http://www.w3.org/2000/svg" width="84" height="84" viewBox="0 0 84 84" fill="none">
                <!-- Background subtle grid container -->
                <rect x="12" y="12" width="60" height="60" rx="8" fill="rgba(31,78,121,0.06)" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.12"/>
                <!-- Card 1 (top-left, large) -->
                <rect x="18" y="18" width="36" height="24" rx="5" fill="currentColor" fill-opacity="0.1" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.2"/>
                <rect x="22" y="22" width="16" height="3" rx="1.5" fill="currentColor" fill-opacity="0.25"/>
                <rect x="22" y="28" width="28" height="2" rx="1" fill="currentColor" fill-opacity="0.12"/>
                <rect x="22" y="33" width="20" height="2" rx="1" fill="currentColor" fill-opacity="0.12"/>
                <!-- Card 2 (top-right, small) -->
                <rect x="58" y="18" width="18" height="24" rx="5" fill="currentColor" fill-opacity="0.08" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.2"/>
                <rect x="62" y="22" width="10" height="3" rx="1.5" fill="currentColor" fill-opacity="0.2"/>
                <!-- Card 3 (bottom, wide) -->
                <rect x="18" y="46" width="58" height="20" rx="5" fill="currentColor" fill-opacity="0.08" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.2"/>
                <rect x="22" y="50" width="16" height="3" rx="1.5" fill="currentColor" fill-opacity="0.2"/>
                <rect x="22" y="56" width="48" height="2" rx="1" fill="currentColor" fill-opacity="0.12"/>
            </svg>
        </div>
        <h3>لا توجد بطاقات معروضة</h3>
        <p>لم يتم تكوين أي بطاقة نشطة بعد. أضف بطاقات من لوحة الإدارة.</p>
    </div>
}
else
{
    <div class="wd-filterbar" role="search">
        <div class="wd-filterbar__search">
            <span class="wd-filterbar__icon" aria-hidden="true">🔍</span>
            <input type="search" id="wd-search" placeholder="ابحث بعنوان البطاقة…" autocomplete="off"
                   aria-label="بحث في البطاقات" />
        </div>
        <select id="wd-type-filter" class="wd-filterbar__select" aria-label="تصفية حسب نوع الرسم البياني">
            <option value="All">كل الأنواع</option>
            <option value="Bar">أعمدة (Bar)</option>
            <option value="Line">خطي (Line)</option>
            <option value="Pie">دائري (Pie)</option>
            <option value="KPI">مؤشر (KPI)</option>
            <option value="Table">جدول (Table)</option>
            <option value="Gauge">مقياس (Gauge)</option>
        </select>
        <span class="wd-filterbar__count" id="wd-filter-count"></span>
    </div>

    <span class="wd-last-updated" id="wd-last-updated">آخر تحديث: الآن</span>

    <div class="wd-dashboard-grid">
        @for (var i = 0; i < Model.Cards.Count; i++)
        {
            var c = Model.Cards[i];
            var w = Math.Max(1, Math.Min(c.GridWidth, 12));
            var h = Math.Max(1, Math.Min(c.GridHeight, 6));
            var colStart = Math.Max(1, Math.Min(c.GridPositionX < 1 ? 1 : c.GridPositionX, 13 - w));
            var rowStart = Math.Max(1, c.GridPositionY);
                var cardHeight = Math.Max(200, h * 90 + (h - 1) * 24);
                var canDrill = Model.CardsWithDrill.Contains(c.Id);
                <article class="wd-card wd-span-@w wd-row-@h@(canDrill ? " wd-card--drillable" : "")"
                         style="grid-column-start: @colStart; grid-row-start: @rowStart; height: @(cardHeight)px; animation-delay: @(i * 70)ms;@(canDrill ? " cursor:pointer;" : "")"
                         id="card-@c.Id"
                         data-card-id="@c.Id"
                         data-grid-height="@h"
                         data-title="@c.Title"
                         data-chart-type="@c.ChartType"
                         @(canDrill ? "onclick=\"wdOpenDrill(" + c.Id + ")\" role=\"button\" tabindex=\"0\" onkeydown=\"if(event.key==='Enter')wdOpenDrill(" + c.Id + ")\"" : "")>
                    <div class="wd-card__header">
                        <h3 class="wd-card__title">@c.Title</h3>
                        <span class="wd-card__type">@c.ChartType</span>
                    </div>
                    <div class="wd-card__body">
                        <div class="wd-skeleton-wrap" aria-hidden="true">
                            <div class="wd-skel wd-skel--tall"></div>
                        </div>
                    </div>
                    @if (canDrill)
                    {
                        <span class="wd-card__drill-hint" title="انقر للتعمّق" aria-hidden="true">›</span>
                    }
                </article>
            }
        </div>

        <div class="wd-filter-empty wd-hidden" id="wd-filter-empty" aria-live="polite">
            <div class="wd-filter-empty__icon" aria-hidden="true">🔍</div>
            <h3>لا توجد بطاقات مطابقة</h3>
            <p>جرّب تعديل كلمة البحث أو نوع الرسم البياني.</p>
        </div>
    }

@section Scripts {
    <script>
        // Configurable Sync API base URL (C4: read from appsettings.json, not hardcoded).
        window.SYNC_API_BASE = '@Model.SyncApiBaseUrl';

        // Card ids rendered server-side — drives the per-card fetch loop.
        window.WD_CARDS = [@Html.Raw(string.Join(",", Model.Cards.Select(c => "{\"id\":" + c.Id + "}")))];

        (function () {
            var PALETTE = window.WD_PALETTE || ['#1F4E79', '#163A5A', '#2E6DA4', '#0A2540', '#8FBCDE', '#5B7A99'];
            var CHARTS = {}; // id -> control instance (for resize refresh)

            // Shared utilities (toNum, isNum, formatNum, escapeHtml, showToast,
            // wdEmptyHtml, wdErrorHtml) are provided by ~/js/dashboard-utils.js.

            function animateCountUp(el, target, duration) {
                if (!el) return;
                var start = 0;
                var startTime = null;
                function step(timestamp) {
                    if (!startTime) startTime = timestamp;
                    var progress = Math.min((timestamp - startTime) / duration, 1);
                    // Ease out cubic
                    var eased = 1 - Math.pow(1 - progress, 3);
                    var current = Math.round(start + (target - start) * eased);
                    el.textContent = formatNum ? formatNum(current) : current.toLocaleString();
                    if (progress < 1) {
                        requestAnimationFrame(step);
                    } else {
                        el.textContent = formatNum ? formatNum(target) : target.toLocaleString();
                    }
                }
                requestAnimationFrame(step);
            }

            function wdKpiHtml(card) {
                var val = card.kpiMainValue || card.kpiValue;
                var target = toNum(val);
                var display = target === 0 ? '0' : '0';
                var kpiMode = card.kpiMode || 'simple';

                var html = '<div class="wd-kpi">';

                // Main value
                html += '<div class="wd-kpi__value" data-kpi-target="' + target + '">' + display + '</div>';

                // Change badge (for withChange and composite modes)
                if ((kpiMode === 'withChange' || kpiMode === 'composite') && card.kpiChangePercent !== null && card.kpiChangePercent !== undefined) {
                    var changePercent = card.kpiChangePercent;
                    var direction = card.kpiChangeDirection || 'flat';
                    var arrow = direction === 'up' ? '↑' : direction === 'down' ? '↓' : '→';
                    var changeClass = 'wd-kpi__change--' + direction;
                    html += '<div class="wd-kpi__change ' + changeClass + '">' + arrow + ' ' + Math.abs(changePercent) + '%</div>';
                }

                // Sparkline container (for composite mode)
                if (kpiMode === 'composite' && card.kpiSparklineData && card.kpiSparklineData.length > 0) {
                    html += '<div class="wd-kpi__sparkline" data-card-id="' + card.cardId + '"></div>';
                }

                // Grand total (for composite mode)
                if (kpiMode === 'composite' && card.kpiGrandTotal !== null && card.kpiGrandTotal !== undefined) {
                    var grandTotal = card.kpiGrandTotal;
                    var grandDisplay = grandTotal !== null ? formatNum(toNum(grandTotal)) : '—';
                    html += '<div class="wd-kpi__total">الإجمالي: ' + grandDisplay + '</div>';
                }

                // Label
                html += '<div class="wd-kpi__label">قيمة المؤشر</div>';
                html += '</div>';

                return html;
            }

            function wdRenderSparkline(container, data) {
                var chartData = data.map(function(r) {
                    return { label: r.Month || r.month || '', value: toNum(r.MonthlyValue || r.monthlyValue || 0) };
                });

                var chart = new ej.charts.Chart({
                    theme: 'Bootstrap5',
                    series: [{
                        type: 'Line',
                        dataSource: chartData,
                        xName: 'label',
                        yName: 'value',
                        width: 2,
                        marker: { visible: false },
                        fill: '#1F4E79'
                    }],
                    primaryXAxis: {
                        valueType: 'Category',
                        majorGridLines: { width: 0 },
                        labelStyle: { color: '#5B7A99', fontSize: '10px' }
                    },
                    primaryYAxis: {
                        majorGridLines: { width: 0 },
                        labelStyle: { display: false }
                    },
                    tooltip: { enable: true, fill: '#0A2540', textStyle: { color: '#ffffff' } },
                    width: '100%',
                    height: '60px'
                });
                chart.appendTo(container);
            }

            function clearBody(el) {
                var body = el.querySelector('.wd-card__body');
                body.innerHTML = '';
                return body;
            }

            function wdRenderCard(card) {
                var el = document.getElementById('card-' + card.cardId);
                if (!el) return;
                var body = clearBody(el);

                if (card.status === 'empty') { body.innerHTML = wdEmptyHtml(); return; }
                if (card.status === 'error') { body.innerHTML = wdErrorHtml(card.errorMessage, card.cardId); return; }

                try {
                    if (card.chartType === 'KPI') {
                        body.innerHTML = wdKpiHtml(card);
                        var kpiVal = body.querySelector('.wd-kpi__value');
                        if (kpiVal) animateCountUp(kpiVal, toNum(card.kpiMainValue || card.kpiValue), 1000);

                        // Render sparkline if present
                        if (card.kpiMode === 'composite' && card.kpiSparklineData && card.kpiSparklineData.length > 0) {
                            var sparkContainer = body.querySelector('.wd-kpi__sparkline');
                            if (sparkContainer) {
                                wdRenderSparkline(sparkContainer, card.kpiSparklineData);
                            }
                        }
                        return;
                    }
                    if (!card.columns || card.columns.length < 1) { body.innerHTML = wdEmptyHtml(); return; }

                    var viz = document.createElement('div');
                    viz.style.width = '100%';
                    viz.style.height = '100%';
                    viz.style.minHeight = '180px';
                    body.appendChild(viz);

                    if (card.chartType === 'Table') { wdRenderGrid(viz, card); return; }
                    if (card.chartType === 'Gauge') { wdRenderGauge(viz, card); return; }
                    wdRenderChart(viz, card);
                } catch (e) {
                    body.innerHTML = wdErrorHtml('تعذر عرض العنصر: ' + (e && e.message ? e.message : e), card.cardId);
                }
            }

            function wdRenderChart(viz, card) {
                var cols = card.columns;
                var data = (card.rows || []).map(function (r) {
                    return { label: r[cols[0]], value: toNum(r[cols[1]]) };
                });
                var typeMap = { Bar: 'Column', Line: 'Line', Pie: 'Pie' };
                var type = typeMap[card.chartType] || 'Column';
                var isPie = card.chartType === 'Pie';

                var chart = new ej.charts.Chart({
                    theme: 'Bootstrap5',
                    palette: PALETTE,
                    primaryXAxis: {
                        valueType: 'Category',
                        labelStyle: { color: '#5B7A99' },
                        lineStyle: { color: '#D4E2F0' },
                        majorGridLines: { width: 0 },
                        title: isPie ? '' : (cols[0] || '')
                    },
                    primaryYAxis: {
                        labelStyle: { color: '#5B7A99' },
                        lineStyle: { color: '#D4E2F0' },
                        majorGridLines: { color: '#D4E2F0', width: 0.5 }
                    },
                    legendSettings: { visible: isPie, position: 'Bottom', textStyle: { color: '#5B7A99' } },
                    tooltip: { enable: true, fill: '#0A2540', textStyle: { color: '#ffffff' } },
                    series: [{
                        type: type,
                        dataSource: data,
                        xName: 'label',
                        yName: 'value',
                        name: card.title,
                        cornerRadius: card.chartType === 'Bar' ? { topLeft: 4, topRight: 4 } : undefined,
                        marker: card.chartType === 'Line' ? { visible: true, width: 2, height: 6 } : undefined,
                        dataLabel: isPie ? { visible: true, position: 'Outside' } : { visible: false },
                        width: card.chartType === 'Line' ? 2 : undefined
                    }],
                    width: '100%',
                    height: '100%'
                });
                chart.appendTo(viz);
                CHARTS[card.cardId] = { control: chart, kind: 'chart' };
            }

            function wdRenderGauge(viz, card) {
                var val = toNum(card.kpiValue);
                var max = val <= 0 ? 100 : (val <= 100 ? 100 : Math.ceil(val * 1.2));
                var gauge = new ej.circulargauge.CircularGauge({
                    theme: 'Bootstrap5',
                    axes: [{
                        minimum: 0,
                        maximum: max,
                        radius: '100%',
                        startAngle: 200, endAngle: 160,
                        pointers: [{
                            value: val, type: 'RangeBar', radius: '100%', pointerWidth: 6,
                            color: '#1F4E79', cap: { radius: 0 },
                            animation: { enable: true, duration: 900 }
                        }],
                        lineStyle: { width: 8, color: '#D4E2F0' },
                        majorTicks: { color: '#D4E2F0', height: 0 },
                        minorTicks: { height: 0 },
                        labelStyle: { color: '#5B7A99', font: { size: '12px' } },
                        ranges: [{ start: 0, end: val, startWidth: 8, endWidth: 8, color: '#2E6DA4', radius: '100%' }]
                    }],
                    annotations: [{
                        content: '<div style="font-size:22px;font-weight:700;color:#102A43">' + escapeHtml(formatNum(val)) + '</div>',
                        radius: '0%', angle: 0, zIndex: '1'
                    }],
                    width: '100%',
                    height: '100%'
                });
                gauge.appendTo(viz);
                CHARTS[card.cardId] = { control: gauge, kind: 'gauge' };
            }

            function wdRenderGrid(viz, card) {
                var cols = (card.columns || []).map(function (c) {
                    var sample = card.rows && card.rows.length ? card.rows[0][c] : null;
                    return { field: c, headerText: c, textAlign: isNum(sample) ? 'Right' : 'Left', width: 120 };
                });
                var grid = new ej.grids.Grid({
                    theme: 'Bootstrap5',
                    dataSource: card.rows || [],
                    columns: cols,
                    allowPaging: (card.rows || []).length > 10,
                    pageSize: 10,
                    allowSorting: true,
                    gridLines: 'Horizontal',
                    cssClass: 'wd-sync-grid',
                    width: '100%',
                    height: '100%'
                });
                grid.appendTo(viz);
                CHARTS[card.cardId] = { control: grid, kind: 'grid' };
            }

            function wdLoadCard(id, showSkeleton) {
                var el = document.getElementById('card-' + id);
                if (!el) return;
                if (showSkeleton) {
                    var body = el.querySelector('.wd-card__body');
                    body.innerHTML = '<div class="wd-skeleton-wrap"><div class="wd-skel wd-skel--tall"></div></div>';
                }
                fetch('/api/dashboard/card/' + id, { headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.json(); })
                    .then(function (data) { wdRenderCard(data); })
                    .catch(function (err) {
                        var b = el.querySelector('.wd-card__body');
                        if (b) b.innerHTML = wdErrorHtml('تعذر الاتصال بالخادم: ' + (err && err.message ? err.message : ''), id);
                        showToast('error', 'تعذر تحميل بطاقة #' + id);
                    });
            }

            window.wdRetry = function (id) { wdLoadCard(id, true); };

            function updateTimestamp() {
                var el = document.getElementById('wd-last-updated');
                if (el) el.textContent = 'آخر تحديث: ' + new Date().toLocaleTimeString('ar-SA');
            }

            window.wdRefreshAll = function () {
                showToast('success', 'جارٍ تحديث البطاقات…');
                updateTimestamp();
                (window.WD_CARDS || []).forEach(function (c) { wdLoadCard(c.id, true); });
            };

            // Open a card's drill-down page (TASK-COD-012). Cards without configured
            // levels are never given this handler, so navigation only happens for drillable cards.
            window.wdOpenDrill = function (id) {
                window.location.href = '/Dashboard/Drill/' + id;
            };

            function wdCheckConnection() {
                var badge = document.getElementById('wd-conn');
                var txt = document.getElementById('wd-conn-text');
                fetch('/api/sync/status', { headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        if (!badge || !txt) return;
                        if (d && d.connected) {
                            badge.className = 'wd-conn wd-conn--online';
                            txt.textContent = 'متصل';
                        } else {
                            badge.className = 'wd-conn wd-conn--offline';
                            txt.textContent = 'غير متصل';
                        }
                    })
                    .catch(function () {
                        if (!badge || !txt) return;
                        badge.className = 'wd-conn wd-conn--offline';
                        txt.textContent = 'غير متصل';
                    });
            }

            document.addEventListener('DOMContentLoaded', function () {
                (window.WD_CARDS || []).forEach(function (c) { wdLoadCard(c.id, false); });
                wdCheckConnection();

                // Focus Mode toggle
                (function() {
                    var toggle = document.getElementById('wd-focus-toggle');
                    if (!toggle) return;
                    toggle.addEventListener('click', function() {
                        document.body.classList.toggle('wd-dashboard--focus');
                        toggle.classList.toggle('wd-btn--primary');
                        toggle.querySelector('svg').innerHTML = document.body.classList.contains('wd-dashboard--focus')
                            ? '<path d="M8 3v3a2 2 0 01-2 2H3"/><path d="M21 8h-3a2 2 0 01-2-2V3"/><path d="M16 21v-3a2 2 0 012-2h3"/><path d="M3 16h3a2 2 0 012 2v3"/>'
                            : '<path d="M8 3H5a2 2 0 00-2 2v3"/><path d="M21 8V5a2 2 0 00-2-2h-3"/><path d="M16 21h3a2 2 0 002-2v-3"/><path d="M3 16v3a2 2 0 002 2h3"/>';
                    });
                })();
            });

            var rt;
            window.addEventListener('resize', function () {
                clearTimeout(rt);
                rt = setTimeout(function () {
                    Object.keys(CHARTS).forEach(function (k) {
                        try { CHARTS[k].control.refresh(); } catch (e) { /* noop */ }
                    });
                }, 200);
            });
        })();

        /* ===== TASK-COD-014: client-side search + ChartType filtering ===== */
        (function () {
            var searchInput = document.getElementById('wd-search');
            var typeSelect = document.getElementById('wd-type-filter');
            var emptyState = document.getElementById('wd-filter-empty');
            var countLabel = document.getElementById('wd-filter-count');
            if (!searchInput || !typeSelect) return;

            var grid = document.querySelector('.wd-dashboard-grid');
            var cards = grid
                ? Array.prototype.slice.call(grid.querySelectorAll('.wd-dashboard-grid > .wd-card'))
                : [];

            // Smoothly toggle a card's hidden state. A per-element sequence guards
            // against rapid keystrokes cancelling an in-flight transition.
            function setCardHidden(el, hide) {
                var seq = (el._wdFilterSeq = (el._wdFilterSeq || 0) + 1);
                if (hide) {
                    el.classList.add('wd-card--fade');
                    setTimeout(function () {
                        if (el._wdFilterSeq === seq) {
                            el.classList.add('wd-hidden');
                            el.classList.remove('wd-card--fade');
                        }
                    }, 240);
                } else {
                    el.classList.remove('wd-hidden');
                    el.classList.add('wd-card--fade');
                    requestAnimationFrame(function () {
                        requestAnimationFrame(function () {
                            if (el._wdFilterSeq === seq) el.classList.remove('wd-card--fade');
                        });
                    });
                }
            }

            var wasEmpty = false;
            function applyFilter() {
                var q = (searchInput.value || '').trim().toLocaleLowerCase();
                var type = typeSelect.value;
                var visible = 0;

                cards.forEach(function (el) {
                    var title = (el.getAttribute('data-title') || '').toLocaleLowerCase();
                    var chartType = el.getAttribute('data-chart-type') || '';
                    var match = (q === '' || title.indexOf(q) !== -1) &&
                                (type === 'All' || chartType === type);
                    setCardHidden(el, !match);
                    if (match) visible++;
                });

                if (emptyState) emptyState.classList.toggle('wd-hidden', visible !== 0);
                if (countLabel) {
                    countLabel.textContent = (visible === cards.length)
                        ? (cards.length + ' بطاقة')
                        : (' ظاهر ' + visible + ' من ' + cards.length);
                }

                var isEmpty = visible === 0;
                if (isEmpty && !wasEmpty && window.wdShowToast) {
                    window.wdShowToast('info', 'لا توجد بطاقات مطابقة لبحثك');
                }
                wasEmpty = isEmpty;
            }

            // Debounce typing so we never thrash layout on every keystroke.
            var debounceTimer;
            searchInput.addEventListener('input', function () {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(applyFilter, 120);
            });
            typeSelect.addEventListener('change', applyFilter);

            applyFilter(); // sync count label on first render
        })();
    </script>
}
