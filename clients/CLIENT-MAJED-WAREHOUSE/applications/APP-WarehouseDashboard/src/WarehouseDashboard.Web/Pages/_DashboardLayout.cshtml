@{
    // Public dashboard layout (Viewer is public — no admin auth).
    // Shares the Blue Identity design system via wwwroot/css/blue-theme.css
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Warehouse Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet" />

    @* Shared design system — single source of truth for the Blue Identity palette *@
    <link rel="stylesheet" href="~/css/blue-theme.css" />

    @* ApexCharts (MIT license, no build step — replaces Chart.js for RTL + drill-down support) *@
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

    @* SortableJS — drag-and-drop reordering for dashboard cards *@
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
</head>
<body class="wd-app">
    @{
        ViewData["BrandHref"] = "/";
        ViewData["BrandText"] = "Warehouse Dashboard · لوحة المعلومات";
        ViewData["IsAdmin"] = false;
        ViewData["ShowConnectionStatus"] = true;
    }
    @await Html.PartialAsync("_Header")

    <main class="wd-content">
        @RenderBody()
    </main>

    <div id="wd-toast-host" class="wd-toast-host" aria-live="polite" aria-atomic="true"></div>

    @* Shared dashboard utilities (toNum, formatNum, escapeHtml, showToast, wdEmptyHtml, wdErrorHtml) *@
    <script src="~/js/dashboard-utils.js"></script>

    <script>
        // Shared palette (§2.2) — the 11 Blue Identity colors, recycled with a soft repeat.
        window.WD_PALETTE = ['#1F4E79', '#163A5A', '#2E6DA4', '#0A2540', '#8FBCDE', '#5B7A99',
                             '#2E6DA4', '#1F4E79', '#0A2540', '#8FBCDE', '#163A5A'];
        // Card ids rendered server-side (drives the per-card fetch loop).
        window.WD_CARDS = [];
    </script>

    <button id="wd-scroll-top" class="wd-scroll-top" aria-label="العودة للأعلى" title="العودة للأعلى">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
    </button>

    <script>
        (function() {
            var btn = document.getElementById('wd-scroll-top');
            if (!btn) return;
            var handler = function() {
                btn.classList.toggle('is-visible', window.scrollY > 300);
            };
            window.addEventListener('scroll', handler, { passive: true });
            btn.addEventListener('click', function() {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        })();
    </script>

    <script>
        (function() {
            function checkSyncStatus() {
                var badge = document.getElementById('wd-sync-status');
                var text = document.getElementById('wd-sync-status-text');
                if (!badge || !text) return;
                fetch('/api/sync/status')
                    .then(function(r) { return r.json(); })
                    .then(function(d) {
                        if (d && d.isRunning) {
                            badge.className = 'wd-sync-status wd-sync-status--running';
                            text.textContent = 'مزامنة...';
                        } else if (d && d.lastError) {
                            badge.className = 'wd-sync-status wd-sync-status--error';
                            text.textContent = 'خطأ';
                        } else {
                            badge.className = 'wd-sync-status wd-sync-status--idle';
                            text.textContent = 'متوقف';
                        }
                    })
                    .catch(function() {
                        badge.className = 'wd-sync-status';
                        text.textContent = '--';
                    });
            }
            checkSyncStatus();
            setInterval(checkSyncStatus, 15000);
        })();

        // === Theme Switcher ===
        (function() {
            var toggleBtn = document.getElementById('wd-theme-toggle');
            var themeMenu = document.getElementById('wd-theme-menu');
            if (toggleBtn && themeMenu) {
                toggleBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    themeMenu.hidden = !themeMenu.hidden;
                });
                document.addEventListener('click', function() {
                    themeMenu.hidden = true;
                });
                themeMenu.addEventListener('click', function(e) {
                    e.stopPropagation();
                });
            }

            var currentTheme = localStorage.getItem('wd-theme') || 'blue';
            document.documentElement.setAttribute('data-theme', currentTheme);

            var options = document.querySelectorAll('.wd-theme-option');
            options.forEach(function(opt) {
                if (opt.getAttribute('data-theme') === currentTheme) opt.classList.add('is-active');
                opt.addEventListener('click', function() {
                    var theme = this.getAttribute('data-theme');
                    localStorage.setItem('wd-theme', theme);
                    document.documentElement.setAttribute('data-theme', theme);
                    options.forEach(function(o) { o.classList.remove('is-active'); });
                    this.classList.add('is-active');
                    themeMenu.hidden = true;
                });
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
