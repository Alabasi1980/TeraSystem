<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Warehouse Dashboard</title>

    @* Arabic webfont (§1.3) — free Google Fonts, loaded via CDN *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet" />

    @* Shared design system (TASK-COD-013 canonical blue-theme.css; reused by TASK-COD-011) *@
    <link rel="stylesheet" href="~/css/blue-theme.css" asp-append-version="true" />

    @* AI Assistant Side Panel styles (TASK-AI-D02) *@
    <link rel="stylesheet" href="~/css/assistant-panel.css" asp-append-version="true" />
</head>
<body>
    <header>
        <h1>Warehouse Dashboard</h1>
    </header>
    <main>
        @RenderBody()
    </main>

    @* Radzen Blazor interactive components *@
    <script src="_framework/blazor.web.js"></script>

    @* AI Assistant Side Panel partial view (TASK-AI-D02) *@
    <partial name="_AssistantSidePanel" />

    @* AI Assistant Panel — open/close logic (TASK-AI-D03) *@
    <script src="~/js/assistant-panel.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
