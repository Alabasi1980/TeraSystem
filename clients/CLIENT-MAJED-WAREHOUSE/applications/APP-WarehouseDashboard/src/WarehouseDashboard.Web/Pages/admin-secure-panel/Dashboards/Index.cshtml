@page
@model IndexModel
@{
    ViewData["Title"] = "إدارة الداشبوردات";
}

<div class="wd-breadcrumb-row">
    <span>لوحة الإدارة</span>
    <span class="wd-sep">/</span>
    <span>الداشبوردات</span>
</div>

<div class="wd-page-head">
    <h2 class="wd-page-title">إدارة الداشبوردات</h2>
    <a href="/admin-secure-panel/Dashboards/Create" class="wd-btn wd-btn--primary">+ داشبورد جديدة</a>
</div>

@if (Model.Dashboards.Count == 0)
{
    <div class="wd-card wd-empty">
        <div class="wd-empty__icon">📋</div>
        <h3>لا توجد داشبوردات بعد</h3>
        <p>ابدأ بإنشاء داشبورد جديد لتنظيم البطاقات.</p>
        <a href="/admin-secure-panel/Dashboards/Create" class="wd-btn wd-btn--primary">+ إنشاء داشبورد</a>
    </div>
}
else
{
    <div class="wd-card">
        <table style="width:100%;border-collapse:collapse;">
            <thead>
                <tr style="background:var(--c-surface-muted);border-bottom:1px solid var(--c-border);">
                    <th style="padding:12px 16px;text-align:right;font-size:13px;font-weight:600;color:var(--c-text);">الترتيب</th>
                    <th style="padding:12px 16px;text-align:right;font-size:13px;font-weight:600;color:var(--c-text);">الاسم</th>
                    <th style="padding:12px 16px;text-align:right;font-size:13px;font-weight:600;color:var(--c-text);">المعرف (Slug)</th>
                    <th style="padding:12px 16px;text-align:right;font-size:13px;font-weight:600;color:var(--c-text);">الأيقونة</th>
                    <th style="padding:12px 16px;text-align:center;font-size:13px;font-weight:600;color:var(--c-text);">البطاقات</th>
                    <th style="padding:12px 16px;text-align:center;font-size:13px;font-weight:600;color:var(--c-text);">افتراضية</th>
                    <th style="padding:12px 16px;text-align:center;font-size:13px;font-weight:600;color:var(--c-text);">نشط</th>
                    <th style="padding:12px 16px;text-align:center;font-size:13px;font-weight:600;color:var(--c-text);">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Dashboards)
                {
                    <tr style="border-bottom:1px solid var(--c-border);transition:background var(--dur-fast) var(--ease);"
                        onmouseover="this.style.background='var(--c-surface-muted)'" onmouseout="this.style.background='transparent'">
                        <td style="padding:12px 16px;font-size:13px;color:var(--c-text-muted);width:60px;">
                            <span style="cursor:default;" title="ترتيب#@item.Dashboard.SortOrder">@(item.Dashboard.SortOrder)</span>
                        </td>
                        <td style="padding:12px 16px;font-size:14px;font-weight:600;color:var(--c-text);">
                            @item.Dashboard.Name
                            @if (!string.IsNullOrEmpty(item.Dashboard.Description))
                            {
                                <span style="display:block;font-size:12px;font-weight:400;color:var(--c-text-muted);margin-top:2px;">@item.Dashboard.Description</span>
                            }
                        </td>
                        <td style="padding:12px 16px;font-size:13px;color:var(--c-text-muted);font-family:monospace;direction:ltr;text-align:left;">
                            @item.Dashboard.Slug
                        </td>
                        <td style="padding:12px 16px;font-size:20px;text-align:center;">
                            @item.Dashboard.Icon
                        </td>
                        <td style="padding:12px 16px;font-size:13px;text-align:center;color:var(--c-text);">
                            @item.CardCount
                        </td>
                        <td style="padding:12px 16px;text-align:center;">
                            @if (item.Dashboard.IsDefault)
                            {
                                <span class="wd-badge wd-badge--on">افتراضية</span>
                            }
                        </td>
                        <td style="padding:12px 16px;text-align:center;">
                            @if (item.Dashboard.IsActive)
                            {
                                <span class="wd-badge wd-badge--on">نشط</span>
                            }
                            else
                            {
                                <span class="wd-badge wd-badge--off">معطل</span>
                            }
                        </td>
                        <td style="padding:12px 16px;text-align:center;white-space:nowrap;">
                            <a href="/admin-secure-panel/Dashboards/Edit?id=@item.Dashboard.Id" class="wd-link">تعديل</a>
                            <button type="button" class="wd-link wd-link--danger" onclick="wdConfirmDelete(@item.Dashboard.Id, '@item.Dashboard.IsDefault.ToString().ToLower()', @item.CardCount)">حذف</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<form id="wdDeleteForm" method="post" asp-page-handler="Delete" class="wd-hidden">
    <input type="hidden" name="id" id="wdDeleteId" />
</form>

@section Scripts {
    <script>
        function wdConfirmDelete(id, isDefault, cardCount) {
            if (isDefault === 'true') {
                window.alert('لا يمكن حذف الداشبورد الافتراضي. قم بتعيين داشبورد افتراضي آخر أولاً.');
                return;
            }
            if (cardCount > 0) {
                window.alert('لا يمكن حذف الداشبورد لأنه يحتوي على ' + cardCount + ' بطاقات. انقل البطاقات إلى داشبورد آخر أولاً.');
                return;
            }
            if (window.confirm('هل أنت متأكد من حذف هذا الداشبورد؟')) {
                document.getElementById('wdDeleteId').value = id;
                document.getElementById('wdDeleteForm').submit();
            }
        }
    </script>
}

@section Toast {
    @if (!string.IsNullOrEmpty(Model.ToastMessage))
    {
        <div class="wd-toast wd-toast--@Model.ToastType" role="status">
            <span class="wd-toast__icon">@(Model.ToastType == "success" ? "✓" : "✕")</span>
            <span class="wd-toast__msg">@Model.ToastMessage</span>
        </div>
    }
}
