@page
@model WarehouseDashboard.Web.Pages.AdminSecurePanel.DrillDownModel
@{
    ViewData["Title"] = "تكوين التنقّل العميق";
}
@Html.AntiForgeryToken()

<style>
    /* Page-specific styles not provided by _CardsLayout */
    .wd-page { max-width: 1100px; margin: 0 auto; padding: 0; }
    .wd-page__header { margin-bottom: 24px; animation: wdFadeUp var(--dur-norm) var(--ease); }
    .wd-breadcrumb { font-size: 12px; color: var(--c-text-muted); margin-bottom: 6px; }
    .wd-breadcrumb a { color: var(--c-secondary); text-decoration: none; }
    .wd-page__title { font-size: 22px; font-weight: 700; color: var(--c-text); margin: 0; }
    .wd-page__subtitle { font-size: 14px; color: var(--c-text-muted); margin: 6px 0 0; }

    .wd-card { margin-bottom: 24px; }
    .wd-card__header { flex-wrap: wrap; }

    .wd-label { display: block; font-size: 13px; font-weight: 600; color: var(--c-text-muted); margin-bottom: 6px; }
    .wd-input, .wd-select, .wd-textarea {
        width: 100%; font-family: var(--font-ar);
        font-size: 14px; color: var(--c-text);
        border: 1px solid var(--c-border); border-radius: var(--radius-md);
        padding: 10px 12px; background: var(--c-surface);
        transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
    }
    .wd-textarea { min-height: 120px; resize: vertical; direction: ltr; text-align: start; font-family: "Courier New", monospace; }
    .wd-input:focus, .wd-select:focus, .wd-textarea:focus {
        outline: none; border-color: var(--c-primary);
        box-shadow: 0 0 0 3px rgba(31,78,121,0.12);
    }
    .wd-field { margin-bottom: 14px; }

    .wd-grid { margin-top: 8px; min-height: 80px; }

    .wd-skeleton { padding: 12px; }
    .wd-skeleton__row {
        height: 18px; margin-bottom: 12px; border-radius: 6px;
        background: linear-gradient(90deg, var(--c-surface-muted) 25%, #dbe7f3 37%, var(--c-surface-muted) 63%);
        background-size: 400% 100%;
        animation: wdShimmer 1.2s ease-in-out infinite;
    }

    .wd-form-panel {
        position: fixed; inset: 0; z-index: 12000;
        width: 100vw; height: 100vh; height: 100dvh;
        background: rgba(10,37,64,0.58);
        display: flex; align-items: center; justify-content: center;
        padding: 18px 24px; box-sizing: border-box;
        animation: wdFadeUp var(--dur-fast) var(--ease);
    }
    .wd-form-panel__inner {
        width: min(1120px, calc(100vw - 48px));
        max-height: calc(100vh - 36px); max-height: calc(100dvh - 36px);
        overflow: hidden; display: grid; grid-template-rows: auto minmax(0, 1fr) auto;
        background: var(--c-surface); border: 1px solid var(--c-border);
        border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);
        padding: 0; animation: wdSlideUp var(--dur-norm) var(--ease);
    }

    /* Header */
    .wd-form-header {
        padding: 14px 24px 12px; border-bottom: 1px solid var(--c-border);
        display: flex; align-items: center; justify-content: space-between;
        background: var(--c-surface); z-index: 1;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }
    .wd-form-header h3 { font-size: 17px; font-weight: 700; color: var(--c-text); margin: 0; }
    .wd-form-header__close {
        width: 32px; height: 32px; border: none; background: transparent;
        border-radius: var(--radius-md); cursor: pointer; display: flex;
        align-items: center; justify-content: center; color: var(--c-text-muted);
        font-size: 18px; transition: background var(--dur-fast) var(--ease);
    }
    .wd-form-header__close:hover { background: var(--c-surface-muted); color: var(--c-text); }

    /* Body scrollable area */
    .wd-form-body {
        min-height: 0; overflow-y: auto; overflow-x: hidden;
        padding: 14px 24px;
    }

    /* Footer */
    .wd-form-footer {
        padding: 12px 24px; border-top: 1px solid var(--c-border);
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        background: var(--c-surface);
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    }

    /* Sections */
    .wd-form-section {
        margin-bottom: 12px;
    }
    .wd-form-section:last-child { margin-bottom: 0; }
    .wd-form-section__title {
        font-size: 12px; font-weight: 700; color: var(--c-text-muted);
        text-transform: uppercase; letter-spacing: 0.3px;
        margin-bottom: 8px; padding-bottom: 6px;
        border-bottom: 1px solid var(--c-border);
        display: flex; align-items: center; gap: 6px;
    }
    .wd-form-section__icon {
        font-size: 14px; line-height: 1;
    }

    /* Two-column grid */
    .wd-form-grid {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px 14px;
    }
    .wd-form-grid--full {
        grid-template-columns: 1fr;
    }
    .wd-form-grid .wd-field--span2 {
        grid-column: 1 / -1;
    }
    .wd-form-panel .wd-field { margin-bottom: 0; }
    .wd-form-panel .wd-label { margin-bottom: 4px; font-size: 12px; }
    .wd-form-panel .wd-input,
    .wd-form-panel .wd-select,
    .wd-form-panel .wd-textarea { padding: 8px 10px; font-size: 13px; }
    .wd-form-panel .wd-textarea { min-height: 108px; max-height: 140px; }
    .wd-form-panel .wd-field-hint { margin-top: 3px; font-size: 11px; }

    /* Button improvements */
    .wd-btn--primary {
        background: var(--c-primary); color: #fff; border: none;
        padding: 9px 22px; font-weight: 600; font-size: 14px;
        border-radius: var(--radius-md); cursor: pointer;
        transition: background var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease);
    }
    .wd-btn--primary:hover { background: color-mix(in srgb, var(--c-primary) 85%, #000); }
    .wd-btn--primary:active { transform: scale(0.97); }

    .wd-btn--cancel {
        background: transparent; color: var(--c-text-muted); border: 1px solid var(--c-border);
        padding: 9px 18px; font-weight: 600; font-size: 14px;
        border-radius: var(--radius-md); cursor: pointer;
        transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
    }
    .wd-btn--cancel:hover { background: var(--c-surface-muted); color: var(--c-text); }

    .wd-btn--test {
        background: var(--c-surface-muted); color: var(--c-text); border: 1px solid var(--c-border);
        padding: 9px 18px; font-weight: 600; font-size: 14px;
        border-radius: var(--radius-md); cursor: pointer;
        transition: background var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
        margin-right: auto;
    }
    .wd-btn--test:hover { background: color-mix(in srgb, var(--c-surface-muted) 80%, var(--c-primary)); border-color: var(--c-primary); }

    @@keyframes wdSlideUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    .wd-toast-container {
        position: fixed; inset-inline-end: 16px; inset-block-end: 16px;
        display: flex; flex-direction: column; gap: 8px; z-index: 13000;
    }
    .wd-toast {
        min-width: 240px; max-width: 360px; padding: 12px 16px; border-radius: var(--radius-md);
        color: #fff; box-shadow: var(--shadow-md); display: flex; align-items: center; gap: 8px;
        animation: wdToastIn var(--dur-norm) var(--ease);
        font-size: 14px;
    }
    .wd-toast--success { background: var(--c-success); }
    .wd-toast--error { background: var(--c-error); }
    .wd-toast--warning { background: var(--c-warning); color: #3a2c00; }
    .wd-toast--info { background: var(--c-secondary); }

    .wd-field--checkbox { display: flex; align-items: center; gap: 8px; }
    .wd-field--checkbox input[type=checkbox] { width: 18px; height: 18px; cursor: pointer; }
    .wd-field--checkbox label { margin: 0 !important; cursor: pointer; }
    .wd-help-icon { cursor: help; color: var(--c-text-muted); font-size: 14px; user-select: none; }
    .wd-field-hint { display: block; color: var(--c-text-muted); font-size: 12px; margin-top: 4px; }

    .wd-preview { margin-top: 8px; border: 1px solid var(--c-border); border-radius: var(--radius-md); overflow: hidden; }
    .wd-preview__header { padding: 8px 12px; background: var(--c-surface-muted); font-size: 13px; font-weight: 600; color: var(--c-text); border-bottom: 1px solid var(--c-border); display: flex; align-items: center; gap: 8px; }
    .wd-preview__body { overflow-x: auto; padding: 0; }
    .wd-preview__body table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .wd-preview__body th { padding: 6px 10px; background: var(--c-surface-muted); font-weight: 600; text-align: right; border-bottom: 1px solid var(--c-border); white-space: nowrap; }
    .wd-preview__body td { padding: 6px 10px; border-bottom: 1px solid var(--c-border); text-align: right; white-space: nowrap; }
    .wd-preview__body tr:last-child td { border-bottom: none; }
    .wd-preview__empty { padding: 24px; text-align: center; color: var(--c-text-muted); font-size: 14px; }
    .wd-preview__error { padding: 12px 16px; color: #b91c1c; background: #fef2f2; border-radius: var(--radius-md); font-size: 14px; display: flex; align-items: center; gap: 8px; }
    .wd-preview__warnings { margin: 8px 12px; padding: 8px 12px; background: #fef9c3; color: #854d0e; border-radius: var(--radius-md); font-size: 13px; display: flex; flex-direction: column; gap: 4px; }
    .wd-preview__warnings span { display: flex; align-items: center; gap: 6px; }
    .wd-preview__rowcount { font-size: 12px; color: var(--c-text-muted); margin-right: auto; }

    @@media (max-width: 900px) {
        .wd-form-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @@media (max-width: 640px) {
        .wd-form-panel { align-items: flex-start; padding: 12px; }
        .wd-form-panel__inner { width: calc(100vw - 24px); max-height: calc(100vh - 24px); max-height: calc(100dvh - 24px); }
        .wd-form-grid { grid-template-columns: 1fr; }
        .wd-form-header, .wd-form-body, .wd-form-footer { padding-inline: 14px; }
    }

    /* ============ Tabs ============ */
    .wd-tab-bar {
        display: flex; gap: 0; border-bottom: 1px solid var(--c-border);
        margin-bottom: 16px; background: var(--c-surface-muted);
        border-radius: var(--radius-md) var(--radius-md) 0 0;
        overflow-x: auto; flex-shrink: 0;
    }
    .wd-tab-btn {
        padding: 10px 20px; font-size: 13px; font-weight: 600;
        color: var(--c-text-muted); cursor: pointer;
        border: none; background: transparent;
        border-bottom: 2px solid transparent;
        transition: all var(--dur-fast) var(--ease);
        font-family: var(--font-ar); white-space: nowrap;
        user-select: none;
    }
    .wd-tab-btn:hover { color: var(--c-text); background: rgba(0,0,0,0.03); }
    .wd-tab-btn--active {
        color: var(--c-primary); border-bottom-color: var(--c-primary);
        background: var(--c-surface);
    }
    .wd-tab-content { display: none; }
    .wd-tab-content--active { display: block; }
    /* Tab content scrollable — form-body already scrolls */
    .wd-tab-content .wd-form-grid {
        margin-top: 0;
    }
    /* Compact hint inside tabs */
    .wd-tab-content .wd-field-hint {
        margin-top: 3px; font-size: 11px; line-height: 1.4;
    }

    [hidden] { display: none !important; }
</style>

<div class="wd-page">
    <header class="wd-page__header">
        <div class="wd-breadcrumb">
            <a href="/admin-secure-panel">لوحة الإدارة</a> &laquo; تكوين التنقّل العميق
        </div>
        <h2 class="wd-page__title">تكوين التنقّل العميق</h2>
        <p class="wd-page__subtitle">إدارة مستويات التنقّل العميق لكل بطاقة (الاستعلام ونوع الرسم لكل مستوى).</p>
    </header>

    <section class="wd-card">
        <div class="wd-card__header">
            <span class="wd-card__title">البطاقة</span>
            <button class="wd-btn wd-btn--sm" onclick="openForm()">+ إضافة مستوى</button>
        </div>
        <div class="wd-card__body">
            <label class="wd-label" for="cardSelect">اختر بطاقة لتكوين مستوياتها</label>
            <select id="cardSelect" class="wd-select" onchange="onCardChange()">
                <option value="">— اختر بطاقة —</option>
                @foreach (var card in Model.Cards)
                {
                    <option value="@card.Id">@card.Title</option>
                }
            </select>
        </div>
    </section>

    <section class="wd-card">
        <div class="wd-card__header">
            <span class="wd-card__title">مستويات التنقّل العميق</span>
        </div>
        <div class="wd-card__body">
            <div id="levelsSkeleton" class="wd-skeleton" hidden>
                @for (int i = 0; i < 5; i++) { <div class="wd-skeleton__row"></div> }
            </div>
            <div id="levelsEmpty" class="wd-empty">
                <span class="wd-empty__icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="12" width="4" height="8"/>
                        <rect x="10" y="5" width="4" height="15"/>
                        <rect x="17" y="8" width="4" height="12"/>
                    </svg>
                </span>
                اختر بطاقة لعرض مستويات التنقّل العميق الخاصة بها.
            </div>
            <div id="levelsGrid" class="wd-grid"></div>
        </div>
    </section>
</div>

<div id="formPanel" class="wd-form-panel" hidden>
    <div class="wd-form-panel__inner">
        <div class="wd-form-header">
            <h3 id="formTitle">إضافة مستوى تنقّل عميق</h3>
            <button class="wd-form-header__close" onclick="closeForm()" title="إغلاق">✕</button>
        </div>
        <div class="wd-form-body">
            <!-- Tab Bar -->
            <div class="wd-tab-bar">
                <button class="wd-tab-btn wd-tab-btn--active" data-tab="tab-basic" onclick="switchTab('tab-basic')" type="button">معلومات أساسية</button>
                <button class="wd-tab-btn" data-tab="tab-query" onclick="switchTab('tab-query')" type="button">الاستعلام والاختبار</button>
                <button class="wd-tab-btn" data-tab="tab-advanced" onclick="switchTab('tab-advanced')" type="button">إعدادات متقدمة</button>
            </div>

            <!-- Tab 1: Basic Info -->
            <div id="tab-basic" class="wd-tab-content wd-tab-content--active">
                <div class="wd-form-grid">
                    <div class="wd-field">
                        <label class="wd-label" for="levelInput">المستوى (رقم ≥ 1)</label>
                        <input id="levelInput" class="wd-input" type="number" min="1" value="1" />
                    </div>
                    <div class="wd-field">
                        <label class="wd-label" for="displayNameInput">اسم العرض</label>
                        <input id="displayNameInput" class="wd-input" type="text" placeholder="مثال: حسب المدينة" />
                    </div>
                    <div class="wd-field">
                        <label class="wd-label" for="chartTypeInput">نوع الرسم</label>
                        <select id="chartTypeInput" class="wd-select">
                            <option value="Bar">Bar</option>
                            <option value="Line">Line</option>
                            <option value="Pie">Pie</option>
                            <option value="KPI">KPI</option>
                            <option value="Table">Table</option>
                            <option value="Gauge">Gauge</option>
                        </select>
                    </div>
                    <div class="wd-field">
                        <label class="wd-label" for="parameterColumnInput">عمود الباراميتر (اختياري)</label>
                        <input id="parameterColumnInput" class="wd-input" type="text" placeholder="مثال: City" />
                        <small class="wd-field-hint">اسم العمود الذي تمرّر قيمته للمستوى التالي</small>
                    </div>
                    <div class="wd-field">
                        <label class="wd-label" for="labelColumnInput">عمود التسمية (اختياري)</label>
                        <input id="labelColumnInput" class="wd-input" type="text" placeholder="مثال: CityName" />
                        <small class="wd-field-hint">اسم العمود المعروض في Breadcrumb</small>
                    </div>
                    <div class="wd-field wd-field--checkbox" style="align-self:end; padding-bottom:10px;">
                        <input id="requiresParentValueInput" type="checkbox" />
                        <label class="wd-label" for="requiresParentValueInput">يتطلب قيمة من المستوى السابق</label>
                        <span class="wd-help-icon" title="المستوى الأول عادة لا يتطلب قيمة">❔</span>
                    </div>
                </div>
            </div>

            <!-- Tab 2: Query & Test -->
            <div id="tab-query" class="wd-tab-content">
                <div class="wd-form-grid wd-form-grid--full">
                    <div class="wd-field">
                        <label class="wd-label" for="queryInput">استعلام SQL</label>
                        <textarea id="queryInput" class="wd-textarea" rows="4" placeholder="SELECT City, COUNT(*) AS Qty FROM ..." oninput="toggleTestParameterInput()"></textarea>
                        <small class="wd-field-hint">قد يقبل معاملاً <code>@@p0</code> يُمرّر من المستوى السابق</small>
                    </div>
                </div>
                <div class="wd-form-grid" style="margin-bottom:12px;">
                    <div class="wd-field" id="testParamField" hidden>
                        <label class="wd-label" for="testParameterValueInput">قيمة اختبار للمعامل @@p0</label>
                        <input id="testParameterValueInput" class="wd-input" type="text" placeholder="مثال: Riyadh" />
                    </div>
                </div>
                <div id="testQueryArea">
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                        <button class="wd-btn--test" onclick="testQuery()" id="testQueryBtn">▶ اختبار الاستعلام</button>
                    </div>
                    <div id="testSpinner" class="wd-skeleton" style="margin-top:6px;display:none;">
                        <div class="wd-skeleton__row"></div>
                    </div>
                    <div id="testPreview" style="margin-top:8px;display:none;"></div>
                </div>
            </div>

            <!-- Tab 3: Advanced Settings -->
            <div id="tab-advanced" class="wd-tab-content">
                <div class="wd-form-grid wd-form-grid--full">
                    <div class="wd-field">
                        <label class="wd-label" for="columnAliasesInput">أسماء الأعمدة العربية (اختياري)</label>
                        <textarea id="columnAliasesInput" class="wd-textarea" rows="4" placeholder="TYPE_CODE = رمز النوع, TYPE_NAME = اسم النوع" style="direction:ltr;text-align:start;font-family:'Courier New',monospace;min-height:80px;"></textarea>
                        <small class="wd-field-hint">اكتب اسم العمود الإنجليزي ثم = ثم الاسم العربي. افصل بين الأعمدة بفاصلة.</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="wd-form-footer">
            <button class="wd-btn--primary" onclick="saveLevel()">💾 حفظ</button>
            <button class="wd-btn--cancel" onclick="closeForm()">إلغاء</button>
        </div>
    </div>
</div>

<div id="toastContainer" class="wd-toast-container"></div>

<script>
    let levelsGrid = null;
    let currentLevels = [];
    let editingId = null;
    let selectedCardId = null;

    function switchTab(tabId) {
        document.querySelectorAll('.wd-tab-content').forEach(function(el) {
            el.classList.remove('wd-tab-content--active');
        });
        document.querySelectorAll('.wd-tab-btn').forEach(function(el) {
            el.classList.remove('wd-tab-btn--active');
        });
        document.getElementById(tabId).classList.add('wd-tab-content--active');
        var btn = document.querySelector('[data-tab="' + tabId + '"]');
        if (btn) btn.classList.add('wd-tab-btn--active');
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text ?? '';
        return div.innerHTML;
    }

    function showToast(message, type) {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        toast.className = 'wd-toast wd-toast--' + (type || 'info');
        const icon = type === 'success' ? '✓' : type === 'error' ? '✕' : type === 'warning' ? '⚠' : 'ℹ';
        toast.innerHTML = '<span>' + icon + '</span><span>' + escapeHtml(message) + '</span>';
        container.appendChild(toast);
        setTimeout(function () {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(8px)';
            setTimeout(function () { toast.remove(); }, 240);
        }, 3500);
    }

    function showLevelsSkeleton(show) {
        document.getElementById('levelsSkeleton').hidden = !show;
        if (show) { showLevelsEmpty(false); destroyLevelsGrid(); }
    }

    function showLevelsEmpty(show) {
        document.getElementById('levelsEmpty').hidden = !show;
        if (show) { destroyLevelsGrid(); }
    }

    function destroyLevelsGrid() {
        levelsGrid = null;
        document.getElementById('levelsGrid').innerHTML = '';
    }

    function renderLevels(levels) {
        destroyLevelsGrid();
        const container = document.getElementById('levelsGrid');
        document.getElementById('levelsEmpty').hidden = true;

        if (!levels || levels.length === 0) {
            showLevelsEmpty(true);
            return;
        }

        var html = '<table class="wd-table" style="width:100%;border-collapse:collapse;">';
        html += '<thead><tr>';
        html += '<th style="padding:8px 12px;background:var(--c-surface-muted);font-weight:600;text-align:right;border-bottom:1px solid var(--c-border);width:90px;">المستوى</th>';
        html += '<th style="padding:8px 12px;background:var(--c-surface-muted);font-weight:600;text-align:right;border-bottom:1px solid var(--c-border);width:200px;">الاسم</th>';
        html += '<th style="padding:8px 12px;background:var(--c-surface-muted);font-weight:600;text-align:right;border-bottom:1px solid var(--c-border);width:120px;">النوع</th>';
        html += '<th style="padding:8px 12px;background:var(--c-surface-muted);font-weight:600;text-align:right;border-bottom:1px solid var(--c-border);width:120px;">الباراميتر</th>';
        html += '<th style="padding:8px 12px;background:var(--c-surface-muted);font-weight:600;text-align:center;border-bottom:1px solid var(--c-border);width:100px;">يتطلب قيمة</th>';
        html += '<th style="padding:8px 12px;background:var(--c-surface-muted);font-weight:600;text-align:right;border-bottom:1px solid var(--c-border);">الاستعلام</th>';
        html += '<th style="padding:8px 12px;background:var(--c-surface-muted);font-weight:600;text-align:center;border-bottom:1px solid var(--c-border);width:170px;">إجراءات</th>';
        html += '</tr></thead><tbody>';
        levels.forEach(function(level) {
            html += '<tr style="border-bottom:1px solid var(--c-border);">';
            html += '<td style="padding:8px 12px;text-align:right;">' + escapeHtml(String(level.level ?? '')) + '</td>';
            html += '<td style="padding:8px 12px;text-align:right;">' + escapeHtml(level.displayName || '') + '</td>';
            html += '<td style="padding:8px 12px;text-align:right;">' + escapeHtml(level.targetChartType || '') + '</td>';
            html += '<td style="padding:8px 12px;text-align:right;">' + escapeHtml(level.parameterColumn || '—') + '</td>';
            html += '<td style="padding:8px 12px;text-align:center;font-weight:600;color:' + (level.requiresParentValue ? 'var(--c-success)' : 'var(--c-text-muted)') + ';">' + (level.requiresParentValue ? 'نعم' : 'لا') + '</td>';
            html += '<td style="padding:8px 12px;text-align:right;max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + escapeHtml(level.drillDownQuery || '') + '">' + escapeHtml(level.drillDownQuery || '') + '</td>';
            html += '<td style="padding:8px 12px;text-align:center;">';
            html += '<button class="wd-btn wd-btn--sm" onclick="editLevel(' + level.id + ')">تعديل</button> ';
            html += '<button class="wd-btn wd-btn--sm wd-btn--danger" onclick="deleteLevel(' + level.id + ')">حذف</button>';
            html += '</td></tr>';
        });
        html += '</tbody></table>';
        container.innerHTML = html;
    }

    function onCardChange() {
        selectedCardId = document.getElementById('cardSelect').value;
        if (!selectedCardId) {
            showLevelsEmpty(true);
            destroyLevelsGrid();
            currentLevels = [];
            return;
        }
        loadLevels(selectedCardId);
    }

    async function loadLevels(cardId) {
        showLevelsSkeleton(true);
        try {
            const resp = await fetch('?handler=Levels&cardId=' + encodeURIComponent(cardId));
            const data = await resp.json();
            document.getElementById('levelsSkeleton').hidden = true;

            if (!data.success) {
                showToast(data.errorMessage || 'تعذر تحميل المستويات.', 'error');
                showLevelsEmpty(true);
                return;
            }

            currentLevels = data.levels || [];
            renderLevels(currentLevels);
        } catch (err) {
            document.getElementById('levelsSkeleton').hidden = true;
            showToast('تعذر الاتصال بالخادم.', 'error');
            showLevelsEmpty(true);
        }
    }

    function openForm() {
        if (!selectedCardId) {
            showToast('الرجاء اختيار بطاقة أولاً.', 'warning');
            return;
        }
        editingId = null;
        document.getElementById('formTitle').textContent = 'إضافة مستوى تنقّل عميق';
        document.getElementById('levelInput').value = '1';
        document.getElementById('displayNameInput').value = '';
        document.getElementById('chartTypeInput').value = 'Bar';
        document.getElementById('queryInput').value = '';
        document.getElementById('parameterColumnInput').value = '';
        document.getElementById('labelColumnInput').value = '';
        document.getElementById('requiresParentValueInput').checked = false;
        document.getElementById('columnAliasesInput').value = '';
        document.getElementById('testParameterValueInput').value = '';
        document.getElementById('testPreview').innerHTML = '';
        document.getElementById('testPreview').style.display = 'none';
        toggleTestParameterInput();
        // Reset to first tab
        switchTab('tab-basic');
        document.getElementById('formPanel').hidden = false;
    }

    function closeForm() {
        document.getElementById('formPanel').hidden = true;
    }

    function editLevel(id) {
        const level = currentLevels.find(function (l) { return l.id === id; });
        if (!level) { return; }
        editingId = id;
        document.getElementById('formTitle').textContent = 'تعديل مستوى تنقّل عميق';
        document.getElementById('levelInput').value = level.level;
        document.getElementById('displayNameInput').value = level.displayName;
        document.getElementById('chartTypeInput').value = level.targetChartType;
        document.getElementById('queryInput').value = level.drillDownQuery;
        document.getElementById('parameterColumnInput').value = level.parameterColumn || '';
        document.getElementById('labelColumnInput').value = level.labelColumn || '';
        document.getElementById('requiresParentValueInput').checked = !!level.requiresParentValue;
        document.getElementById('columnAliasesInput').value = level.columnAliases || '';
        document.getElementById('testParameterValueInput').value = '';
        document.getElementById('testPreview').innerHTML = '';
        document.getElementById('testPreview').style.display = 'none';
        toggleTestParameterInput();
        // Reset to first tab
        switchTab('tab-basic');
        document.getElementById('formPanel').hidden = false;
    }

    async function deleteLevel(id) {
        if (!confirm('هل تريد حذف هذا المستوى؟')) { return; }
        try {
            const token = document.querySelector('input[name=__RequestVerificationToken]').value;
            const fd = new FormData();
            fd.append('id', id);
            const resp = await fetch('?handler=Delete', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: fd
            });
            const data = await resp.json();
            if (data.success) {
                showToast('تم حذف المستوى.', 'success');
                if (selectedCardId) { loadLevels(selectedCardId); }
            } else {
                showToast(data.errorMessage || 'تعذر الحذف.', 'error');
            }
        } catch (err) {
            showToast('تعذر الاتصال بالخادم.', 'error');
        }
    }

    async function saveLevel() {
        const level = parseInt(document.getElementById('levelInput').value, 10);
        const displayName = document.getElementById('displayNameInput').value.trim();
        const targetChartType = document.getElementById('chartTypeInput').value;
        const drillDownQuery = document.getElementById('queryInput').value;

        if (!level || level < 1) { showToast('المستوى يجب أن يكون رقماً 1 أو أكثر.', 'warning'); return; }
        if (!displayName) { showToast('الرجاء إدخال اسم العرض.', 'warning'); return; }
        if (!drillDownQuery.trim()) { showToast('الرجاء إدخال استعلام SQL.', 'warning'); return; }

        try {
            const token = document.querySelector('input[name=__RequestVerificationToken]').value;
            const fd = new FormData();
            fd.append('parentCardId', selectedCardId);
            fd.append('level', level);
            fd.append('displayName', displayName);
            fd.append('targetChartType', targetChartType);
            fd.append('drillDownQuery', drillDownQuery);
            fd.append('parameterColumn', document.getElementById('parameterColumnInput').value);
            fd.append('labelColumn', document.getElementById('labelColumnInput').value);
            fd.append('requiresParentValue', document.getElementById('requiresParentValueInput').checked);
            fd.append('columnAliases', document.getElementById('columnAliasesInput').value);
            if (editingId) { fd.append('id', editingId); }

            const resp = await fetch('?handler=Save', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: fd
            });
            const data = await resp.json();

            if (data.success) {
                showToast(editingId ? 'تم تحديث المستوى.' : 'تم حفظ المستوى.', 'success');
                closeForm();
                if (selectedCardId) { loadLevels(selectedCardId); }
            } else {
                showToast(data.errorMessage || 'تعذر الحفظ.', 'error');
            }
        } catch (err) {
            showToast('تعذر الاتصال بالخادم.', 'error');
        }
    }

    function toggleTestParameterInput() {
        const query = document.getElementById('queryInput').value || '';
        const testParamField = document.getElementById('testParamField');
        if (query.indexOf('@@p0') !== -1) {
            testParamField.hidden = false;
        } else {
            testParamField.hidden = true;
            document.getElementById('testParameterValueInput').value = '';
        }
    }

    async function testQuery() {
        const query = document.getElementById('queryInput').value.trim();
        if (!query) {
            showToast('الرجاء إدخال استعلام SQL أولاً.', 'warning');
            return;
        }

        const parameterColumn = document.getElementById('parameterColumnInput').value;
        const labelColumn = document.getElementById('labelColumnInput').value;
        const testParameterValue = document.getElementById('testParameterValueInput').value;

        const previewDiv = document.getElementById('testPreview');
        const spinner = document.getElementById('testSpinner');
        const btn = document.getElementById('testQueryBtn');

        previewDiv.style.display = 'none';
        previewDiv.innerHTML = '';
        spinner.style.display = 'block';
        btn.disabled = true;

        try {
            const token = document.querySelector('input[name=__RequestVerificationToken]').value;
            const fd = new FormData();
            fd.append('drillDownQuery', query);
            if (parameterColumn) fd.append('parameterColumn', parameterColumn);
            if (labelColumn) fd.append('labelColumn', labelColumn);
            if (testParameterValue) fd.append('testParameterValue', testParameterValue);

            const resp = await fetch('?handler=TestQuery', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: fd
            });
            const data = await resp.json();

            spinner.style.display = 'none';
            btn.disabled = false;

            if (!data.success) {
                previewDiv.innerHTML = '<div class="wd-preview__error"><span>❌</span><span>' + escapeHtml(data.errorMessage || 'فشل الاختبار') + '</span></div>';
                previewDiv.style.display = 'block';
                return;
            }

            var html = '<div class="wd-preview">';

            if (data.warnings && data.warnings.length > 0) {
                html += '<div class="wd-preview__warnings">';
                data.warnings.forEach(function(w) {
                    html += '<span>⚠ ' + escapeHtml(w) + '</span>';
                });
                html += '</div>';
            }

            html += '<div class="wd-preview__header">';
            html += '<span>📊 نتيجة الاختبار</span>';
            html += '<span class="wd-preview__rowcount">' + escapeHtml(String(data.rowCount ?? 0)) + ' صف' + ((data.rowCount ?? 0) !== 1 ? 'وف' : '') + '</span>';
            html += '</div>';

            if (!data.columns || data.columns.length === 0 || !data.rows || data.rows.length === 0) {
                html += '<div class="wd-preview__empty">لا توجد نتائج للاستعلام المحدد</div>';
            } else {
                html += '<div class="wd-preview__body"><table><thead><tr>';
                data.columns.forEach(function(col) {
                    html += '<th>' + escapeHtml(col) + '</th>';
                });
                html += '</tr></thead><tbody>';
                var displayRows = data.rows.slice(0, 10);
                displayRows.forEach(function(row) {
                    html += '<tr>';
                    data.columns.forEach(function(col) {
                        var val = row[col];
                        var display = val !== null && val !== undefined ? String(val) : '—';
                        html += '<td>' + escapeHtml(display) + '</td>';
                    });
                    html += '</tr>';
                });
                html += '</tbody></table></div>';
                if (data.rows.length > 10) {
                    html += '<div style="padding:8px 12px;font-size:12px;color:var(--c-text-muted);text-align:center;border-top:1px solid var(--c-border);">عرض أول 10 صفوف من أصل ' + escapeHtml(String(data.rows.length)) + '</div>';
                }
            }

            html += '</div>';
            previewDiv.innerHTML = html;
            previewDiv.style.display = 'block';

        } catch (err) {
            spinner.style.display = 'none';
            btn.disabled = false;
            previewDiv.innerHTML = '<div class="wd-preview__error"><span>❌</span><span>تعذر الاتصال بالخادم</span></div>';
            previewDiv.style.display = 'block';
        }
    }
</script>
