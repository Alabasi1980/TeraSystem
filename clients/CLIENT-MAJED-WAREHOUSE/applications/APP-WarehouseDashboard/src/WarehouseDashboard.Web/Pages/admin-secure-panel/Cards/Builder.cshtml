@section Scripts {
    <script src="~/js/card-templates.js"></script>
    <script src="~/js/card-builder.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            window.wbBuilder = new CardBuilderWizard({
                previewApiUrl: '/api/dashboard/cardbuilder?handler=Preview',
                tablesApiUrl: '/api/tablemappings/active',
                savedQueriesApiUrl: '/api/savedqueries',
                cloneId: '@Model.Request.Query["clone"]',
                initialData: {
                    cardType: '@Model.CardType',
                    sourceType: '@Model.SourceType',
                    sourceId: '@Model.SourceId',
                    customSql: '@Model.CustomSql',
                    title: '@Model.Title',
                    displayName: '@Model.DisplayName',
                    measurement: '@Model.Measurement'
                }
            });
        });
    </script>
}