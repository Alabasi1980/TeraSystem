@page
@model WarehouseDashboard.Web.Pages.admin_secure_panel.Cards.BuilderModel
@{
    Layout = "_CardsLayout";
    ViewData["Title"] = "منشئ البطاقات البصري";
}

@section Styles {
    <link rel="stylesheet" href="~/css/card-builder.css" />
}

<div class="wb-wizard" id="wb-wizard" data-clone-id="@Model.Request.Query["clone"]">
    <!-- Step Indicator -->
    <nav class="wb-step-indicator" aria-label="خطوات المعالج" role="navigation">
        <ol class="wb-steps">
            <li class="wb-step" data-step="1" aria-current="step">
                <span class="wb-step__number" aria-hidden="true">1</span>
                <span class="wb-step__label">النوع</span>
                <span class="wb-step__bar" aria-hidden="true"></span>
            </li>
            <li class="wb-step" data-step="2">
                <span class="wb-step__number" aria-hidden="true">2</span>
                <span class="wb-step__label">المصدر</span>
                <span class="wb-step__bar" aria-hidden="true"></span>
            </li>
            <li class="wb-step" data-step="3">
                <span class="wb-step__number" aria-hidden="true">3</span>
                <span class="wb-step__label">الحقول</span>
                <span class="wb-step__bar" aria-hidden="true"></span>
            </li>
            <li class="wb-step wb-step--kpi wd-hidden" data-step="4">
                <span class="wb-step__number" aria-hidden="true">4</span>
                <span class="wb-step__label">إعدادات KPI</span>
                <span class="wb-step__bar" aria-hidden="true"></span>
            </li>
            <li class="wb-step" data-step="5">
                <span class="wb-step__number" aria-hidden="true">5</span>
                <span class="wb-step__label">الشكل</span>
            </li>
        </ol>
    </nav>

    <div class="wb-wizard__content">
        <!-- Main Form Area (Left/Top) -->
        <div class="wb-form-pane">
            <form method="post" id="wb-form" class="wb-form" novalidate>

                <!-- Step 1: Type Picker -->
                <fieldset class="wb-step-panel" data-step="1" aria-labelledby="wb-step1-title" role="group">
                    <legend id="wb-step1-title" class="wb-step-panel__title">
                        <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-grid"></use></svg>
                        اختر نوع البطاقة
                    </legend>
                    <p class="wb-step-panel__hint">اختر نوع التمثيل المرئي للبيانات. يمكن تغييره لاحقاً.</p>

                    <div class="wb-type-picker" role="radiogroup" aria-label="نوع البطاقة" id="wb-type-picker">
                        <label class="wb-type-card" data-type="KPI" role="radio" aria-checked="true" tabindex="0">
                            <svg class="wb-type-card__icon" aria-hidden="true"><use href="#wb-icon-kpi"></use></svg>
                            <span class="wb-type-card__name">مؤشر أداء (KPI)</span>
                            <span class="wb-type-card__desc">قيمة واحدة مع مؤشر اتجاه</span>
                            <span class="wb-type-card__check" aria-hidden="true"><svg><use href="#wb-icon-check"></use></svg></span>
                        </label>
                        <label class="wb-type-card" data-type="Bar" role="radio" aria-checked="false" tabindex="-1">
                            <svg class="wb-type-card__icon" aria-hidden="true"><use href="#wb-icon-bar"></use></svg>
                            <span class="wb-type-card__name">مخطط أعمدة</span>
                            <span class="wb-type-card__desc">مقارنة قيم عبر فئات</span>
                            <span class="wb-type-card__check" aria-hidden="true"><svg><use href="#wb-icon-check"></use></svg></span>
                        </label>
                        <label class="wb-type-card" data-type="Line" role="radio" aria-checked="false" tabindex="-1">
                            <svg class="wb-type-card__icon" aria-hidden="true"><use href="#wb-icon-line"></use></svg>
                            <span class="wb-type-card__name">مخطط خطي</span>
                            <span class="wb-type-card__desc">اتجاهات عبر الزمن</span>
                            <span class="wb-type-card__check" aria-hidden="true"><svg><use href="#wb-icon-check"></use></svg></span>
                        </label>
                        <label class="wb-type-card" data-type="Pie" role="radio" aria-checked="false" tabindex="-1">
                            <svg class="wb-type-card__icon" aria-hidden="true"><use href="#wb-icon-pie"></use></svg>
                            <span class="wb-type-card__name">مخطط دائري</span>
                            <span class="wb-type-card__desc">نسب وتركيبة</span>
                            <span class="wb-type-card__check" aria-hidden="true"><svg><use href="#wb-icon-check"></use></svg></span>
                        </label>
                        <label class="wb-type-card" data-type="Table" role="radio" aria-checked="false" tabindex="-1">
                            <svg class="wb-type-card__icon" aria-hidden="true"><use href="#wb-icon-table"></use></svg>
                            <span class="wb-type-card__name">جدول بيانات</span>
                            <span class="wb-type-card__desc">صفوف وأعمدة قابلة للفرز</span>
                            <span class="wb-type-card__check" aria-hidden="true"><svg><use href="#wb-icon-check"></use></svg></span>
                        </label>
                        <label class="wb-type-card" data-type="Gauge" role="radio" aria-checked="false" tabindex="-1">
                            <svg class="wb-type-card__icon" aria-hidden="true"><use href="#wb-icon-gauge"></use></svg>
                            <span class="wb-type-card__name">مقياس (Gauge)</span>
                            <span class="wb-type-card__desc">تقدم نحو هدف</span>
                            <span class="wb-type-card__check" aria-hidden="true"><svg><use href="#wb-icon-check"></use></svg></span>
                        </label>
                    </div>

                    <div class="wb-step-panel__error wd-hidden" id="wb-step1-error" role="alert" aria-live="polite"></div>
                </fieldset>

                <!-- Step 2: Source Selector -->
                <fieldset class="wb-step-panel wd-hidden" data-step="2" aria-labelledby="wb-step2-title" role="group">
                    <legend id="wb-step2-title" class="wb-step-panel__title">
                        <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-database"></use></svg>
                        اختر مصدر البيانات
                    </legend>
                    <p class="wb-step-panel__hint">من أين ستأتي البيانات؟ اختر قالباً جاهزاً أو استعلماً أو جدولاً.</p>

                    <div class="wb-field">
                        <label class="wd-field__label" for="wb-source-type">نوع المصدر</label>
                        <select id="wb-source-type" class="wd-select wb-source-type-select" name="sourceType" aria-describedby="wb-source-type-hint">
                            <option value="Template">قالب جاهز (Template)</option>
                            <option value="SavedQuery">استعلام محفوظ</option>
                            <option value="SqlTable">جدول SQL Server (المزامن)</option>
                            <option value="CustomSQL">استعلام SQL مخصص (متقدم)</option>
                        </select>
                        <span id="wb-source-type-hint" class="wd-field__hint">القوالب تملأ الحقول تلقائياً</span>
                    </div>

                    <!-- Template Selector -->
                    <div class="wb-source-panel" data-source="Template" id="wb-panel-template">
                        <div class="wb-template-grid" id="wb-template-grid" role="listbox" aria-label="القوالب المتاحة">
                            <!-- Templates injected by JS -->
                        </div>
                        <div class="wb-source-panel__empty wd-hidden" id="wb-template-empty">
                            <svg class="wb-empty__icon" aria-hidden="true"><use href="#wb-icon-box"></use></svg>
                            <p>لا توجد قوالب متاحة لهذا النوع</p>
                        </div>
                    </div>

                    <!-- Saved Queries -->
                    <div class="wb-source-panel wd-hidden" data-source="SavedQuery" id="wb-panel-savedquery">
                        <div class="wb-field">
                            <label class="wd-field__label" for="wb-saved-query">استعلام محفوظ</label>
                            <select id="wb-saved-query" class="wd-select wb-searchable-select" name="sourceId" aria-describedby="wb-saved-query-hint">
                                <option value="">ابحث أو اختر استعلاماً محفوظاً...</option>
                            </select>
                            <span id="wb-saved-query-hint" class="wd-field__hint">جاري التحميل...</span>
                        </div>
                    </div>

                    <!-- SQL Server Tables (Synced) -->
                    <div class="wb-source-panel wd-hidden" data-source="SqlTable" id="wb-panel-sqltable">
                        <div class="wb-field">
                            <label class="wd-field__label" for="wb-sql-table">جدول SQL Server</label>
                            <select id="wb-sql-table" class="wd-select wb-searchable-select" name="sourceId" aria-describedby="wb-sql-table-hint">
                                <option value="">ابحث أو اختر جدولاً...</option>
                            </select>
                            <span id="wb-sql-table-hint" class="wd-field__hint">اختر جدولاً مزامناً من SQL Server</span>
                        </div>
                        <div class="wb-field">
                            <label class="wd-field__label" for="wb-measurement-field">الحقل/القياس</label>
                            <select id="wb-measurement-field" class="wd-select" name="measurement" aria-describedby="wb-measurement-hint" disabled>
                                <option value="">اختر جدولاً أولاً</option>
                            </select>
                            <span id="wb-measurement-hint" class="wd-field__hint">الحقل الرقمي للرسوم أو القيمة للمؤشرات</span>
                        </div>
                    </div>

                    <!-- Custom SQL (Advanced) -->
                    <div class="wb-source-panel wd-hidden" data-source="CustomSQL" id="wb-panel-customsql">
                        <div class="wb-field">
                            <label class="wd-field__label" for="wb-custom-sql">استعلام SQL مخصص</label>
                            <textarea id="wb-custom-sql" class="wd-textarea wb-sql-textarea" name="customSql" rows="8" placeholder="SELECT column1, column2 FROM table WHERE condition..." aria-describedby="wb-custom-sql-hint"></textarea>
                            <span id="wb-custom-sql-hint" class="wd-field__hint">استخدم هذا للخبراء فقط. يجب أن يعيد أعمدة قابلة للتمثيل البياني.</span>
                        </div>
                        <div class="wb-field">
                            <label class="wd-field__label" for="wb-sql-measurement">الحقل/القياس</label>
                            <input type="text" id="wb-sql-measurement" class="wd-input" name="measurement" placeholder="اسم العمود الرقمي" aria-describedby="wb-sql-measurement-hint">
                            <span id="wb-sql-measurement-hint" class="wd-field__hint">أدخل اسم العمود الرقمي يدوياً</span>
                        </div>
                    </div>

                    <div class="wb-step-panel__error wd-hidden" id="wb-step2-error" role="alert" aria-live="polite"></div>
                </fieldset>

                <!-- Step 3: Basic Fields -->
                <fieldset class="wb-step-panel wd-hidden" data-step="3" aria-labelledby="wb-step3-title" role="group">
                    <legend id="wb-step3-title" class="wb-step-panel__title">
                        <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-edit"></use></svg>
                        الحقول الأساسية
                    </legend>
                    <p class="wb-step-panel__hint">الحقول المطلوبة موضحة بنجمة. الباقي اختياري.</p>

                    <div class="wd-form__grid">
                        <div class="wd-field">
                            <label class="wd-field__label" for="wb-title">العنوان <span class="wb-required" aria-hidden="true">*</span></label>
                            <input type="text" id="wb-title" class="wd-input" name="title" value="@Model.Title" required aria-required="true" maxlength="100" placeholder="مثال: إجمالي المخزون الشهري">
                            <span class="wd-error" data-for="title"></span>
                        </div>

                        <div class="wd-field">
                            <label class="wd-field__label" for="wb-display-name">اسم العرض <span class="wb-required" aria-hidden="true">*</span></label>
                            <input type="text" id="wb-display-name" class="wd-input" name="displayName" required aria-required="true" maxlength="100" placeholder="مثال: إجمالي المخزون">
                            <span class="wd-error" data-for="displayName"></span>
                        </div>

                        <div class="wd-field wd-field--full">
                            <label class="wd-field__label" for="wb-measurement">القياس/الحقل <span class="wb-required" aria-hidden="true">*</span></label>
                            <select id="wb-measurement" class="wd-select" name="measurement" required aria-required="true" aria-describedby="wb-measurement-hint2">
                                <option value="">اختر قياساً...</option>
                            </select>
                            <span id="wb-measurement-hint2" class="wd-field__hint">يحدد بناءً على المصدر المختار</span>
                            <span class="wd-error" data-for="measurement"></span>
                        </div>

                        <div class="wd-field wd-field--full">
                            <label class="wd-field__label" for="wb-description">الوصف (اختياري)</label>
                            <textarea id="wb-description" class="wd-textarea" name="description" rows="3" placeholder="وصف مختصر للبطاقة يظهر في التلميحات..."></textarea>
                        </div>
                    </div>

                    <div class="wb-step-panel__error wd-hidden" id="wb-step3-error" role="alert" aria-live="polite"></div>
                </fieldset>

                <!-- Step 4: KPI Settings (only shown when chartType == 'KPI') -->
                <fieldset class="wb-step-panel wd-hidden" data-step="4" aria-labelledby="wb-step4-kpi-title" role="group" id="wb-step-kpi">
                    <legend id="wb-step4-kpi-title" class="wb-step-panel__title">
                        <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-kpi"></use></svg>
                        إعدادات المؤشر KPI
                    </legend>
                    <p class="wb-step-panel__hint">تكوين طريقة عرض المؤشر والبيانات المتعددة.</p>

                    <!-- KPI Mode -->
                    <div class="wb-visual-section">
                        <h4 class="wb-visual-section__title">نوع المؤشر</h4>
                        <div class="wb-kpi-mode-picker" id="wb-kpi-mode-picker" role="radiogroup" aria-label="نوع المؤشر">
                            <label class="wb-kpi-mode-card" data-mode="simple" role="radio" aria-checked="true" tabindex="0">
                                <span class="wb-kpi-mode-card__icon">📊</span>
                                <span class="wb-kpi-mode-card__name">بسيط</span>
                                <span class="wb-kpi-mode-card__desc">قيمة واحدة فقط</span>
                            </label>
                            <label class="wb-kpi-mode-card" data-mode="withChange" role="radio" aria-checked="false" tabindex="-1">
                                <span class="wb-kpi-mode-card__icon">📈</span>
                                <span class="wb-kpi-mode-card__name">مع تغير</span>
                                <span class="wb-kpi-mode-card__desc">قيمة + نسبة التغير</span>
                            </label>
                            <label class="wb-kpi-mode-card" data-mode="composite" role="radio" aria-checked="false" tabindex="-1">
                                <span class="wb-kpi-mode-card__icon">🎯</span>
                                <span class="wb-kpi-mode-card__name">متقدم</span>
                                <span class="wb-kpi-mode-card__desc">قيمة + تغير + Sparkline + إجمالي</span>
                            </label>
                        </div>
                        <input type="hidden" name="kpiMode" id="wb-h-kpiMode" value="simple">
                    </div>

                    <!-- Column Mappings -->
                    <div class="wb-visual-section">
                        <h4 class="wb-visual-section__title">تعيينات الأعمدة</h4>
                        <div class="wd-form__grid">
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-kpi-value-column">عمود القيمة <span class="wb-required" aria-hidden="true">*</span></label>
                                <select id="wb-kpi-value-column" class="wd-select" name="valueColumn">
                                    <option value="">اختر عموداً...</option>
                                </select>
                                <span class="wd-field__hint">العمود الرقمي للقيمة الرئيسية</span>
                            </div>
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-kpi-date-column">عمود التاريخ <span class="wb-required" aria-hidden="true">*</span></label>
                                <select id="wb-kpi-date-column" class="wd-select" name="dateColumn">
                                    <option value="">اختر عموداً...</option>
                                </select>
                                <span class="wd-field__hint">عمود التاريخ للفلترة الزمنية</span>
                            </div>
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-kpi-category-column">عمود التصنيف (اختياري)</label>
                                <select id="wb-kpi-category-column" class="wd-select" name="categoryColumn">
                                    <option value="">بدون تصنيف</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Change Settings (shown only for withChange and composite) -->
                    <div class="wb-visual-section wb-kpi-section wb-kpi-change-section" id="wb-kpi-change-section" style="display:none;">
                        <h4 class="wb-visual-section__title">إعدادات نسبة التغير</h4>
                        <div class="wd-form__grid">
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-kpi-change-source">مقارنة بـ</label>
                                <select id="wb-kpi-change-source" class="wd-select" name="changeSource">
                                    <option value="previousPeriod">الفترة السابقة (30 يوم)</option>
                                    <option value="previousMonth">الشهر السابق</option>
                                    <option value="previousYear">السنة السابقة</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Sparkline Settings (shown only for composite) -->
                    <div class="wb-visual-section wb-kpi-section wb-kpi-sparkline-section" id="wb-kpi-sparkline-section" style="display:none;">
                        <h4 class="wb-visual-section__title">إعدادات رسم الاتجاه</h4>
                        <div class="wd-form__grid">
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-kpi-sparkline-months">عدد الأشهر</label>
                                <select id="wb-kpi-sparkline-months" class="wd-select" name="sparklineMonths">
                                    <option value="3">3 أشهر</option>
                                    <option value="6" selected>6 أشهر</option>
                                    <option value="12">12 شهر</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Grand Total Settings (shown only for composite) -->
                    <div class="wb-visual-section wb-kpi-section wb-kpi-total-section" id="wb-kpi-total-section" style="display:none;">
                        <h4 class="wb-visual-section__title">إعدادات الإجمالي العام</h4>
                        <div class="wd-form__grid">
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-kpi-grand-total-source">مصدر الإجمالي</label>
                                <select id="wb-kpi-grand-total-source" class="wd-select" name="grandTotalSource">
                                    <option value="sameTable">نفس الجدول (بدون فلتر زمني)</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Date Filter Settings (shown only for withChange and composite) -->
                    <div class="wb-visual-section wb-kpi-section wb-kpi-date-section" id="wb-kpi-date-section" style="display:none;">
                        <h4 class="wb-visual-section__title">إعدادات الفلتر الزمني</h4>
                        <div class="wd-form__grid">
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-kpi-date-filter-mode">طريقة الفلترة</label>
                                <select id="wb-kpi-date-filter-mode" class="wd-select" name="dateFilterMode">
                                    <option value="dashboard">حسب فلتر لوحة المعلومات</option>
                                    <option value="fixed">نطاق ثابت</option>
                                    <option value="relative">آخر N يوم</option>
                                </select>
                            </div>
                            <div class="wd-field wb-kpi-fixed-dates" id="wb-kpi-fixed-start-field" style="display:none;">
                                <label class="wd-field__label" for="wb-kpi-fixed-start">تاريخ البداية</label>
                                <input type="date" id="wb-kpi-fixed-start" class="wd-input" name="fixedStartDate">
                            </div>
                            <div class="wd-field wb-kpi-fixed-dates" id="wb-kpi-fixed-end-field" style="display:none;">
                                <label class="wd-field__label" for="wb-kpi-fixed-end">تاريخ النهاية</label>
                                <input type="date" id="wb-kpi-fixed-end" class="wd-input" name="fixedEndDate">
                            </div>
                            <div class="wd-field wb-kpi-relative-days" id="wb-kpi-relative-days-field" style="display:none;">
                                <label class="wd-field__label" for="wb-kpi-relative-days">عدد الأيام</label>
                                <input type="number" id="wb-kpi-relative-days" class="wd-input" name="relativeDays" min="1" max="365" value="30">
                            </div>
                        </div>
                    </div>

                    <div class="wb-step-panel__error wd-hidden" id="wb-step4-kpi-error" role="alert" aria-live="polite"></div>
                </fieldset>

                <!-- Step 5: Visual Settings -->
                <fieldset class="wb-step-panel wd-hidden" data-step="5" aria-labelledby="wb-step5-title" role="group">
                    <legend id="wb-step5-title" class="wb-step-panel__title">
                        <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-palette"></use></svg>
                        إعدادات الشكل
                    </legend>
                    <p class="wb-step-panel__hint">تحكم في الحجم، الموضع، الألوان، والتحديث التلقائي.</p>

                    <div class="wb-visual-section">
                        <h4 class="wb-visual-section__title">الحجم والموضع (Grid)</h4>
                        <div class="wd-form__grid">
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-grid-width">العرض (1-12)</label>
                                <input type="number" id="wb-grid-width" class="wd-input wb-grid-input" name="gridWidth" min="1" max="12" value="4" aria-describedby="wb-grid-width-hint">
                                <span id="wb-grid-width-hint" class="wd-field__hint">عدد الأعمدة</span>
                            </div>
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-grid-height">الارتفاع (1-6)</label>
                                <input type="number" id="wb-grid-height" class="wd-input wb-grid-input" name="gridHeight" min="1" max="6" value="2" aria-describedby="wb-grid-height-hint">
                                <span id="wb-grid-height-hint" class="wd-field__hint">عدد الصفوف</span>
                            </div>
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-grid-x">الموضع X (اختياري)</label>
                                <input type="number" id="wb-grid-x" class="wd-input wb-grid-input" name="gridX" min="0" max="11" placeholder="تلقائي" aria-describedby="wb-grid-x-hint">
                                <span id="wb-grid-x-hint" class="wd-field__hint">يترك فارغاً للتعيين التلقائي</span>
                            </div>
                            <div class="wd-field">
                                <label class="wd-field__label" for="wb-grid-y">الموضع Y (اختياري)</label>
                                <input type="number" id="wb-grid-y" class="wd-input wb-grid-input" name="gridY" min="0" placeholder="تلقائي" aria-describedby="wb-grid-y-hint">
                                <span id="wb-grid-y-hint" class="wd-field__hint">يترك فارغاً للتعيين التلقائي</span>
                            </div>
                        </div>
                    </div>

                    <div class="wb-visual-section">
                        <h4 class="wb-visual-section__title">لوحة الألوان</h4>
                        <div class="wb-palette-picker" id="wb-palette-picker" role="radiogroup" aria-label="لوحة الألوان">
                            <!-- Palette options injected by JS -->
                        </div>
                    </div>

                    <div class="wb-visual-section">
                        <h4 class="wb-visual-section__title">فترة التحديث التلقائي</h4>
                        <div class="wb-field">
                            <label class="wd-field__label" for="wb-refresh-interval">التحديث</label>
                            <select id="wb-refresh-interval" class="wd-select" name="refreshInterval" aria-describedby="wb-refresh-hint">
                                <option value="0">إيقاف (يدوي فقط)</option>
                                <option value="60">دقيقة واحدة</option>
                                <option value="300" selected>5 دقائق</option>
                                <option value="900">15 دقيقة</option>
                                <option value="3600">ساعة واحدة</option>
                            </select>
                            <span id="wb-refresh-hint" class="wd-field__hint">كم مرة يتم تحديث البيانات تلقائياً</span>
                        </div>
                    </div>

                    <!-- Chart-specific options (collapsible) -->
                    <div class="wb-visual-section">
                        <h4 class="wb-visual-section__title">خيارات نوع الرسم <span class="wb-visual-section__badge" id="wb-chart-options-badge">مطوية</span></h4>
                        <details class="wb-chart-options" id="wb-chart-options">
                            <summary class="wb-chart-options__summary">
                                <span>إظهار/إخفاء خيارات <span id="wb-chart-type-name">الرسم</span></span>
                                <svg class="wb-icon wb-chart-options__chevron" aria-hidden="true"><use href="#wb-icon-chevron-down"></use></svg>
                            </summary>
                            <div class="wb-chart-options__content" id="wb-chart-options-content">
                                <!-- Injected by JS based on card type -->
                            </div>
                        </details>
                    </div>

                    <!-- Advanced Accordion -->
                    <details class="wb-advanced-accordion" id="wb-advanced-accordion">
                        <summary class="wb-advanced-accordion__summary">
                            <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-settings"></use></svg>
                            <span>خيارات متقدمة</span>
                            <svg class="wb-icon wb-advanced-accordion__chevron" aria-hidden="true"><use href="#wb-icon-chevron-down"></use></svg>
                        </summary>
                        <div class="wb-advanced-accordion__content">
                            <div class="wb-advanced-section">
                                <h5 class="wb-advanced-section__title">فلاتر البيانات (اختياري)</h5>
                                <div id="wb-filters-container" class="wb-filters-list">
                                    <div class="wb-filter-row">
                                        <input type="text" class="wd-input wb-filter-key" placeholder="المفتاح (مثال: WarehouseId)" aria-label="مفتاح الفلتر">
                                        <input type="text" class="wd-input wb-filter-value" placeholder="القيمة (مثال: 1)" aria-label="قيمة الفلتر">
                                        <button type="button" class="wd-btn wd-btn--ghost wd-btn--sm wb-filter-remove" aria-label="إزالة الفلتر"><svg class="wb-icon"><use href="#wb-icon-trash"></use></svg></button>
                                    </div>
                                </div>
                                <button type="button" class="wd-btn wd-btn--ghost wd-btn--sm" id="wb-add-filter">
                                    <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-plus"></use></svg>
                                    إضافة فلتر
                                </button>
                            </div>

                            <div class="wb-advanced-section">
                                <h5 class="wb-advanced-section__title">تكوين Drill-down (اختياري)</h5>
                                <div class="wd-form__grid">
                                    <div class="wd-field">
                                        <label class="wd-field__label" for="wb-drill-level">مستوى الحفر</label>
                                        <select id="wb-drill-level" class="wd-select" name="drillLevel">
                                            <option value="">لا يوجد</option>
                                            <option value="warehouse">مستودع</option>
                                            <option value="item">صنف</option>
                                            <option value="transaction">معاملة</option>
                                        </select>
                                    </div>
                                    <div class="wd-field">
                                        <label class="wd-field__label" for="wb-drill-field">الحقل المرتبط</label>
                                        <input type="text" id="wb-drill-field" class="wd-input" name="drillField" placeholder="مثال: WarehouseId">
                                    </div>
                                </div>
                            </div>

                            <div class="wb-advanced-section">
                                <h5 class="wb-advanced-section__title">تسميات وتلميحات مخصصة (اختياري)</h5>
                                <div class="wd-form__grid">
                                    <div class="wd-field">
                                        <label class="wd-field__label" for="wb-custom-label">تسمية مخصصة للمحور Y</label>
                                        <input type="text" id="wb-custom-label" class="wd-input" name="customLabel" placeholder="مثال: الكمية (وحدة)">
                                    </div>
                                    <div class="wd-field">
                                        <label class="wd-field__label" for="wb-tooltip-format">تنسيق التلميح</label>
                                        <input type="text" id="wb-tooltip-format" class="wd-input" name="tooltipFormat" placeholder="مثال: {value:N0} وحدة">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </details>

                    <div class="wb-step-panel__error wd-hidden" id="wb-step5-error" role="alert" aria-live="polite"></div>
                </fieldset>

                <!-- Hidden fields for form submission -->
                <input type="hidden" name="cardType" id="wb-h-cardType" value="@Model.CardType">
                <input type="hidden" name="sourceType" id="wb-h-sourceType" value="@Model.SourceType">
                <input type="hidden" name="sourceId" id="wb-h-sourceId" value="@Model.SourceId">
                <input type="hidden" name="customSql" id="wb-h-customSql" value="@Model.CustomSql">
                <input type="hidden" name="gridWidth" id="wb-h-gridWidth" value="4">
                <input type="hidden" name="gridHeight" id="wb-h-gridHeight" value="2">
                <input type="hidden" name="gridX" id="wb-h-gridX" value="">
                <input type="hidden" name="gridY" id="wb-h-gridY" value="">
                <input type="hidden" name="colorPalette" id="wb-h-colorPalette" value="primary">
                <input type="hidden" name="refreshInterval" id="wb-h-refreshInterval" value="300">
                <input type="hidden" name="chartOptionsJson" id="wb-h-chartOptionsJson" value="{}">
                <input type="hidden" name="filtersJson" id="wb-h-filtersJson" value="[]">
                <input type="hidden" name="drillDownConfigJson" id="wb-h-drillDownConfigJson" value="{}">
                <input type="hidden" name="customLabelsJson" id="wb-h-customLabelsJson" value="{}">

                <!-- KPI fields (TASK-KPI-006) -->
                <input type="hidden" name="valueColumn" id="wb-h-valueColumn" value="">
                <input type="hidden" name="dateColumn" id="wb-h-dateColumn" value="">
                <input type="hidden" name="categoryColumn" id="wb-h-categoryColumn" value="">
                <input type="hidden" name="showChange" id="wb-h-showChange" value="false">
                <input type="hidden" name="changeSource" id="wb-h-changeSource" value="previousPeriod">
                <input type="hidden" name="showSparkline" id="wb-h-showSparkline" value="false">
                <input type="hidden" name="sparklineMonths" id="wb-h-sparklineMonths" value="6">
                <input type="hidden" name="showGrandTotal" id="wb-h-showGrandTotal" value="false">
                <input type="hidden" name="grandTotalSource" id="wb-h-grandTotalSource" value="sameTable">
                <input type="hidden" name="dateFilterMode" id="wb-h-dateFilterMode" value="dashboard">
                <input type="hidden" name="fixedStartDate" id="wb-h-fixedStartDate" value="">
                <input type="hidden" name="fixedEndDate" id="wb-h-fixedEndDate" value="">
                <input type="hidden" name="relativeDays" id="wb-h-relativeDays" value="30">

            </form>
        </div>

        <!-- Live Preview Pane (Right/Bottom) -->
        <aside class="wb-preview-pane" id="wb-preview-pane" aria-label="معاينة مباشرة" role="region">
            <div class="wb-preview__header">
                <h3 class="wb-preview__title">معاينة مباشرة</h3>
                <div class="wb-preview__status">
                    <span class="wb-connection-status" id="wb-connection-status" aria-live="polite">
                        <span class="wb-connection-status__dot" aria-hidden="true"></span>
                        <span class="wb-connection-status__text">متصل</span>
                    </span>
                </div>
            </div>

            <div class="wb-preview__container" id="wb-preview-container">
                <!-- Skeleton Loading -->
                <div class="wb-preview__skeleton wd-skeleton-wrap" id="wb-preview-skeleton" aria-hidden="true">
                    <div class="wd-skel-row">
                        <div class="wd-skel" style="width: 60%;"></div>
                        <div class="wd-skel" style="width: 30%;"></div>
                    </div>
                    <div class="wd-skel-row" style="margin-top: var(--sp-4);">
                        <div class="wd-skel" style="width: 100%; height: 120px; border-radius: var(--radius-md);"></div>
                    </div>
                    <div class="wd-skel-row" style="margin-top: var(--sp-3);">
                        <div class="wd-skel" style="width: 40%;"></div>
                        <div class="wd-skel" style="width: 40%;"></div>
                    </div>
                </div>

                <!-- Actual Preview Content -->
                <div class="wb-preview__content wd-hidden" id="wb-preview-content" role="img" aria-label="معاينة البطاقة">
                    <!-- Syncfusion chart/card rendered here -->
                </div>

                <!-- Empty State -->
                <div class="wb-preview__empty wd-hidden" id="wb-preview-empty">
                    <svg class="wb-empty__icon" aria-hidden="true"><use href="#wb-icon-preview"></use></svg>
                    <h4>اختر نوع بطاقة للبدء</h4>
                    <p>المعاينة تظهر هنا فور اختيارك للنوع والمصدر</p>
                </div>

                <!-- Error State -->
                <div class="wb-preview__error wd-hidden" id="wb-preview-error" role="alert">
                    <svg class="wb-empty__icon" aria-hidden="true"><use href="#wb-icon-alert"></use></svg>
                    <h4>تعذر تحميل المعاينة</h4>
                    <p id="wb-preview-error-msg">حدث خطأ أثناء توليد المعاينة</p>
                    <button type="button" class="wd-btn wd-btn--ghost wd-btn--sm" id="wb-preview-retry">إعادة المحاولة</button>
                </div>
            </div>
        </aside>
    </div>

    <!-- Fixed Bottom Navigation -->
    <footer class="wb-wizard__footer" id="wb-wizard-footer">
        <div class="wb-footer__left">
            <button type="button" class="wd-btn wd-btn--ghost wb-btn-prev" id="wb-btn-prev" disabled aria-disabled="true">
                <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-chevron-right"></use></svg>
                السابق
            </button>
            <button type="button" class="wd-btn wd-btn--ghost wb-btn-cancel" id="wb-btn-cancel">
                إلغاء
            </button>
        </div>
        <div class="wb-footer__right">
            <button type="button" class="wd-btn wd-btn--ghost wb-btn-save-add" id="wb-btn-save-add" disabled aria-disabled="true">
                حفظ وإضافة أخرى
            </button>
            <button type="button" class="wd-btn wd-btn--primary wb-btn-save" id="wb-btn-save" disabled aria-disabled="true">
                <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-save"></use></svg>
                حفظ
            </button>
            <button type="button" class="wd-btn wd-btn--primary wb-btn-next" id="wb-btn-next" disabled aria-disabled="true">
                التالي
                <svg class="wb-icon" aria-hidden="true"><use href="#wb-icon-chevron-left"></use></svg>
            </button>
        </div>
    </footer>
</div>

