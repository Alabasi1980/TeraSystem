@{
    // Self-contained admin layout for the Cards CRUD area.
    // Kept inside the Cards folder so it does not touch the global _Layout.
    // Blue theme tokens are inlined per 28_UI_UX_GUIDELINES.md §1.
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Warehouse Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet" />

    @* Shared design system — single source of truth for the Blue Identity palette *@
    <link rel="stylesheet" href="~/css/blue-theme.css" />

    @* Chart.js (MIT license, no build step) *@
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

    <style>
        /* All design tokens now come from blue-theme.css — no duplicate :root here.
           The [data-theme] overrides in blue-theme.css handle midnight/emerald themes. */

        * { box-sizing: border-box; }

        html, body { margin: 0; padding: 0; }

        body.wd-app {
            font-family: var(--font-ar);
            font-size: 14px;
            line-height: 1.6;
            color: var(--c-text);
            background: var(--c-bg);
            min-height: 100vh;
        }

        /* Topbar styles moved to blue-theme.css */

        /* ===== Content ===== */
        .wd-content {
            padding: var(--sp-6);
            max-width: 1200px;
            margin-inline: auto;
            width: 100%;
        }

        /* ===== Breadcrumb ===== */
        .wd-breadcrumb-row {
            display: flex;
            align-items: center;
            gap: var(--sp-2);
            color: var(--c-text-muted);
            font-size: 13px;
            margin-bottom: var(--sp-4);
        }
        .wd-breadcrumb-row a { color: var(--c-secondary); text-decoration: none; }
        .wd-breadcrumb-row a:hover { color: var(--c-primary); }
        .wd-sep { color: var(--c-border); }

        /* ===== Page head ===== */
        .wd-page-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: var(--sp-4);
            margin-bottom: var(--sp-6);
        }
        .wd-page-title { font-size: 22px; font-weight: 700; margin: 0; color: var(--c-text); }

        /* ===== Card container §3.2 ===== */
        .wd-card {
            background: var(--c-surface);
            border: 1px solid var(--c-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            padding: var(--sp-6);
            transition: box-shadow var(--dur-norm) var(--ease);
            animation: wdFadeUp var(--dur-norm) var(--ease) both;
        }
        .wd-card:hover { box-shadow: var(--shadow-lg); }
        .wd-card__header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: var(--sp-3);
        }
        .wd-card__title { font-size: 18px; font-weight: 600; margin: 0; color: var(--c-text); }

        /* ===== Buttons ===== */
        .wd-btn {
            display: inline-flex; align-items: center; justify-content: center; gap: var(--sp-2);
            font-family: var(--font-ar);
            font-size: 14px; font-weight: 600; line-height: 1.2;
            padding: 10px 18px;
            border-radius: var(--radius-md);
            border: 1px solid transparent;
            cursor: pointer;
            text-decoration: none;
            transition: background var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease);
            min-height: 40px;
        }
        .wd-btn:active { transform: translateY(1px); }
        .wd-btn--primary { background: var(--c-primary); color: #fff; }
        .wd-btn--primary:hover { background: var(--c-primary-strong); }
        .wd-btn--ghost { background: transparent; color: var(--c-primary); border-color: var(--c-border); }
        .wd-btn--ghost:hover { background: var(--c-surface-muted); }
        .wd-btn--sm { padding: 6px 12px; min-height: 34px; font-size: 13px; }
        .wd-btn--danger { background: var(--c-error); color: #fff; }
        .wd-btn--danger:hover { filter: brightness(0.95); }

        /* ===== Form ===== */
        .wd-form { margin-top: var(--sp-2); }
        .wd-form__grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: var(--sp-4) var(--sp-6);
        }
        .wd-field { display: flex; flex-direction: column; gap: var(--sp-2); margin-bottom: var(--sp-2); }
        .wd-field--full { grid-column: 1 / -1; }
        .wd-field--check { flex-direction: row; align-items: center; }
        .wd-field label { font-size: 13px; font-weight: 600; color: var(--c-text); }
        .wd-field .wd-error { color: var(--c-error); font-size: 12px; }

        /* ===== Standard form controls ===== */
        .wd-input, .wd-select, .wd-textarea {
            width: 100%; font-family: var(--font-ar);
            font-size: 14px; color: var(--c-text);
            border: 1px solid var(--c-border); border-radius: var(--radius-md);
            padding: 10px 12px; background: var(--c-surface);
            transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
        }
        .wd-textarea { min-height: 100px; resize: vertical; }
        .wd-input:focus, .wd-select:focus, .wd-textarea:focus {
            outline: none; border-color: var(--c-primary);
            box-shadow: 0 0 0 3px rgba(31,78,121,0.12);
        }

        .wd-form__actions {
            display: flex; align-items: center; gap: var(--sp-3);
            margin-top: var(--sp-6);
            padding-top: var(--sp-4);
            border-top: 1px solid var(--c-border);
        }

        /* ===== Radzen grid tuning §2.3 ===== */
        .wd-radzen-grid { border-radius: var(--radius-md); overflow: hidden; }
        .wd-radzen-grid .rz-datatable-thead th { background: var(--c-surface-muted); color: var(--c-text); font-weight: 600; }
        .wd-radzen-grid .rz-datatable-data td { color: var(--c-text); }
        .wd-radzen-grid .rz-datatable-even { background: #F7FAFD; }

        /* ===== Grid wrapper + skeleton ===== */
        .wd-grid-wrap { display: none; }
        .wd-skeleton-wrap {
            display: block;
            background: var(--c-surface);
            border: 1px solid var(--c-border);
            border-radius: var(--radius-lg);
            padding: var(--sp-4);
            box-shadow: var(--shadow-sm);
        }
        .wd-skel-row {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 0.6fr 0.6fr 0.6fr 0.6fr 0.6fr 0.8fr 1fr;
            gap: var(--sp-3);
            padding: var(--sp-3) var(--sp-2);
            border-bottom: 1px solid var(--c-border);
        }
        .wd-skel {
            height: 16px; border-radius: var(--radius-sm);
            background: linear-gradient(90deg, var(--c-surface-muted) 25%, rgba(143,188,222,0.08) 50%, var(--c-surface-muted) 75%);
            background-size: 200% 100%;
            animation: wdShimmer 1.6s ease-in-out infinite;
        }
        @@keyframes wdShimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* ===== Badge (IsActive) ===== */
        .wd-badge {
            display: inline-flex; align-items: center; justify-content: center;
            padding: 2px 10px; border-radius: var(--radius-full);
            font-size: 12px; font-weight: 600; line-height: 1.6;
        }
        .wd-badge--on { background: rgba(30, 158, 106, 0.12); color: var(--c-success); }
        .wd-badge--off { background: rgba(214, 69, 69, 0.10); color: var(--c-error); }

        /* ===== Links (grid actions) ===== */
        .wd-link {
            color: var(--c-primary); font-weight: 600; text-decoration: none;
            background: none; border: none; cursor: pointer; font-family: var(--font-ar); font-size: 13px;
            padding: 4px 8px; border-radius: var(--radius-sm);
        }
        .wd-link:hover { background: var(--c-surface-muted); }
        .wd-link--danger { color: var(--c-error); }

        /* ===== Empty state §7.1 ===== */
        .wd-empty {
            text-align: center;
            display: flex; flex-direction: column; align-items: center; gap: var(--sp-3);
            padding: var(--sp-12) var(--sp-6);
        }
        .wd-empty__icon {
            width: 64px; height: 64px; border-radius: var(--radius-full);
            background: var(--c-surface-muted); color: var(--c-text-muted);
            display: flex; align-items: center; justify-content: center; font-size: 30px;
        }
        .wd-empty h3 { margin: 0; font-size: 18px; color: var(--c-text); }
        .wd-empty p { margin: 0; color: var(--c-text-muted); }

        /* ===== Toast (§7.2) ===== */
        .wd-toast-host {
            position: fixed; top: 76px; inset-inline-end: var(--sp-6);
            z-index: 1000; display: flex; flex-direction: column; gap: var(--sp-2);
            pointer-events: none;
        }
        .wd-toast {
            pointer-events: auto;
            display: flex; align-items: center; gap: var(--sp-3);
            background: var(--c-surface); color: var(--c-text);
            border: 1px solid var(--c-border); border-inline-start: 4px solid var(--c-success);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-lg);
            padding: 12px 16px; min-width: 260px; max-width: 360px;
            animation: wdToastIn var(--dur-norm) var(--ease) both;
        }
        .wd-toast--success { border-inline-start-color: var(--c-success); }
        .wd-toast--error { border-inline-start-color: var(--c-error); }
        .wd-toast__icon {
            width: 24px; height: 24px; border-radius: var(--radius-full);
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700; color: #fff; flex: none;
        }
        .wd-toast--success .wd-toast__icon { background: var(--c-success); }
        .wd-toast--error .wd-toast__icon { background: var(--c-error); }
        .wd-toast__msg { font-size: 14px; }

        .wd-hidden { display: none !important; }

        /* ===== Animations ===== */
        @@keyframes wdFadeUp {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @@keyframes wdToastIn {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ===== Responsive §5 ===== */
        @@media (max-width: 768px) {
            .wd-content { padding: var(--sp-3); }
            .wd-form__grid { grid-template-columns: 1fr; }
            .wd-skel-row { grid-template-columns: 1fr; }
            .wd-page-head { flex-direction: column; align-items: flex-start; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="wd-app">
    @{
        ViewData["BrandHref"] = "/admin-secure-panel";
        ViewData["BrandText"] = "Warehouse Dashboard · لوحة الإدارة";
        ViewData["IsAdmin"] = true;
        ViewData["ShowConnectionStatus"] = true;
    }
    @await Html.PartialAsync("_Header")

    <main class="wd-content">
        @RenderBody()
    </main>

    <div id="wd-toast-host" class="wd-toast-host" aria-live="polite" aria-atomic="true">
        @await RenderSectionAsync("Toast", required: false)
    </div>

    @* ===== Keyboard Shortcuts HUD ===== *@
    <div id="wd-shortcuts-hud" class="wd-hud" role="dialog" aria-label="اختصارات لوحة المفاتيح" hidden>
        <div class="wd-hud__overlay" onclick="closeShortcutsHud()"></div>
        <div class="wd-hud__panel">
            <div class="wd-hud__header">
                <h3 class="wd-hud__title">اختصارات لوحة المفاتيح</h3>
                <button type="button" class="wd-hud__close" onclick="closeShortcutsHud()" aria-label="إغلاق">&times;</button>
            </div>
            <div class="wd-hud__body">
                <div class="wd-hud__row"><kbd>?</kbd> <span>عرض هذه القائمة</span></div>
                <div class="wd-hud__row"><kbd>Ctrl + Enter</kbd> <span>تشغيل الاستعلام (في مختبّر الاستعلامات)</span></div>
                <div class="wd-hud__row"><kbd>Esc</kbd> <span>إغلاق النافذة المنبثقة</span></div>
                <div class="wd-hud__row"><kbd>C</kbd> <span>الذهاب إلى إدارة البطاقات</span></div>
                <div class="wd-hud__row"><kbd>S</kbd> <span>الذهاب إلى شاشة المزامنة</span></div>
                <div class="wd-hud__row"><kbd>L</kbd> <span>الذهاب إلى سجلات المزامنة</span></div>
                <div class="wd-hud__row"><kbd>Q</kbd> <span>الذهاب إلى مختبّر الاستعلامات</span></div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            // === Keyboard Shortcuts HUD ===
            function openShortcutsHud() {
                var hud = document.getElementById('wd-shortcuts-hud');
                if (hud) hud.hidden = false;
            }
            window.openShortcutsHud = openShortcutsHud;
            window.closeShortcutsHud = function() {
                var hud = document.getElementById('wd-shortcuts-hud');
                if (hud) hud.hidden = true;
            };
            document.addEventListener('keydown', function(e) {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
                if (e.key === '?' && !e.shiftKey) return;
                if (e.key === '?' || (e.shiftKey && e.key === '?' && !e.ctrlKey && !e.altKey && !e.metaKey)) {
                    e.preventDefault();
                    var hud = document.getElementById('wd-shortcuts-hud');
                    if (hud) hud.hidden = !hud.hidden;
                }
                if (e.key === 'Escape') {
                    var hud = document.getElementById('wd-shortcuts-hud');
                    if (hud && !hud.hidden) { hud.hidden = true; return; }
                }
                var hud = document.getElementById('wd-shortcuts-hud');
                if (hud && !hud.hidden) return;
                if (!e.ctrlKey && !e.altKey && !e.metaKey) {
                    if (e.key === 'c' || e.key === 'C') { e.preventDefault(); window.location.href = '/admin-secure-panel/Cards'; }
                    if (e.key === 's' || e.key === 'S') { e.preventDefault(); window.location.href = '/admin-secure-panel/Sync'; }
                    if (e.key === 'l' || e.key === 'L') { e.preventDefault(); window.location.href = '/admin-secure-panel/SyncLogs'; }
                    if (e.key === 'q' || e.key === 'Q') { e.preventDefault(); window.location.href = '/admin-secure-panel/QueryTester'; }
                }
                if (e.ctrlKey && e.key === 'Enter') {
                    var runBtn = document.getElementById('runBtn');
                    if (runBtn) { e.preventDefault(); runBtn.click(); }
                }
            });

            // === Sync Status Polling ===
            function checkSyncStatus() {
                var badge = document.getElementById('wd-sync-status');
                var text = document.getElementById('wd-sync-status-text');
                if (!badge || !text) return;
                fetch('/api/sync/status')
                    .then(function(r) { return r.json(); })
                    .then(function(d) {
                        if (d && d.isRunning) {
                            badge.className = 'wd-sync-status wd-sync-status--running';
                            text.textContent = 'مزامنة...';
                        } else if (d && d.lastError) {
                            badge.className = 'wd-sync-status wd-sync-status--error';
                            text.textContent = 'خطأ';
                        } else {
                            badge.className = 'wd-sync-status wd-sync-status--idle';
                            text.textContent = 'متوقف';
                        }
                    })
                    .catch(function() {
                        badge.className = 'wd-sync-status';
                        text.textContent = '--';
                    });
            }
            checkSyncStatus();
            setInterval(checkSyncStatus, 15000);
        })();

        // === Theme Switcher ===
        (function() {
            var toggleBtn = document.getElementById('wd-theme-toggle');
            var themeMenu = document.getElementById('wd-theme-menu');
            if (toggleBtn && themeMenu) {
                toggleBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    themeMenu.hidden = !themeMenu.hidden;
                });
                document.addEventListener('click', function() {
                    themeMenu.hidden = true;
                });
                themeMenu.addEventListener('click', function(e) {
                    e.stopPropagation();
                });
            }

            var currentTheme = localStorage.getItem('wd-theme') || 'blue';
            document.documentElement.setAttribute('data-theme', currentTheme);

            var options = document.querySelectorAll('.wd-theme-option');
            options.forEach(function(opt) {
                if (opt.getAttribute('data-theme') === currentTheme) opt.classList.add('is-active');
                opt.addEventListener('click', function() {
                    var theme = this.getAttribute('data-theme');
                    localStorage.setItem('wd-theme', theme);
                    document.documentElement.setAttribute('data-theme', theme);
                    options.forEach(function(o) { o.classList.remove('is-active'); });
                    this.classList.add('is-active');
                    themeMenu.hidden = true;
                });
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
