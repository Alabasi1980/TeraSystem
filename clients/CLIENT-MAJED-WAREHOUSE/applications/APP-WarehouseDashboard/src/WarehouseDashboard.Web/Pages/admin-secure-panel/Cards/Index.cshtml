@page
@model IndexModel
@{
    ViewData["Title"] = "إدارة البطاقات";
}

<div class="wd-breadcrumb-row">
    <span>البطاقات</span>
</div>

<div class="wd-page-head">
    <h2 class="wd-page-title">بطاقات لوحة المعلومات</h2>
    <a href="/admin-secure-panel/Cards/Create" class="wd-btn wd-btn--primary">+ بطاقة جديدة</a>
</div>

@if (Model.Cards.Count == 0)
{
    <div class="wd-card wd-empty">
        <div class="wd-empty__icon">▦</div>
        <h3>لا توجد بطاقات بعد</h3>
        <p>ابدأ بإضافة بطاقة جديدة لعرضها في لوحة المعلومات.</p>
        <a href="/admin-secure-panel/Cards/Create" class="wd-btn wd-btn--primary">+ إضافة بطاقة</a>
    </div>
}
else
{
    <div class="wd-grid-wrap" id="wdGridWrap">
        <component type="typeof(CardsGrid)" render-mode="ServerPrerendered"
                   param-CardsJson="@System.Text.Json.JsonSerializer.Serialize(Model.Cards)" />
    </div>

    <div class="wd-skeleton-wrap" id="wdSkeleton" aria-hidden="true">
        @for (var i = 0; i < 6; i++)
        {
            <div class="wd-skel-row">
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
            </div>
        }
    </div>
}

<form id="wdDeleteForm" method="post" asp-page-handler="Delete" class="wd-hidden">
    <input type="hidden" name="id" id="wdDeleteId" />
</form>

@section Scripts {
    <script>
        function wdConfirmDelete(id) {
            if (window.confirm('هل أنت متأكد من حذف هذه البطاقة؟ سيتم حذف مستويات التنقيح المرتبطة بها تلقائياً.')) {
                document.getElementById('wdDeleteId').value = id;
                document.getElementById('wdDeleteForm').submit();
            }
        }
        function wdHideSkeleton() {
            var sk = document.getElementById('wdSkeleton');
            var grid = document.getElementById('wdGridWrap');
            if (sk) sk.style.display = 'none';
            if (grid) grid.style.display = 'block';
        }
        // Fallback: never let the shimmer stick if Radzen renders slowly or JS is unavailable.
        window.addEventListener('load', function () { setTimeout(wdHideSkeleton, 700); });
    </script>
}

@section Toast {
    @if (!string.IsNullOrEmpty(Model.ToastMessage))
    {
        <div class="wd-toast wd-toast--@Model.ToastType" role="status">
            <span class="wd-toast__icon">@(Model.ToastType == "success" ? "✓" : "✕")</span>
            <span class="wd-toast__msg">@Model.ToastMessage</span>
        </div>
    }
}
