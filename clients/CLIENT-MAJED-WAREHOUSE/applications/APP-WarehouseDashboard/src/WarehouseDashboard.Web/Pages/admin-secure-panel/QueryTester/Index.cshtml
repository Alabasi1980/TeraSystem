@page
@model WarehouseDashboard.Web.Pages.AdminSecurePanel.QueryTesterModel
@{
    ViewData["Title"] = "مختبِّر الاستعلامات";
}
@Html.AntiForgeryToken()

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css" />
<style>
    /* ============================================================
       Page-specific styles (including TASK-ENH-QT-002 additions)
       ============================================================ */

    /* ---- Base layout ---- */
    .wd-page { max-width: 1100px; margin: 0 auto; padding: 0; }
    .wd-page__header { margin-bottom: 24px; animation: wdFadeUp var(--dur-norm) var(--ease); }
    .wd-breadcrumb { font-size: 12px; color: var(--c-text-muted); margin-bottom: 6px; }
    .wd-breadcrumb a { color: var(--c-secondary); text-decoration: none; }
    .wd-page__title { font-size: 22px; font-weight: 700; color: var(--c-text); margin: 0; }
    .wd-page__subtitle { font-size: 14px; color: var(--c-text-muted); margin: 6px 0 0; }

    .wd-label { display: block; font-size: 13px; font-weight: 600; color: var(--c-text-muted); margin-bottom: 6px; }
    .wd-textarea, .wd-input, .wd-select {
        width: 100%; font-family: var(--font-ar);
        font-size: 14px; color: var(--c-text);
        border: 1px solid var(--c-border); border-radius: var(--radius-md);
        padding: 10px 12px; background: var(--c-surface);
        transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
    }
    .wd-textarea { min-height: 140px; resize: vertical; direction: ltr; text-align: start; font-family: "Courier New", monospace; }
    .wd-textarea:focus, .wd-input:focus, .wd-select:focus {
        outline: none; border-color: var(--c-primary);
        box-shadow: 0 0 0 3px rgba(31,78,121,0.12);
    }

    .wd-actions { display: flex; align-items: center; gap: 12px; margin-top: 12px; flex-wrap: wrap; }
    .wd-meta { font-size: 13px; color: var(--c-text-muted); }
    .wd-grid { margin-top: 8px; min-height: 80px; }

    .wd-skeleton { padding: 12px; }
    .wd-skeleton__row {
        height: 18px; margin-bottom: 12px; border-radius: 6px;
        background: linear-gradient(90deg, var(--c-surface-muted) 25%, #dbe7f3 37%, var(--c-surface-muted) 63%);
        background-size: 400% 100%;
        animation: wdShimmer 1.2s ease-in-out infinite;
    }

    .wd-toast-container {
        position: fixed; inset-inline-end: 16px; inset-block-end: 16px;
        display: flex; flex-direction: column; gap: 8px; z-index: 9999;
    }
    .wd-toast {
        min-width: 240px; max-width: 360px; padding: 12px 16px; border-radius: var(--radius-md);
        color: #fff; box-shadow: var(--shadow-md); display: flex; align-items: center; gap: 8px;
        animation: wdToastIn var(--dur-norm) var(--ease);
        font-size: 14px;
    }
    .wd-toast--success { background: var(--c-success); }
    .wd-toast--error { background: var(--c-error); }
    .wd-toast--warning { background: var(--c-warning); color: #3a2c00; }
    .wd-toast--info { background: var(--c-secondary); }
    [hidden] { display: none !important; }

    /* =============================================================
       SOURCE TABS  (TASK-ENH-QT-002)
       ============================================================= */
    .qt-source-tabs { display: flex; gap: 0; margin-bottom: 16px; border-bottom: 2px solid var(--c-border); }
    .qt-source-tab {
        padding: 8px 20px; font-family: var(--font-ar); font-size: 14px; font-weight: 600;
        cursor: pointer; border: none; background: none; color: var(--c-text-muted);
        border-bottom: 2px solid transparent; margin-bottom: -2px;
        transition: all var(--dur-fast) var(--ease); user-select: none;
    }
    .qt-source-tab:hover { color: var(--c-primary); }
    .qt-source-tab.active { color: var(--c-primary); border-bottom-color: var(--c-primary); }
    .qt-source-tab:focus-visible { outline: 2px solid var(--c-secondary); outline-offset: 2px; }
    /* =============================================================
       TWO-PANEL LAYOUT  (TASK-ENH-QT-002)
       ============================================================= */
    .qt-layout { display: flex; gap: 16px; align-items: flex-start; animation: wdFadeUp var(--dur-norm) var(--ease); }
    .qt-sidebar { width: 280px; flex-shrink: 0; background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); position: sticky; top: 16px; }
    .qt-main { flex: 1; min-width: 0; }

    .qt-sidebar-toggle {
        display: none; align-items: center; gap: 6px; padding: 8px 14px;
        font-family: var(--font-ar); font-size: 13px; font-weight: 600;
        color: var(--c-primary); background: var(--c-surface);
        border: 1px solid var(--c-border); border-radius: var(--radius-md);
        cursor: pointer; margin-bottom: 12px;
        transition: all var(--dur-fast) var(--ease);
    }
    .qt-sidebar-toggle:hover { background: var(--c-surface-muted); }

    /* =============================================================
       SCHEMA BROWSER — SIDEBAR
       ============================================================= */
    .qt-sidebar__header { padding: 12px 14px; border-bottom: 1px solid var(--c-border); background: var(--c-surface-muted); display: flex; align-items: center; justify-content: space-between; }
    .qt-sidebar__title { font-family: var(--font-ar); font-size: 14px; font-weight: 700; color: var(--c-text); }
    .qt-sidebar__refresh { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: var(--radius-sm); border: none; background: transparent; color: var(--c-text-muted); cursor: pointer; transition: all var(--dur-fast) var(--ease); }
    .qt-sidebar__refresh:hover { background: var(--c-surface); color: var(--c-primary); }

    .qt-sidebar__loading, .qt-sidebar__empty, .qt-sidebar__error { padding: 24px 14px; text-align: center; font-family: var(--font-ar); font-size: 13px; color: var(--c-text-muted); }
    .qt-sidebar__error { color: var(--c-error); }

    .qt-sidebar__tree { padding: 6px; max-height: 480px; overflow-y: auto; }

    .qt-tree-item { padding: 6px 8px; cursor: pointer; border-radius: var(--radius-sm); display: flex; align-items: center; gap: 6px; font-family: var(--font-ar); font-size: 13px; color: var(--c-text); transition: background var(--dur-fast) var(--ease); user-select: none; }
    .qt-tree-item:hover { background: var(--c-surface-muted); }
    .qt-tree-toggle { font-size: 10px; color: var(--c-text-muted); width: 14px; flex-shrink: 0; text-align: center; transition: transform var(--dur-fast) var(--ease); }
    .qt-tree-toggle--open { transform: rotate(90deg); }
    .qt-tree-icon { flex-shrink: 0; font-size: 13px; }
    .qt-tree-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .qt-tree-children { padding-inline-start: 20px; }
    .qt-tree-leaf { padding: 4px 8px; cursor: pointer; border-radius: var(--radius-sm); display: flex; align-items: center; gap: 6px; font-family: var(--font-ar); font-size: 12px; color: var(--c-text); transition: background var(--dur-fast) var(--ease); user-select: none; }
    .qt-tree-leaf:hover { background: var(--c-surface-muted); }
    .qt-leaf-icon { flex-shrink: 0; font-size: 11px; color: var(--c-secondary); }
    .qt-leaf-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .qt-leaf-type { font-size: 11px; color: var(--c-text-muted); margin-inline-start: auto; flex-shrink: 0; }
    .qt-tree-loading { padding: 12px 8px; text-align: center; font-family: var(--font-ar); font-size: 12px; color: var(--c-text-muted); }

    /* =============================================================
       SELECT BUILDER
       ============================================================= */
    .qt-select-builder { background: var(--c-surface-muted); border: 1px solid var(--c-border); border-radius: var(--radius-md); padding: 12px 16px; margin-bottom: 16px; }
    .qt-builder-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
    .qt-builder-select { flex: 1; min-width: 180px; padding: 6px 10px; border: 1px solid var(--c-border); border-radius: var(--radius-sm); font-family: var(--font-ar); font-size: 13px; color: var(--c-text); background: var(--c-surface); }
    .qt-builder-select:focus { outline: none; border-color: var(--c-primary); box-shadow: 0 0 0 3px rgba(31,78,121,0.12); }
    .qt-builder-columns { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
    .qt-builder-columns label { display: flex; align-items: center; gap: 4px; font-family: var(--font-ar); font-size: 13px; padding: 4px 8px; background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-sm); cursor: pointer; transition: border-color var(--dur-fast) var(--ease); }
    .qt-builder-columns label:hover { border-color: var(--c-primary); }
    .qt-builder-columns input[type="checkbox"] { accent-color: var(--c-primary); cursor: pointer; }
    .qt-builder-hint { font-family: var(--font-ar); font-size: 13px; color: var(--c-text-muted); padding: 4px 0; }
    .qt-builder-col-type { font-size: 11px; color: var(--c-text-muted); background: var(--c-surface-muted); padding: 1px 5px; border-radius: 3px; }

    .qt-btn--sm { padding: 5px 12px; min-height: 30px; font-family: var(--font-ar); font-size: 13px; font-weight: 600; border-radius: var(--radius-sm); cursor: pointer; transition: all var(--dur-fast) var(--ease); display: inline-flex; align-items: center; gap: 5px; border: 1px solid var(--c-border); background: var(--c-surface); color: var(--c-text); }
    .qt-btn--sm:hover { background: var(--c-surface-muted); }
    .qt-btn--primary { background: var(--c-primary); color: #fff; border-color: var(--c-primary); }
    .qt-btn--primary:hover { background: var(--c-primary-strong); }
    .qt-btn--ghost { background: transparent; color: var(--c-primary); border-color: var(--c-border); }
    .qt-btn--ghost:hover { background: var(--c-surface-muted); }
    .qt-btn--sm svg { width: 14px; height: 14px; flex-shrink: 0; }
    .qt-btn--xs { padding: 3px 10px; min-height: 24px; font-family: var(--font-ar); font-size: 12px; font-weight: 600; border-radius: var(--radius-sm); cursor: pointer; transition: all var(--dur-fast) var(--ease); display: inline-flex; align-items: center; gap: 4px; border: 1px solid var(--c-border); background: var(--c-surface); color: var(--c-text); }
    .qt-btn--xs:hover { background: var(--c-surface-muted); }

    /* =============================================================
        RESPONSIVE
       ============================================================= */
    @@media (max-width: 768px) {
        .qt-layout { flex-direction: column; }
        .qt-sidebar { width: 100%; position: static; }
        .qt-sidebar--collapsed .qt-sidebar__tree,
        .qt-sidebar--collapsed .qt-sidebar__loading,
        .qt-sidebar--collapsed .qt-sidebar__empty,
        .qt-sidebar--collapsed .qt-sidebar__error { display: none; }
        .qt-sidebar-toggle { display: inline-flex; }
        .wd-page { padding: 0 4px; }
    }

    @@keyframes qtSpin { to { transform: rotate(360deg); } }
    .qt-spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid var(--c-border); border-top-color: var(--c-primary); border-radius: 50%; animation: qtSpin 0.6s linear infinite; }

    /* ============================================================
       WHERE Builder  (TASK-ENH-QT-003)
       ============================================================ */
    .qt-where-builder { margin-bottom: 16px; }
    .qt-where-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; flex-wrap: wrap; padding: 8px 10px; background: var(--c-bg); border-radius: var(--radius-sm); }
    .qt-where-col, .qt-where-op { min-width: 110px; padding: 6px 10px; border: 1px solid var(--c-border); border-radius: var(--radius-sm); font-family: var(--font-ar); font-size: 13px; background: var(--c-surface); }
    .qt-where-val, .qt-where-val2 { min-width: 140px; padding: 6px 10px; border: 1px solid var(--c-border); border-radius: var(--radius-sm); font-size: 13px; }
    .qt-where-logic { min-width: 70px; padding: 6px 8px; border: 1px solid var(--c-border); border-radius: var(--radius-sm); font-family: var(--font-ar); font-size: 12px; }
    .qt-where-actions { display: flex; gap: 8px; margin-top: 8px; }

    /* ============================================================
       History Panel  (TASK-ENH-QT-003)
       ============================================================ */
    .qt-history-panel { position: fixed; bottom: 80px; right: 16px; width: 400px; max-height: 450px; background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); z-index: 9998; display: flex; flex-direction: column; animation: fadeInUp 0.2s var(--ease); }
    .qt-history__header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid var(--c-border); font-weight: 700; font-size: 14px; }
    .qt-history__header-actions { display: flex; align-items: center; gap: 8px; }
    .qt-history__count { font-size: 12px; color: var(--c-text-muted); background: var(--c-surface-muted); padding: 2px 8px; border-radius: var(--radius-full); }
    .qt-history__list { overflow-y: auto; flex: 1; padding: 8px; }
    .qt-history__empty { padding: 24px; text-align: center; color: var(--c-text-muted); font-size: 13px; }
    .qt-history__item { padding: 10px 12px; border-radius: var(--radius-sm); cursor: pointer; transition: background var(--dur-fast); margin-bottom: 4px; }
    .qt-history__item:hover { background: var(--c-surface-muted); }
    .qt-history__item-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
    .qt-history__time { font-size: 11px; color: var(--c-text-muted); }
    .qt-history__badge { font-size: 10px; padding: 1px 6px; border-radius: var(--radius-full); background: var(--c-primary); color: #fff; font-weight: 600; }
    .qt-history__sql { font-size: 12px; color: var(--c-text); display: block; margin-bottom: 2px; direction: ltr; text-align: start; font-family: 'Courier New', monospace; }
    .qt-history__rows { font-size: 11px; color: var(--c-text-muted); }

    /* ============================================================
       Truncated Warning  (TASK-ENH-QT-003)
       ============================================================ */
    .qt-truncated-warning { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: #FFF8E1; border: 1px solid #FFE082; border-radius: var(--radius-md); margin-bottom: 12px; font-size: 13px; color: #795548; }

    /* ============================================================
       Keyboard Hints  (TASK-ENH-QT-003)
       ============================================================ */
    kbd { display: inline-block; padding: 1px 5px; font-size: 11px; font-family: monospace; background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); border-radius: 3px; margin-inline-end: 4px; }

    /* ============================================================
       WHERE Builder + History — Responsive  (TASK-ENH-QT-003)
       ============================================================ */
    /* ============================================================
       JOIN Builder  (TASK-ENH-QT-004)
       ============================================================ */
    .qt-join-builder { margin-bottom: 16px; }
    .qt-join-clause {
        border: 1px solid var(--c-border);
        border-radius: var(--radius-md);
        padding: 12px 16px;
        margin-bottom: 12px;
        background: var(--c-surface);
        animation: wdFadeUp var(--dur-norm) var(--ease) both;
    }
    .qt-join-clause__header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
        flex-wrap: wrap;
    }
    .qt-join-clause__select {
        padding: 6px 10px;
        border: 1px solid var(--c-border);
        border-radius: var(--radius-sm);
        font-family: var(--font-ar);
        font-size: 13px;
        background: var(--c-surface);
        min-width: 130px;
    }
    .qt-join-clause__alias {
        width: 50px;
        padding: 6px 8px;
        border: 1px solid var(--c-border);
        border-radius: var(--radius-sm);
        font-family: monospace;
        font-size: 12px;
        text-align: center;
    }
    .qt-join-conditions { margin-bottom: 8px; }
    .qt-join-condition {
        display: flex; align-items: center; gap: 6px;
        margin-bottom: 6px; flex-wrap: wrap;
        padding: 6px 8px; background: var(--c-bg); border-radius: var(--radius-sm);
    }
    .qt-join-condition select {
        padding: 4px 8px; border: 1px solid var(--c-border);
        border-radius: var(--radius-sm); font-size: 12px;
        min-width: 100px; background: var(--c-surface);
    }
    .qt-join-actions { display: flex; gap: 8px; margin-top: 8px; }
    .qt-join-columns { margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--c-border); }
    .qt-join-columns__header { font-size: 13px; font-weight: 700; color: var(--c-text); margin-bottom: 8px; }
    .qt-join-columns__grid { display: flex; flex-wrap: wrap; gap: 6px; max-height: 200px; overflow-y: auto; }
    .qt-join-columns__grid label {
        display: flex; align-items: center; gap: 4px; font-size: 12px;
        padding: 4px 10px; background: var(--c-surface-muted);
        border: 1px solid var(--c-border); border-radius: var(--radius-sm);
        cursor: pointer; transition: border-color var(--dur-fast) var(--ease);
    }
    .qt-join-columns__grid label:hover { border-color: var(--c-primary); }
    .qt-join-columns__grid input[type="checkbox"] { accent-color: var(--c-primary); cursor: pointer; }
    @@media (max-width: 768px) {
        .qt-join-clause__header { flex-direction: column; align-items: stretch; }
        .qt-join-clause__select, .qt-join-clause__alias { width: 100%; }
        .qt-join-condition { flex-direction: column; align-items: stretch; }
        .qt-join-condition select { width: 100%; }
    }

    @@media (max-width: 768px) {
        .qt-where-row { flex-direction: column; align-items: stretch; }
        .qt-where-col, .qt-where-op, .qt-where-val, .qt-where-val2 { width: 100%; min-width: 0; }
        .qt-history-panel { width: calc(100% - 32px); right: 16px; bottom: 80px; max-height: 60vh; }
    }

    /* CodeMirror override for dashboard theme */
    .CodeMirror {
        height: auto;
        min-height: 140px;
        border: 1px solid var(--c-border);
        border-radius: var(--radius-md);
        font-size: 14px;
        direction: ltr;
        font-family: 'Courier New', Consolas, monospace;
        transition: border-color var(--dur-fast) var(--ease);
    }
    .CodeMirror-focused {
        border-color: var(--c-primary);
        box-shadow: 0 0 0 3px rgba(31,78,121,0.12);
        outline: none;
    }
    .CodeMirror-gutters {
        background: var(--c-surface-muted);
        border-right: 1px solid var(--c-border);
        border-radius: var(--radius-md) 0 0 var(--radius-md);
    }
    .CodeMirror-linenumber {
        color: var(--c-text-muted);
        font-size: 12px;
        padding: 0 6px 0 10px;
    }
    .CodeMirror-placeholder {
        color: var(--c-text-muted) !important;
        opacity: 0.6;
    }

    /* ===== Searchable Dropdown (TASK-ENH-QT-006) ===== */
    .qt-searchable {
      position: relative;
      min-width: 120px;
      font-size: 13px;
      flex: 1;
    }
    .qt-searchable__input-wrapper {
      display: flex;
      align-items: center;
      border: 1px solid var(--c-border);
      border-radius: var(--radius-sm);
      background: var(--c-surface);
      transition: border-color var(--dur-fast) var(--ease);
    }
    .qt-searchable__input-wrapper:focus-within {
      border-color: var(--c-primary);
      box-shadow: 0 0 0 3px rgba(31,78,121,0.12);
    }
    .qt-searchable__input {
      flex: 1;
      border: none; outline: none;
      padding: 6px 10px;
      font-family: var(--font-ar);
      font-size: 13px;
      background: transparent;
      color: var(--c-text);
      min-width: 0;
    }
    .qt-searchable__arrow {
      padding: 0 8px;
      color: var(--c-text-muted);
      font-size: 10px;
      cursor: pointer;
      user-select: none;
    }
    .qt-searchable__dropdown {
      position: absolute;
      top: 100%; left: 0; right: 0;
      z-index: 1000;
      max-height: 220px;
      overflow-y: auto;
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-sm);
      box-shadow: var(--shadow-md);
      margin-top: 2px;
    }
    .qt-searchable__option {
      padding: 6px 10px;
      cursor: pointer;
      font-size: 13px;
      color: var(--c-text);
      transition: background var(--dur-fast);
    }
    .qt-searchable__option:hover,
    .qt-searchable__option.highlighted {
      background: var(--c-surface-muted);
    }
    .qt-searchable__option.selected {
      background: rgba(31,78,121,0.1);
      font-weight: 600;
    }
    .qt-searchable__no-results {
      color: var(--c-text-muted);
      font-style: italic;
      cursor: default;
      padding: 8px 10px;
    }
    .qt-searchable__option-type {
      color: var(--c-text-muted);
      font-size: 11px;
      margin-left: 8px;
    }

    /* ===== Sortable Column List (TASK-ENH-QT-007) ===== */
    .qt-sortable-list {
      display: flex;
      flex-direction: column;
      gap: 4px;
      max-height: 280px;
      overflow-y: auto;
      padding: 2px;
    }
    .qt-sortable-item {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 5px 8px;
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-sm);
      transition: background var(--dur-fast), border-color var(--dur-fast);
      font-size: 13px;
    }
    .qt-sortable-item:hover {
      background: var(--c-surface-muted);
      border-color: var(--c-secondary);
    }
    .qt-sortable-handle {
      color: var(--c-text-muted);
      cursor: grab;
      font-size: 14px;
      user-select: none;
      opacity: 0.5;
    }
    .qt-sortable-item:hover .qt-sortable-handle { opacity: 1; }
    .qt-sortable-checkbox { margin: 0; cursor: pointer; }
    .qt-sortable-label { flex: 1; color: var(--c-text); font-weight: 500; }
    .qt-sortable-type { color: var(--c-text-muted); font-size: 11px; margin: 0 6px; }
    .qt-sortable-btn {
      width: 24px; height: 24px; border: none;
      background: transparent; color: var(--c-text-muted);
      cursor: pointer; border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px;
      transition: background var(--dur-fast), color var(--dur-fast);
    }
    .qt-sortable-btn:hover { background: var(--c-surface-muted); color: var(--c-primary); }
    .qt-sortable-btn:disabled { opacity: 0.2; cursor: default; }
    .qt-sortable-btn:disabled:hover { background: transparent; color: var(--c-text-muted); }
</style>
