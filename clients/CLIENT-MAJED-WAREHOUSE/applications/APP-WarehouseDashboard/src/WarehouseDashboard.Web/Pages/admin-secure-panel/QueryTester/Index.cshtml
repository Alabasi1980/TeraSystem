<div id="toastContainer" class="wd-toast-container"></div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/sql/sql.min.js"></script>
<script>
    // ================================================================
    // EXISTING FUNCTIONS (preserved from original)
    // ================================================================

    let currentColumns = [];
    let currentRows = [];
    let sortColumn = null;
    let sortAsc = true;

    // Initialize CodeMirror editor
    var editor = CodeMirror(document.getElementById('editor'), {
        value: 'SELECT 1 AS [عيّنة]',
        mode: 'text/x-mssql',
        lineNumbers: true,
        indentWithTabs: false,
        smartIndent: true,
        tabSize: 2,
        lineWrapping: true,
        extraKeys: {
            'Ctrl-Enter': function() { runQuery(); },
            'Ctrl-Shift-C': function() { clearEditor(); }
        }
    });

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text ?? '';
        return div.innerHTML;
    }

    function showToast(message, type) {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        toast.className = 'wd-toast wd-toast--' + (type || 'info');
        const icon = type === 'success' ? '\u2713' : type === 'error' ? '\u2715' : type === 'warning' ? '\u26A0' : '\u2139';
        toast.innerHTML = '<span>' + icon + '</span><span>' + escapeHtml(message) + '</span>';
        container.appendChild(toast);
        setTimeout(function () {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(8px)';
            setTimeout(function () { toast.remove(); }, 240);
        }, 3500);
    }

    function setRunning(running) {
        document.getElementById('runBtn').disabled = running;
        document.getElementById('runBtn').textContent = running ? '\u062C\u0627\u0631\u064D \u0627\u0644\u062A\u0646\u0641\u064A\u0630...' : '\u062A\u0634\u063A\u064A\u0644';
    }

    function showSkeleton(show) {
        document.getElementById('skeleton').hidden = !show;
        if (show) { document.getElementById('emptyState').hidden = true; destroyGrid(); }
    }

    function destroyGrid() {
        currentColumns = [];
        currentRows = [];
        document.getElementById('gridContainer').innerHTML = '';
    }

    function mapType(clrType) {
        switch ((clrType || '').toLowerCase()) {
            case 'int32': case 'int64': case 'int16': case 'decimal':
            case 'double': case 'single': case 'byte': case 'sbyte':
                return 'number';
            case 'datetime': case 'datetimeoffset': case 'timespan':
                return 'datetime';
            case 'boolean':
                return 'boolean';
            default:
                return 'string';
        }
    }

    function formatCell(val, dataType) {
        if (val == null) return '<span style="color:var(--c-text-muted)">\u2014</span>';
        var type = mapType(dataType);
        if (type === 'number') return '<span style="text-align:right;direction:ltr;display:block">' + Number(val).toLocaleString('en-US') + '</span>';
        if (type === 'datetime') return '<span style="direction:ltr;display:block">' + new Date(val).toLocaleString('ar-SA') + '</span>';
        return escapeHtml(String(val));
    }

    function sortBy(colName) {
        if (sortColumn === colName) { sortAsc = !sortAsc; }
        else { sortColumn = colName; sortAsc = true; }
        var sorted = [...currentRows].sort(function(a, b) {
            var va = a[colName], vb = b[colName];
            if (va == null) return 1; if (vb == null) return -1;
            if (typeof va === 'number' && typeof vb === 'number') return sortAsc ? va - vb : vb - va;
            return sortAsc ? String(va).localeCompare(String(vb)) : String(vb).localeCompare(String(va));
        });
        renderGrid(currentColumns, sorted);
    }

    function renderGrid(columns, rows) {
        destroyGrid();
        const container = document.getElementById('gridContainer');
        document.getElementById('emptyState').hidden = true;

        if (!columns || columns.length === 0) {
            container.innerHTML = '<div class="wd-empty"><span class="wd-empty__icon">\u25A6</span>\u0644\u0627 \u062A\u0648\u062C\u062F \u0623\u0639\u0645\u062F\u0629 \u0641\u064A \u0627\u0644\u0646\u062A\u064A\u062C\u0629.</div>';
            document.getElementById('copyBtn').disabled = true;
            document.getElementById('csvBtn').disabled = true;
            return;
        }

        currentColumns = columns;
        currentRows = rows;

        var html = '<table class="wd-table" style="width:100%;border-collapse:collapse;font-size:13px;">';
        html += '<thead><tr>';
        columns.forEach(function(c) {
            var align = mapType(c.dataType) === 'number' ? 'right' : 'left';
            var arrow = '';
            if (sortColumn === c.name) arrow = sortAsc ? ' \u25B2' : ' \u25BC';
            html += '<th style="padding:8px 12px;background:var(--c-surface-muted);font-weight:600;text-align:' + align + ';border-bottom:1px solid var(--c-border);white-space:nowrap;cursor:pointer;-webkit-user-select:none;user-select:none;" onclick="sortBy(\'' + escapeHtml(c.name) + '\')">' + escapeHtml(c.name) + arrow + '</th>';
        });
        html += '</tr></thead><tbody>';
        rows.forEach(function(r, idx) {
            html += '<tr style="border-bottom:1px solid var(--c-border);' + (idx % 2 === 0 ? '' : 'background:#F7FAFD;') + '">';
            columns.forEach(function(c) {
                html += '<td style="padding:6px 12px;">' + formatCell(r[c.name], c.dataType) + '</td>';
            });
            html += '</tr>';
        });
        html += '</tbody></table>';
        container.innerHTML = html;
        document.getElementById('copyBtn').disabled = false;
        document.getElementById('csvBtn').disabled = false;
    }
    function copyResults() {
        if (!currentRows || currentRows.length === 0) return;
        var cols = currentColumns;
        var csv = cols.map(function(c) { return '"' + (c.name || '') + '"'; }).join(',') + '\n';
        currentRows.forEach(function(row) {
            csv += cols.map(function(c) {
                var val = row[c.name];
                return val != null ? '"' + String(val).replace(/"/g, '""') + '"' : '""';
            }).join(',') + '\n';
        });
        navigator.clipboard.writeText(csv).then(function() {
            showToast('\u062A\u0645 \u0646\u0633\u062E ' + currentRows.length + ' \u0635\u0641 \u0625\u0644\u0649 \u0627\u0644\u062D\u0627\u0641\u0638\u0629.', 'success');
        }).catch(function() {
            showToast('\u062A\u0639\u0630\u0631 \u0627\u0644\u0646\u0633\u062E \u0625\u0644\u0649 \u0627\u0644\u062D\u0627\u0641\u0638\u0629.', 'error');
        });
    }

    async function runQuery() {
        var sql = editor.getValue();
        if (!sql.trim()) {
            showToast('\u0627\u0644\u0631\u062C\u0627\u0621 \u0625\u062F\u062E\u0627\u0644 \u0627\u0633\u062A\u0639\u0644\u0627\u0645 SQL.', 'warning');
            return;
        }

        setRunning(true);
        showSkeleton(true);
        document.getElementById('meta').textContent = '';

        try {
            const token = document.querySelector('input[name=__RequestVerificationToken]').value;
            const resp = await fetch('?handler=Run', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({
                    sql: sql,
                    source: currentSource
                })
            });
            const data = await resp.json();
            document.getElementById('skeleton').hidden = true;
            setRunning(false);

            if (!data.success) {
                document.getElementById('emptyState').hidden = false;
                document.getElementById('emptyState').innerHTML =
                    '<span class="wd-empty__icon">\u26A0</span>' + escapeHtml(data.errorMessage || '\u0641\u0634\u0644 \u062A\u0646\u0641\u064A\u0630 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645.');
                document.getElementById('copyBtn').disabled = true;
                showToast(data.errorMessage || '\u0641\u0634\u0644 \u062A\u0646\u0641\u064A\u0630 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645.', 'error');
                return;
            }

            renderGrid(data.columns, data.rows);
            document.getElementById('meta').textContent =
                '\u0627\u0644\u0646\u062A\u0627\u0626\u062C: ' + data.rowCount + ' \u0635\u0641 \u00B7 \u0627\u0644\u0632\u0645\u0646: ' + data.elapsedMilliseconds + ' \u0645\u0644\u064A \u062B\u0627\u0646\u064A\u0629';

            if (data.truncated) {
                document.getElementById('truncatedWarning').hidden = false;
                showToast('\u269A \u062A\u0645 \u0639\u0631\u0636 \u0623\u0648\u0644 1000 \u0635\u0641 \u0641\u0642\u0637. \u0627\u0633\u062A\u062E\u062F\u0645 WHERE \u0644\u062A\u0636\u064A\u064A\u0642 \u0627\u0644\u0646\u062A\u0627\u0626\u062C.', 'warning');
            } else {
                document.getElementById('truncatedWarning').hidden = true;
            }

            if (data.rowCount === 0) {
                document.getElementById('gridContainer').innerHTML =
                    '<div class="wd-empty"><span class="wd-empty__icon">\u2713</span>\u062A\u0645 \u062A\u0646\u0641\u064A\u0630 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645 \u0628\u0646\u062C\u0627\u062D \u0644\u0643\u0646 \u0644\u0645 \u064A\u0631\u062C\u0639 \u0623\u064A \u0635\u0641\u0648\u0641.</div>';
                document.getElementById('copyBtn').disabled = true;
                document.getElementById('csvBtn').disabled = true;
            }

            saveToHistory(sql, currentSource, data.rowCount);
            showToast('\u062A\u0645 \u062A\u0646\u0641\u064A\u0630 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645 \u0628\u0646\u062C\u0627\u062D.', 'success');
        } catch (err) {
            document.getElementById('skeleton').hidden = true;
            document.getElementById('emptyState').hidden = false;
            document.getElementById('copyBtn').disabled = true;
            setRunning(false);
            showToast('\u062A\u0639\u0630\u0631 \u0627\u0644\u0627\u062A\u0635\u0627\u0644 \u0628\u0627\u0644\u062E\u0627\u062F\u0645.', 'error');
        }
    }

    function clearEditor() {
        editor.setValue('');
        destroyGrid();
        document.getElementById('emptyState').hidden = false;
        document.getElementById('copyBtn').disabled = true;
        document.getElementById('csvBtn').disabled = true;
        document.getElementById('meta').textContent = '';
        document.getElementById('truncatedWarning').hidden = true;
    }

    // ================================================================
    // NEW FUNCTIONS — Schema Browser & SELECT Builder (TASK-ENH-QT-002)
    // ================================================================

    let currentSource = 'SqlServer';
    // ---- Source Tab switching ----
    function switchSource(source) {
        if (source === currentSource) return;

        document.querySelectorAll('.qt-source-tab').forEach(function(tab) {
            var isActive = tab.dataset.source === source;
            tab.classList.toggle('active', isActive);
            tab.setAttribute('aria-selected', isActive);
        });

        currentSource = source;
        loadTables();

        var builderWrap = document.getElementById('builderTableWrapper');
        if (builderWrap) {
            var tblOpts = getTableOptions();
            createSearchableDropdown(builderWrap, tblOpts, function() { loadBuilderColumns(); });
        }
        document.getElementById('builderColumns').innerHTML = '<span class="qt-builder-hint">\u0627\u062E\u062A\u0631 \u062C\u062F\u0648\u0644\u0627\u064B \u0644\u0627\u062E\u062A\u064A\u0627\u0631 \u0627\u0644\u0623\u0639\u0645\u062F\u0629.</span>';

        // Reset JOIN Builder state
        document.getElementById('joinClauses').innerHTML = '';
        document.getElementById('joinColumns').hidden = true;
    }

    // ---- Sidebar toggle (mobile) ----
    function toggleSidebar() {
        var sidebar = document.getElementById('schemaSidebar');
        sidebar.classList.toggle('qt-sidebar--collapsed');
    }

    // ---- Load tables into schema tree ----
    function loadTables() {
        var tree = document.getElementById('schemaTree');
        var loading = document.getElementById('schemaLoading');
        var emptyEl = document.getElementById('schemaEmpty');
        var errorEl = document.getElementById('schemaError');

        loading.hidden = false;
        tree.innerHTML = '';
        emptyEl.hidden = true;
        errorEl.hidden = true;

        fetch('?handler=Tables&source=' + encodeURIComponent(currentSource))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                loading.hidden = true;

                if (!data.success) {
                    errorEl.hidden = false;
                    errorEl.textContent = data.errorMessage || '\u062A\u0639\u0630\u0631 \u062A\u062D\u0645\u064A\u0644 \u0627\u0644\u062C\u062F\u0627\u0648\u0644.';
                    return;
                }

                var tables = data.tables || [];
                if (tables.length === 0) {
                    emptyEl.hidden = false;
                    return;
                }

                var html = '';
                tables.forEach(function(t) {
                    var label = t.schema ? t.schema + '.' + t.tableName : t.tableName;
                    html += '<div class="qt-tree-item" data-table="' + encodeURIComponent(t.tableName) + '" data-schema="' + (t.schema || '') + '">';
                    html += '  <span class="qt-tree-toggle">\u25B6</span>';
                    html += '  <span class="qt-tree-icon">\uD83D\uDCCB</span>';
                    html += '  <span class="qt-tree-label" title="' + escapeHtml(label) + '">' + escapeHtml(label) + '</span>';
                    html += '</div>';
                });
                tree.innerHTML = html;

                tree.querySelectorAll('.qt-tree-item').forEach(function(item) {
                    item.addEventListener('click', function(e) {
                        e.stopPropagation();
                        toggleTableTree(this);
                    });
                });

                populateBuilderDropdown(tables);
                window.currentTables = tables;
                populateJoinTableDropdowns();
            })
            .catch(function(err) {
                loading.hidden = true;
                errorEl.hidden = false;
            });
    }

    // ---- Toggle table expand in schema tree ----
    function toggleTableTree(el) {
        var tableName = decodeURIComponent(el.dataset.table);
        var child = el.nextElementSibling;

        if (child && child.classList.contains('qt-tree-children')) {
            child.remove();
            el.querySelector('.qt-tree-toggle').textContent = '\u25B6';
            el.querySelector('.qt-tree-toggle').classList.remove('qt-tree-toggle--open');
            return;
        }

        el.querySelector('.qt-tree-toggle').textContent = '\u25BC';
        el.querySelector('.qt-tree-toggle').classList.add('qt-tree-toggle--open');

        var childrenDiv = document.createElement('div');
        childrenDiv.className = 'qt-tree-children';
        childrenDiv.innerHTML = '<div class="qt-tree-loading">\u062C\u0627\u0631\u064D \u062A\u062D\u0645\u064A\u0644 \u0627\u0644\u0623\u0639\u0645\u062F\u0629...</div>';
        el.after(childrenDiv);

        fetch('?handler=Columns&source=' + encodeURIComponent(currentSource) + '&table=' + encodeURIComponent(tableName))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.success) {
                    childrenDiv.innerHTML = '<div class="qt-tree-loading" style="color:var(--c-error);">\u062A\u0639\u0630\u0631 \u062A\u062D\u0645\u064A\u0644 \u0627\u0644\u0623\u0639\u0645\u062F\u0629.</div>';
                    return;
                }
                var cols = data.columns || [];
                if (cols.length === 0) {
                    childrenDiv.innerHTML = '<div class="qt-tree-loading">\u0644\u0627 \u062A\u0648\u062C\u062F \u0623\u0639\u0645\u062F\u0629.</div>';
                    return;
                }
                var colHtml = '';
                cols.forEach(function(c) {
                    var safeName = c.name.replace(/'/g, "\\'");
                    colHtml += '<div class="qt-tree-leaf" onclick="addColumnToBuilder(\'' + safeName + '\')">';
                    colHtml += '  <span class="qt-leaf-icon">\uD83D\uDD39</span>';
                    colHtml += '  <span class="qt-leaf-name">' + escapeHtml(c.name) + '</span>';
                    colHtml += '  <span class="qt-leaf-type">' + escapeHtml(c.dataType || '') + '</span>';
                    colHtml += '</div>';
                });
                childrenDiv.innerHTML = colHtml;
            })
            .catch(function(err) {
                childrenDiv.innerHTML = '<div class="qt-tree-loading" style="color:var(--c-error);">\u062A\u0639\u0630\u0631 \u0627\u0644\u0627\u062A\u0635\u0627\u0644.</div>';
            });
    }

    // ---- Populate builder table dropdown ----
    function populateBuilderDropdown(tables) {
        var wrap = document.getElementById('builderTableWrapper');
        if (!wrap) return;
        var options = (tables || window.currentTables || []).map(function(t) {
            var label = t.schema ? t.schema + '.' + t.tableName : t.tableName;
            return { value: t.tableName, label: label, type: t.schema };
        });
        createSearchableDropdown(wrap, options, function() { loadBuilderColumns(); });
    }
    // ---- Load columns into SELECT builder sortable list ----
    function loadBuilderColumns() {
        var tableName = document.getElementById('builderTableWrapper').getValue();
        var container = document.getElementById('builderColumns');

        if (!tableName) {
            container.innerHTML = '<span class="qt-builder-hint">\u0627\u062E\u062A\u0631 \u062C\u062F\u0648\u0644\u0627\u064B \u0644\u0627\u062E\u062A\u064A\u0627\u0631 \u0627\u0644\u0623\u0639\u0645\u062F\u0629.</span>';
            return;
        }

        function renderCols() {
            if (!joinColumnCache[tableName]) {
                container.innerHTML = '<span class="qt-builder-hint"><span class="qt-spinner"></span> \u062C\u0627\u0631\u064D \u0627\u0644\u062A\u062D\u0645\u064A\u0644...</span>';
                fetchAndCacheColumns(tableName, function() { renderCols(); });
                return;
            }

            var cols = joinColumnCache[tableName].map(function(col) {
                return { value: col.name, label: col.name, type: col.dataType, checked: true };
            });

            container.innerHTML = '';
            if (cols.length === 0) {
                container.innerHTML = '<span class="qt-builder-hint">\u0644\u0627 \u062A\u0648\u062C\u062F \u0623\u0639\u0645\u062F\u0629 \u0641\u064A \u0647\u0630\u0627 \u0627\u0644\u062C\u062F\u0648\u0644.</span>';
                return;
            }
            createSortableList(container, cols);
        }

        renderCols();
    }

    // ---- Add column from tree leaf to builder ----
    function addColumnToBuilder(columnName) {
        var builderWrap = document.getElementById('builderTableWrapper');
        var builderTable = builderWrap ? builderWrap.getValue() : '';
        if (!builderTable) {
            showToast('\u0627\u062E\u062A\u0631 \u062C\u062F\u0648\u0644\u0627\u064B \u0623\u0648\u0644\u0627\u064B \u0641\u064A \u0645\u0646\u062A\u062C SELECT \u0627\u0644\u0623\u0639\u0645\u062F\u0629.', 'warning');
            return;
        }

        var container = document.getElementById('builderColumns');
        var list = container.querySelector('.qt-sortable-list');
        if (list && list.setChecked) {
            list.setChecked(columnName, true);
            showToast('\u062A\u0645 \u062A\u062D\u062F\u064A\u062F \u0627\u0644\u0639\u0645\u0648\u062F "' + columnName + '".', 'info');
        } else {
            showToast('\u064A\u0631\u062C\u0649 \u062A\u062D\u0645\u064A\u0644 \u0623\u0639\u0645\u062F\u0629 \u0627\u0644\u062C\u062F\u0648\u0644 \u0623\u0648\u0644\u0627\u064B.', 'warning');
        }
    }

    // ---- Select all builder columns ----
    function selectAllBuilderColumns() {
        var list = document.querySelector('#builderColumns .qt-sortable-list');
        if (list && list.selectAll) list.selectAll(true);
    }

    // ---- Deselect all builder columns ----
    function deselectAllBuilderColumns() {
        var list = document.querySelector('#builderColumns .qt-sortable-list');
        if (list && list.selectAll) list.selectAll(false);
    }

    // ---- Generate SELECT statement ----
    function generateSelect() {
        var tableName = document.getElementById('builderTableWrapper').getValue();
        if (!tableName) {
            showToast('\u0627\u062E\u062A\u0631 \u062C\u062F\u0648\u0644\u0627\u064B \u0623\u0648\u0644\u0627\u064B.', 'warning');
            return;
        }

        var list = document.querySelector('#builderColumns .qt-sortable-list');
        var selectedCols = list ? list.getSelected() : [];

        if (selectedCols.length === 0) {
            showToast('\u0627\u0644\u0631\u062C\u0627\u0621 \u0627\u062E\u062A\u064A\u0627\u0631 \u0639\u0645\u0648\u062F \u0648\u0627\u062D\u062F \u0639\u0644\u0649 \u0627\u0644\u0623\u0642\u0644.', 'warning');
            return;
        }

        var sql = 'SELECT\n  ' + selectedCols.join(',\n  ') + '\nFROM ' + tableName;

        editor.setValue(sql);
        showToast('\u062A\u0645 \u0625\u0646\u0634\u0627\u0621 \u0627\u0633\u062A\u0639\u0644\u0627\u0645 SELECT.', 'success');
    }

    // ================================================================
    // WHERE Builder Functions  (TASK-ENH-QT-003)
    // ================================================================

    // ---- Add a new WHERE condition row ----
    function addWhereRow() {
        var container = document.getElementById('whereConditions');
        var row = document.createElement('div');
        row.className = 'qt-where-row';

        var builderWrap = document.getElementById('builderTableWrapper');
        var tableName = builderWrap ? builderWrap.getValue() : '';
        var cols = [];

        // Collect column names from builderColumns sortable list if available
        var builderList = document.querySelector('#builderColumns .qt-sortable-list');
        if (builderList && builderList.getItems) {
            builderList.getItems().forEach(function(item) {
                cols.push(item.value);
            });
        }

        var colSelect = '<select class="qt-where-col">';
        if (cols.length === 0) {
            colSelect += '<option value="">-- لا توجد أعمدة --</option>';
        } else {
            colSelect += '<option value="">-- العمود --</option>';
            cols.forEach(function(col) {
                colSelect += '<option value="' + escapeHtml(col) + '">' + escapeHtml(col) + '</option>';
            });
        }
        colSelect += '</select>';

        var opSelect = '<select class="qt-where-op" onchange="onWhereOpChange(this)">';
        var ops = ['=', '>', '<', '>=', '<=', '<>', 'LIKE', 'NOT LIKE', 'IS NULL', 'IS NOT NULL', 'IN', 'BETWEEN'];
        ops.forEach(function(op) {
            opSelect += '<option value="' + op + '">' + op + '</option>';
        });
        opSelect += '</select>';

        row.innerHTML = colSelect
            + opSelect
            + '<input class="qt-where-val" placeholder="\u0627\u0644\u0642\u064A\u0645\u0629" />'
            + '<input class="qt-where-val2" placeholder="\u0627\u0644\u0642\u064A\u0645\u0629 \u0627\u0644\u062B\u0627\u0646\u064A\u0629" hidden />'
            + '<select class="qt-where-logic"><option>AND</option><option>OR</option></select>'
            + '<button class="qt-btn qt-btn--ghost qt-btn--sm" onclick="removeWhereRow(this)" type="button">\u2715</button>';

        container.appendChild(row);
    }

    // ---- Handle operator change (show/hide value inputs) ----
    function onWhereOpChange(select) {
        var row = select.closest('.qt-where-row');
        var valInput = row.querySelector('.qt-where-val');
        var val2Input = row.querySelector('.qt-where-val2');
        var op = select.value;

        if (op === 'IS NULL' || op === 'IS NOT NULL') {
            valInput.hidden = true;
            val2Input.hidden = true;
        } else if (op === 'BETWEEN') {
            valInput.hidden = false;
            val2Input.hidden = false;
            valInput.placeholder = '\u0627\u0644\u0642\u064A\u0645\u0629 \u0627\u0644\u0623\u0648\u0644\u0649';
            val2Input.placeholder = '\u0627\u0644\u0642\u064A\u0645\u0629 \u0627\u0644\u062B\u0627\u0646\u064A\u0629';
        } else if (op === 'IN') {
            valInput.hidden = false;
            val2Input.hidden = true;
            valInput.placeholder = '(val1, val2, ...)';
        } else {
            valInput.hidden = false;
            val2Input.hidden = true;
            valInput.placeholder = '\u0627\u0644\u0642\u064A\u0645\u0629';
        }
    }

    // ---- Remove a WHERE condition row ----
    function removeWhereRow(btn) {
        var row = btn.closest('.qt-where-row');
        row.remove();
    }

    // ---- Apply WHERE conditions to the SQL query ----
    function applyWhere() {
        var rows = document.querySelectorAll('#whereConditions .qt-where-row');
        if (rows.length === 0) {
            showToast('\u0623\u0636\u0641 \u0634\u0631\u0637\u0627\u064B \u0648\u0627\u062D\u062F\u0627\u064B \u0639\u0644\u0649 \u0627\u0644\u0623\u0642\u0644.', 'warning');
            return;
        }

        var conditions = [];
        var valid = true;

        rows.forEach(function(row, index) {
            var col = row.querySelector('.qt-where-col').value;
            var op = row.querySelector('.qt-where-op').value;
            var val = row.querySelector('.qt-where-val').value.trim();
            var val2 = row.querySelector('.qt-where-val2') ? row.querySelector('.qt-where-val2').value.trim() : '';
            var logicEl = row.querySelector('.qt-where-logic');
            var logic = '';

            if (index > 0 && logicEl) {
                logic = ' ' + logicEl.value + ' ';
            }

            if (!col) {
                showToast('\u0627\u062E\u062A\u0631 \u0639\u0645\u0648\u062F\u0627\u064B \u0644\u0644\u0634\u0631\u0637 \u0631\u0642\u0645 ' + (index + 1) + '.', 'warning');
                valid = false;
                return;
            }

            if (op === 'IS NULL' || op === 'IS NOT NULL') {
                conditions.push(logic + col + ' ' + op);
            } else if (op === 'BETWEEN') {
                if (!val || !val2) {
                    showToast('\u0623\u062F\u062E\u0644 \u0642\u064A\u0645\u062A\u064A\u0646 \u0644\u0644\u0634\u0631\u0637 BETWEEN \u0631\u0642\u0645 ' + (index + 1) + '.', 'warning');
                    valid = false;
                    return;
                }
                conditions.push(logic + col + ' BETWEEN ' + val + ' AND ' + val2);
            } else if (op === 'IN') {
                if (!val) {
                    showToast('\u0623\u062F\u062E\u0644 \u0642\u064A\u0645\u0627\u064B \u0644\u0644\u0634\u0631\u0637 IN \u0631\u0642\u0645 ' + (index + 1) + '.', 'warning');
                    valid = false;
                    return;
                }
                conditions.push(logic + col + ' IN (' + val + ')');
            } else if (op === 'LIKE' || op === 'NOT LIKE') {
                if (!val) {
                    showToast('\u0623\u062F\u062E\u0644 \u0642\u064A\u0645\u0629 \u0644\u0644\u0634\u0631\u0637 ' + op + ' \u0631\u0642\u0645 ' + (index + 1) + '.', 'warning');
                    valid = false;
                    return;
                }
                conditions.push(logic + col + ' ' + op + ' ' + val);
            } else {
                if (!val) {
                    showToast('\u0623\u062F\u062E\u0644 \u0642\u064A\u0645\u0629 \u0644\u0644\u0634\u0631\u0637 \u0631\u0642\u0645 ' + (index + 1) + '.', 'warning');
                    valid = false;
                    return;
                }
                conditions.push(logic + col + ' ' + op + ' ' + val);
            }
        });

        if (!valid) return;

        var whereClause = 'WHERE ' + conditions.join('').trim();
        var currentSql = editor.getValue().trim();

        // Remove existing WHERE clause if present
        var whereIndex = currentSql.toUpperCase().lastIndexOf('WHERE');
        if (whereIndex >= 0) {
            currentSql = currentSql.substring(0, whereIndex).trim();
        }

        editor.setValue(currentSql + '\n' + whereClause);
        showToast('\u062A\u0645 \u062A\u0637\u0628\u064A\u0642 WHERE \u0639\u0644\u0649 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645.', 'success');
    }

    // ================================================================
    // CSV Download  (TASK-ENH-QT-003)
    // ================================================================

    function downloadCSV() {
        if (!currentRows || currentRows.length === 0) return;
        var cols = currentColumns;
        var csv = '\uFEFF'; // BOM for Arabic Excel
        csv += cols.map(function(c) { return '"' + (c.name || '') + '"'; }).join(',') + '\n';
        currentRows.forEach(function(row) {
            csv += cols.map(function(c) {
                var val = row[c.name];
                return val != null ? '"' + String(val).replace(/"/g, '""') + '"' : '""';
            }).join(',') + '\n';
        });
        var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        var link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'query_results_' + new Date().toISOString().slice(0, 10) + '.csv';
        link.click();
        URL.revokeObjectURL(link.href);
        showToast('\u062A\u0645 \u062A\u0646\u0632\u064A\u0644 ' + currentRows.length + ' \u0635\u0641.', 'success');
    }

    // ================================================================
    // Query History  (TASK-ENH-QT-003)
    // ================================================================

    function saveToHistory(sql, source, rowCount) {
        var history = JSON.parse(localStorage.getItem('qtHistory') || '[]');
        history.unshift({ sql: sql, source: source, rowCount: rowCount, timestamp: new Date().toISOString() });
        if (history.length > 50) history = history.slice(0, 50);
        localStorage.setItem('qtHistory', JSON.stringify(history));
    }

    function toggleHistory() {
        var panel = document.getElementById('historyPanel');
        panel.hidden = !panel.hidden;
        if (!panel.hidden) loadHistory();
    }

    function loadHistory() {
        var list = document.getElementById('historyList');
        var count = document.getElementById('historyCount');
        var history = JSON.parse(localStorage.getItem('qtHistory') || '[]');
        count.textContent = history.length;
        if (history.length === 0) {
            list.innerHTML = '<div class="qt-history__empty">\u0644\u0627 \u062A\u0648\u062C\u062F \u0627\u0633\u062A\u0639\u0644\u0627\u0645\u0627\u062A \u0633\u0627\u0628\u0642\u0629.</div>';
            return;
        }
        list.innerHTML = history.map(function(h, i) {
            return '<div class="qt-history__item" onclick="restoreHistory(' + i + ')">'
                + '<div class="qt-history__item-top">'
                + '<span class="qt-history__time">' + new Date(h.timestamp).toLocaleString('ar-SA') + '</span>'
                + '<span class="qt-history__badge">' + escapeHtml(h.source) + '</span>'
                + '</div>'
                + '<code class="qt-history__sql">' + escapeHtml(h.sql.substring(0, 100)) + (h.sql.length > 100 ? '...' : '') + '</code>'
                + '<span class="qt-history__rows">' + (h.rowCount != null ? h.rowCount + ' \u0635\u0641' : '') + '</span>'
                + '</div>';
        }).join('');
    }

    function restoreHistory(index) {
        var history = JSON.parse(localStorage.getItem('qtHistory') || '[]');
        if (history[index]) {
            editor.setValue(history[index].sql);
            if (history[index].source) switchSource(history[index].source);
            toggleHistory();
            showToast('\u062A\u0645 \u0627\u0633\u062A\u0639\u0627\u062F\u0629 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645.', 'info');
        }
    }

    function clearHistory() {
        localStorage.removeItem('qtHistory');
        loadHistory();
        showToast('\u062A\u0645 \u0645\u0633\u062D \u0633\u062C\u0644 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645\u0627\u062A.', 'info');
    }

    // ================================================================
    // Keyboard Shortcuts  (TASK-ENH-QT-003)
