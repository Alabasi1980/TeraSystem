    // ================================================================
    // Searchable Dropdown + Helpers  (TASK-ENH-QT-006)
    // ================================================================

    // ---- Create a searchable dropdown (combobox) ----
    function createSearchableDropdown(container, options, onSelect) {
      container.innerHTML = '';
      container.className = 'qt-searchable';
      container.dataset.value = '';

      var wrapper = document.createElement('div');
      wrapper.className = 'qt-searchable__input-wrapper';

      var input = document.createElement('input');
      input.className = 'qt-searchable__input';
      input.type = 'text';
      input.placeholder = '\u0627\u0628\u062D\u062B...';
      input.autocomplete = 'off';

      var arrow = document.createElement('span');
      arrow.className = 'qt-searchable__arrow';
      arrow.textContent = '\u25BC';

      wrapper.appendChild(input);
      wrapper.appendChild(arrow);

      var dropdown = document.createElement('div');
      dropdown.className = 'qt-searchable__dropdown';
      dropdown.hidden = true;

      container.appendChild(wrapper);
      container.appendChild(dropdown);

      var selectedValue = '';
      var highlightedIndex = -1;
      var filteredOptions = [];

      function renderDropdown() {
        var query = input.value.toLowerCase().trim();
        filteredOptions = options.filter(function(opt) {
          return opt.label.toLowerCase().includes(query);
        });

        if (filteredOptions.length === 0) {
          dropdown.innerHTML = '<div class="qt-searchable__option qt-searchable__no-results">\u0644\u0627 \u062A\u0648\u062C\u062F \u0646\u062A\u0627\u0626\u062C</div>';
          return;
        }

        dropdown.innerHTML = filteredOptions.map(function(opt, idx) {
          var cls = 'qt-searchable__option';
          if (idx === highlightedIndex) cls += ' highlighted';
          if (opt.value === selectedValue) cls += ' selected';
          var typeHtml = opt.type ? ' <span class="qt-searchable__option-type">' + escapeHtml(opt.type) + '</span>' : '';
          return '<div class="' + cls + '" data-index="' + idx + '">' + escapeHtml(opt.label) + typeHtml + '</div>';
        }).join('');
      }

      function openDropdown() {
        highlightedIndex = -1;
        renderDropdown();
        dropdown.hidden = false;
      }

      function closeDropdown() {
        dropdown.hidden = true;
      }

      function selectItem(value, label) {
        selectedValue = value;
        input.value = label;
        container.dataset.value = value;
        closeDropdown();
        if (onSelect) onSelect(value, label);
      }

      input.addEventListener('focus', openDropdown);

      input.addEventListener('input', function() {
        selectedValue = '';
        container.dataset.value = '';
        highlightedIndex = -1;
        openDropdown();
      });

      input.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          highlightedIndex = Math.min(highlightedIndex + 1, filteredOptions.length - 1);
          renderDropdown();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          highlightedIndex = Math.max(highlightedIndex - 1, -1);
          renderDropdown();
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (highlightedIndex >= 0 && highlightedIndex < filteredOptions.length) {
            var opt = filteredOptions[highlightedIndex];
            selectItem(opt.value, opt.label);
          }
        } else if (e.key === 'Escape') {
          closeDropdown();
        }
      });

      dropdown.addEventListener('click', function(e) {
        var optEl = e.target.closest('.qt-searchable__option');
        if (!optEl || optEl.classList.contains('qt-searchable__no-results')) return;
        var idx = parseInt(optEl.dataset.index);
        if (idx >= 0 && idx < filteredOptions.length) {
          var opt = filteredOptions[idx];
          selectItem(opt.value, opt.label);
        }
      });

      document.addEventListener('click', function(e) {
        if (!container.contains(e.target)) {
          closeDropdown();
        }
      });

      arrow.addEventListener('click', function() {
        if (dropdown.hidden) openDropdown(); else closeDropdown();
      });

      container.setValue = function(value) {
        var match = null;
        for (var i = 0; i < options.length; i++) {
          if (options[i].value === value) { match = options[i]; break; }
        }
        if (match) {
          selectedValue = match.value;
          input.value = match.label;
          container.dataset.value = match.value;
        } else {
          selectedValue = '';
          input.value = '';
          container.dataset.value = '';
        }
      };

      container.getValue = function() {
        return container.dataset.value || '';
      };
    }

    // ---- Get table options for searchable dropdowns ----
    function getTableOptions() {
      var tables = window.currentTables || [];
      return tables.map(function(t) {
        var label = t.schema ? t.schema + '.' + t.tableName : t.tableName;
        return { value: t.tableName, label: label, type: t.schema };
      });
    }

    // ---- Get column options for searchable dropdowns ----
    function getColumnOptions(tableName, alias) {
      if (!tableName || !joinColumnCache[tableName]) return [];
      return joinColumnCache[tableName].map(function(col) {
        return { value: alias + '.' + col.name, label: alias + '.' + col.name, type: col.dataType };
      });
    }

    // ---- Get alias for a table in a clause ----
    function getAliasForTable(clauseIndex, tableIndex) {
      var clause = document.querySelector('.qt-join-clause[data-index="' + clauseIndex + '"]');
      if (!clause) return tableIndex === 0 ? 'a' : 'b';
      var aliasInputs = clause.querySelectorAll('.qt-join-clause__alias');
      if (aliasInputs.length > tableIndex) return aliasInputs[tableIndex].value;
      return tableIndex === 0 ? 'a' : 'b';
    }

    // ================================================================
    // JOIN Builder Functions  (TASK-ENH-QT-004)
    // ================================================================

    var joinClauseCount = 0;
    var joinColumnCache = {};

    function getNextAlias() {
        var count = document.querySelectorAll('.qt-join-clause').length;
        return String.fromCharCode(97 + count); // a, b, c, d...
    }

    function getAliasesForClause(index) {
        var clauses = document.querySelectorAll('.qt-join-clause');
        var aliases = {};
        clauses.forEach(function(c, i) {
            if (i <= index) {
                var alias1 = c.querySelector('.qt-join-clause__alias');
                if (alias1) aliases['t1_' + i] = alias1.value;
                var alias2 = c.querySelectorAll('.qt-join-clause__alias')[1];
                if (alias2) aliases['t2_' + i] = alias2.value;
            }
        });
        return aliases;
    }

    // ---- Populate all JOIN table dropdowns ----
    function populateJoinTableDropdowns() {
        var tableOpts = getTableOptions();
        document.querySelectorAll('.qt-join-table1-wrapper').forEach(function(wrap) {
            var currentVal = wrap.getValue();
            createSearchableDropdown(wrap, tableOpts, function() { onJoinTableChange(this); });
            if (currentVal) wrap.setValue(currentVal);
        });
        document.querySelectorAll('.qt-join-table2-wrapper').forEach(function(wrap) {
            var currentVal = wrap.getValue();
            createSearchableDropdown(wrap, tableOpts, function() { onJoinTableChange(this); });
            if (currentVal) wrap.setValue(currentVal);
        });
    }

    // ---- Add a new JOIN clause ----
    function addJoinClause() {
        var container = document.getElementById('joinClauses');

        var alias = getNextAlias();
        var index = joinClauseCount++;

        var html = '<div class="qt-join-clause" data-index="' + index + '">';
        html += '<div class="qt-join-clause__header">';
        html += '<div class="qt-join-table1-wrapper" style="flex:1;min-width:120px"></div>';
        html += '<input class="qt-join-clause__alias" placeholder="' + alias + '" maxlength="3" value="' + alias + '" oninput="updateJoinColumns()">';
        html += '<select class="qt-join-clause__select qt-join-type" onchange="onJoinTypeChange(this)" style="font-weight:700;color:var(--c-primary);min-width:130px">';
        html += '<option value="INNER JOIN">INNER JOIN</option>';
        html += '<option value="LEFT JOIN">LEFT JOIN</option>';
        html += '<option value="RIGHT JOIN">RIGHT JOIN</option>';
        html += '<option value="FULL OUTER JOIN">FULL JOIN</option>';
        html += '<option value="CROSS JOIN">CROSS JOIN</option>';
        html += '</select>';
        html += '<div class="qt-join-table2-wrapper" style="flex:1;min-width:120px"></div>';
        html += '<input class="qt-join-clause__alias" placeholder="b" maxlength="3" value="' + (getNextAlias() === 'a' ? 'b' : getNextAlias()) + '" oninput="updateJoinColumns()">';
        html += '<button class="qt-btn qt-btn--ghost qt-btn--xs" onclick="removeJoinClause(this)" title="حذف JOIN">\uD83D\uDDD1</button>';
        html += '</div>';
        html += '<div class="qt-join-conditions" id="joinConditions_' + index + '">';
        // Add one default condition
        html += '</div>';
        html += '<button class="qt-btn qt-btn--ghost qt-btn--xs" onclick="addJoinCondition(this)" style="font-size:12px" type="button">➕ إضافة شرط ON</button>';
        html += '</div>';

        container.insertAdjacentHTML('beforeend', html);
        
        // Initialize searchable dropdowns for this clause
        var newClause = container.lastElementChild;
        var table1Wrap = newClause.querySelector('.qt-join-table1-wrapper');
        var table2Wrap = newClause.querySelector('.qt-join-table2-wrapper');
        var _this = this;
        if (table1Wrap) createSearchableDropdown(table1Wrap, getTableOptions(), function() {
            onJoinTableChange(this);
        });
        if (table2Wrap) createSearchableDropdown(table2Wrap, getTableOptions(), function() {
            onJoinTableChange(this);
        });
        
        showToast('تم إضافة JOIN بعلاقة ' + alias + '.', 'info');
        updateJoinColumns();
    }

    // ---- When a table is selected in a JOIN clause ----
    function onJoinTableChange(el) {
        // el is either the wrapper div or the select element (backward compat)
        var clause = el.closest('.qt-join-clause');
        if (!clause) return;

        var table1Wrap = clause.querySelector('.qt-join-table1-wrapper');
        var table2Wrap = clause.querySelector('.qt-join-table2-wrapper');

        var table1 = table1Wrap ? table1Wrap.getValue() : (clause.querySelector('.qt-join-table1') ? clause.querySelector('.qt-join-table1').value : '');
        var table2 = table2Wrap ? table2Wrap.getValue() : (clause.querySelector('.qt-join-table2') ? clause.querySelector('.qt-join-table2').value : '');

        // Clear ON conditions when a table changes (old column references invalid)
        var conditionsDiv = clause.querySelector('.qt-join-conditions');
        conditionsDiv.innerHTML = '';

        var index = clause.dataset.index;
        updateJoinColumns();
    }

    // ---- When JOIN type changes ----
    function onJoinTypeChange(selectEl) {
        var clause = selectEl.closest('.qt-join-clause');
        var conditionsDiv = clause.querySelector('.qt-join-conditions');
        var addConditionBtn = clause.querySelector('[onclick*="addJoinCondition"]');

        if (selectEl.value === 'CROSS JOIN') {
            conditionsDiv.style.display = 'none';
            if (addConditionBtn) addConditionBtn.style.display = 'none';
        } else {
            conditionsDiv.style.display = '';
            if (addConditionBtn) addConditionBtn.style.display = '';
        }
    }

    // ---- Add an ON condition to a JOIN clause ----
    function addJoinCondition(btn) {
        var clause = btn.closest('.qt-join-clause');
        var conditionsDiv = clause.querySelector('.qt-join-conditions');
        var index = clause.dataset.index;
        var table1Wrap = clause.querySelector('.qt-join-table1-wrapper');
        var table2Wrap = clause.querySelector('.qt-join-table2-wrapper');
        var table1 = table1Wrap ? table1Wrap.getValue() : (clause.querySelector('.qt-join-table1') ? clause.querySelector('.qt-join-table1').value : '');
        var table2 = table2Wrap ? table2Wrap.getValue() : (clause.querySelector('.qt-join-table2') ? clause.querySelector('.qt-join-table2').value : '');

        var row = document.createElement('div');
        row.className = 'qt-join-condition';

        var col1Wrapper = document.createElement('div');
        col1Wrapper.className = 'qt-join-condition__col-wrapper';
        var col2Wrapper = document.createElement('div');
        col2Wrapper.className = 'qt-join-condition__col2-wrapper';

        var opSelect = document.createElement('select');
        opSelect.className = 'qt-join-condition__op';
        var ops = ['=', '<>', '>', '<', '>=', '<='];
        ops.forEach(function(op) {
            var opt = document.createElement('option');
            opt.value = op;
            opt.textContent = op;
            opSelect.appendChild(opt);
        });

        var removeBtn = document.createElement('button');
        removeBtn.className = 'qt-btn qt-btn--ghost qt-btn--xs';
        removeBtn.innerHTML = '\u2715';
        removeBtn.onclick = function() { removeJoinCondition(this); };
        removeBtn.type = 'button';

        // Append to row FIRST so querySelector works in populateConditionCols
        row.appendChild(col1Wrapper);
        row.appendChild(opSelect);
        row.appendChild(col2Wrapper);
        row.appendChild(removeBtn);

        // Populate columns — now the wrappers are in the DOM tree
        populateConditionCols(row, table1, table2, index);

        conditionsDiv.appendChild(row);
    }

    // ---- Populate column dropdowns in a condition row ----
    function populateConditionCols(row, table1, table2, clauseIndex) {
        var col1Wrapper = row.querySelector('.qt-join-condition__col-wrapper');
        var col2Wrapper = row.querySelector('.qt-join-condition__col2-wrapper');

        if (col1Wrapper && table1) {
            var alias = getAliasForTable(clauseIndex, 0);
            var cols = getColumnOptions(table1, alias);
            if (cols.length === 0 && table1) {
                fetchAndCacheColumns(table1, function() {
                    var alias2 = getAliasForTable(clauseIndex, 0);
                    var cols2 = getColumnOptions(table1, alias2);
                    createSearchableDropdown(col1Wrapper, cols2, function() { updateJoinColumns(); });
                });
            } else {
                createSearchableDropdown(col1Wrapper, cols, function() { updateJoinColumns(); });
            }
        }
        if (col2Wrapper && table2) {
            var alias2 = getAliasForTable(clauseIndex, 1);
            var cols2 = getColumnOptions(table2, alias2);
            if (cols2.length === 0 && table2) {
                fetchAndCacheColumns(table2, function() {
                    var alias3 = getAliasForTable(clauseIndex, 1);
                    var cols3 = getColumnOptions(table2, alias3);
                    createSearchableDropdown(col2Wrapper, cols3, function() { updateJoinColumns(); });
                });
            } else {
                createSearchableDropdown(col2Wrapper, cols2, function() { updateJoinColumns(); });
            }
        }
    }

    // ---- Fetch and cache columns for a table ----
    function fetchAndCacheColumns(tableName, callback) {
        if (joinColumnCache[tableName]) {
            if (callback) callback();
            return;
        }
        fetch('?handler=Columns&source=' + encodeURIComponent(currentSource) + '&table=' + encodeURIComponent(tableName))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    joinColumnCache[tableName] = data.columns || [];
                } else {
                    joinColumnCache[tableName] = [];
                }
                if (callback) callback();
            })
            .catch(function() {
                joinColumnCache[tableName] = [];
                if (callback) callback();
            });
    }

    // ---- Remove a condition row ----
    function removeJoinCondition(btn) {
        var row = btn.closest('.qt-join-condition');
        row.remove();
        updateJoinColumns();
    }

    // ---- Remove a JOIN clause ----
    function removeJoinClause(btn) {
        var clause = btn.closest('.qt-join-clause');
        clause.remove();

        // Renumber remaining clauses
        document.querySelectorAll('.qt-join-clause').forEach(function(c, idx) {
            c.dataset.index = idx;
            var inputs = c.querySelectorAll('.qt-join-clause__alias');
            var alias = String.fromCharCode(97 + idx);
            if (inputs[0]) { inputs[0].value = alias; inputs[0].placeholder = alias; }
            if (inputs[1]) {
                var alias2 = String.fromCharCode(97 + idx + 1);
                inputs[1].value = alias2; inputs[1].placeholder = alias2;
            }
        });

        updateJoinColumns();
        showToast('تم حذف JOIN.', 'info');
    }

    // ---- Update column sortable list for JOIN ----
    function updateJoinColumns() {
        var columnsDiv = document.getElementById('joinColumns');
        var grid = document.getElementById('joinColumnsGrid');

        var allCols = [];
        var clauses = document.querySelectorAll('.qt-join-clause');

        clauses.forEach(function(c) {
            var t1Wrap = c.querySelector('.qt-join-table1-wrapper');
            var t2Wrap = c.querySelector('.qt-join-table2-wrapper');
            var table1 = t1Wrap ? t1Wrap.getValue() : (c.querySelector('.qt-join-table1') ? c.querySelector('.qt-join-table1').value : '');
            var table2 = t2Wrap ? t2Wrap.getValue() : (c.querySelector('.qt-join-table2') ? c.querySelector('.qt-join-table2').value : '');
            var aliasInputs = c.querySelectorAll('.qt-join-clause__alias');
            var alias1 = aliasInputs.length > 0 ? aliasInputs[0].value || 'a' : 'a';
            var alias2 = aliasInputs.length > 1 ? aliasInputs[1].value || 'b' : 'b';

            // If no tables selected at all, keep hidden
            if (!table1 && !table2) {
                columnsDiv.hidden = true;
                return;
            }

            if (table1 && joinColumnCache[table1]) {
                joinColumnCache[table1].forEach(function(col) {
                    var key = alias1 + '.' + col.name;
                    var exists = allCols.some(function(ac) { return ac.value === key; });
                    if (!exists) {
                        allCols.push({ value: key, label: key, type: col.dataType, checked: true });
                    }
                });
            }
            if (table2 && joinColumnCache[table2]) {
                joinColumnCache[table2].forEach(function(col) {
                    var key = alias2 + '.' + col.name;
                    var exists = allCols.some(function(ac) { return ac.value === key; });
                    if (!exists) {
                        allCols.push({ value: key, label: key, type: col.dataType, checked: true });
                    }
                });
            }
        });

        // Also add columns from the current SELECT builder table if it's selected
        var builderTableWrap = document.getElementById('builderTableWrapper');
        var builderTable = builderTableWrap ? builderTableWrap.getValue() : '';
        if (builderTable && joinColumnCache[builderTable]) {
            joinColumnCache[builderTable].forEach(function(col) {
                var key = builderTable + '.' + col.name;
                var exists = allCols.some(function(ac) { return ac.value === key; });
                if (!exists) {
                    allCols.push({ value: key, label: key, type: col.dataType, checked: true });
                }
            });
        }

        if (allCols.length === 0) {
            columnsDiv.hidden = true;
            return;
        }

        columnsDiv.hidden = false;
        grid.innerHTML = '';
        createSortableList(grid, allCols);
    }

    // ---- Select/deselect all JOIN columns ----
    function selectAllJoinCols(select) {
        var list = document.querySelector('#joinColumnsGrid .qt-sortable-list');
        if (list && list.selectAll) list.selectAll(select);
    }

    // ---- Generate JOIN query ----
    function generateJoinQuery() {
        var clauses = document.querySelectorAll('.qt-join-clause');
        if (clauses.length === 0) {
            showToast('أضف JOIN واحداً على الأقل أولاً.', 'warning');
            return;
        }

        // Collect selected columns from sortable list
        var colList = document.querySelector('#joinColumnsGrid .qt-sortable-list');
        var selectedCols = colList ? colList.getSelected() : [];

        // Validate first clause has both tables
        var firstClause = clauses[0];
        var t1Wrap = firstClause.querySelector('.qt-join-table1-wrapper');
        var t2Wrap = firstClause.querySelector('.qt-join-table2-wrapper');
        var table1 = t1Wrap ? t1Wrap.getValue() : (firstClause.querySelector('.qt-join-table1') ? firstClause.querySelector('.qt-join-table1').value : '');
        var table2 = t2Wrap ? t2Wrap.getValue() : (firstClause.querySelector('.qt-join-table2') ? firstClause.querySelector('.qt-join-table2').value : '');
        var aliasInputs1 = firstClause.querySelectorAll('.qt-join-clause__alias');
        var alias1 = aliasInputs1.length > 0 ? aliasInputs1[0].value || 'a' : 'a';

        if (!table1) {
            showToast('اختر الجدول الأول في أول JOIN.', 'warning');
            return;
        }

        // Build the SQL
        var sql = '';

        // SELECT part
        if (selectedCols.length > 0) {
            sql += 'SELECT ' + selectedCols.join(', ');
        } else {
            // If no columns selected, use the first table with a.*
            sql += 'SELECT ' + alias1 + '.*';
        }

        // FROM part (from first clause's table1)
        sql += '\nFROM ' + table1 + ' ' + alias1;

        // JOIN parts
        for (var i = 0; i < clauses.length; i++) {
            var c = clauses[i];
            var ct1Wrap = c.querySelector('.qt-join-table1-wrapper');
            var ct2Wrap = c.querySelector('.qt-join-table2-wrapper');
            var t1 = ct1Wrap ? ct1Wrap.getValue() : (c.querySelector('.qt-join-table1') ? c.querySelector('.qt-join-table1').value : '');
            var t2 = ct2Wrap ? ct2Wrap.getValue() : (c.querySelector('.qt-join-table2') ? c.querySelector('.qt-join-table2').value : '');
            var joinType = c.querySelector('.qt-join-type').value;
            var aliasEls = c.querySelectorAll('.qt-join-clause__alias');
            var a1 = aliasEls.length > 0 ? aliasEls[0].value || 'a' : 'a';
            var a2 = aliasEls.length > 1 ? aliasEls[1].value || 'b' : 'b';

            if (!t2) {
                showToast('اختر الجدول الثاني في JOIN رقم ' + (i + 1) + '.', 'warning');
                return;
            }

            sql += '\n' + joinType + ' ' + t2 + ' ' + a2;

            if (joinType !== 'CROSS JOIN') {
                // Collect ON conditions
                var conditionsRows = c.querySelectorAll('.qt-join-condition');
                var onParts = [];
                conditionsRows.forEach(function(row) {
                    var col1Wrapper = row.querySelector('.qt-join-condition__col-wrapper');
                    var op = row.querySelector('.qt-join-condition__op');
                    var col2Wrapper = row.querySelector('.qt-join-condition__col2-wrapper');
                    var col1 = col1Wrapper ? col1Wrapper.getValue() : (row.querySelector('.qt-join-condition__col') ? row.querySelector('.qt-join-condition__col').value : '');
                    var col2 = col2Wrapper ? col2Wrapper.getValue() : (row.querySelector('.qt-join-condition__col2') ? row.querySelector('.qt-join-condition__col2').value : '');
                    if (col1 && op && col2) {
                        onParts.push(col1 + ' ' + op.value + ' ' + col2);
                    }
                });

                if (onParts.length > 0) {
                    sql += ' ON ' + onParts.join(' AND ');
                } else {
                    // Use default ON based on first condition attempt
                    // Generate a reasonable default: a1.ID = a2.Table1ID
                    sql += ' ON ' + a1 + '.ID = ' + a2 + '.' + t1 + 'ID';
                }
            }
        }

        // Check existing editor content
        var existingSql = editor.getValue().trim();

        if (existingSql && existingSql !== 'SELECT 1 AS [عيّنة]') {
            // Append to existing SQL (before any WHERE clause)
            var whereIdx = existingSql.toUpperCase().lastIndexOf('WHERE');
            var orderIdx = existingSql.toUpperCase().lastIndexOf('ORDER BY');

            var insertPos = existingSql.length;
            var suffix = '';

            if (orderIdx >= 0) {
                suffix = existingSql.substring(orderIdx);
                insertPos = orderIdx;
            } else if (whereIdx >= 0) {
                suffix = existingSql.substring(whereIdx);
                insertPos = whereIdx;
            }

            var baseSql = existingSql.substring(0, insertPos).trim();
            editor.setValue(baseSql + '\n' + sql + (suffix ? '\n' + suffix : ''));
        } else {
            editor.setValue(sql);
        }

        showToast('تم إنشاء استعلام JOIN بنجاح.', 'success');

        // Save to history if available
        if (typeof saveToHistory === 'function') {
            saveToHistory(editor.getValue(), currentSource, 0);
        }
    }

    // ---- Create a sortable column list with ↑↓ buttons ----
    function createSortableList(container, columns, onChange) {
      container.innerHTML = '';
      container.className = 'qt-sortable-list';

      var items = columns.map(function(col) {
        return {
          value: col.value,
          label: col.label,
          type: col.type || '',
          checked: col.checked !== false
        };
      });

      function render() {
        var html = items.map(function(item, idx) {
          var checkedAttr = item.checked ? 'checked' : '';
          var upDisabled = idx === 0 ? 'disabled' : '';
          var downDisabled = idx === items.length - 1 ? 'disabled' : '';
          return '<div class="qt-sortable-item" data-index="' + idx + '">' +
            '<span class="qt-sortable-handle">⠿</span>' +
            '<input type="checkbox" class="qt-sortable-checkbox" ' + checkedAttr + ' data-idx="' + idx + '">' +
            '<span class="qt-sortable-label">' + escapeHtml(item.label) + '</span>' +
            (item.type ? '<span class="qt-sortable-type">(' + escapeHtml(item.type) + ')</span>' : '') +
            '<button class="qt-sortable-btn qt-sortable-up" ' + upDisabled + ' data-idx="' + idx + '" title="رفع">↑</button>' +
            '<button class="qt-sortable-btn qt-sortable-down" ' + downDisabled + ' data-idx="' + idx + '" title="خفض">↓</button>' +
            '</div>';
        }).join('');
        container.innerHTML = html;

        // Sync checkbox states
        container.querySelectorAll('.qt-sortable-checkbox').forEach(function(cb) {
          cb.checked = items[parseInt(cb.dataset.idx)].checked;
        });
      }

      // Event delegation for ↑↓ buttons and checkboxes
      container.addEventListener('click', function(e) {
        var btn = e.target.closest('.qt-sortable-btn');
        if (btn) {
          var idx = parseInt(btn.dataset.idx);
          if (btn.classList.contains('qt-sortable-up') && idx > 0) {
            var temp = items[idx];
            items[idx] = items[idx - 1];
            items[idx - 1] = temp;
            render();
            notifyChange();
          } else if (btn.classList.contains('qt-sortable-down') && idx < items.length - 1) {
            var temp = items[idx];
            items[idx] = items[idx + 1];
            items[idx + 1] = temp;
            render();
            notifyChange();
          }
          return;
        }

        var cb = e.target.closest('.qt-sortable-checkbox');
        if (cb) {
          items[parseInt(cb.dataset.idx)].checked = cb.checked;
          notifyChange();
        }
      });

      container.selectAll = function(select) {
        items.forEach(function(item) { item.checked = select; });
        render();
        notifyChange();
      };

      container.getSelected = function() {
        return items.filter(function(item) { return item.checked; }).map(function(item) { return item.value; });
      };

      container.getItems = function() { return items; };

      container.setChecked = function(value, checked) {
        items.forEach(function(item) {
          if (item.value === value) item.checked = checked;
        });
        render();
        notifyChange();
      };

      function notifyChange() {
        if (onChange) onChange(container.getSelected());
      }

      render();
    }
</script>
