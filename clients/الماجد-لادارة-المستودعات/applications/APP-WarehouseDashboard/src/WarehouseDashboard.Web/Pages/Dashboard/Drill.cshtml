@page "{cardId:int}"
@model WarehouseDashboard.Web.Pages.Dashboard.DrillModel
@{
    ViewData["Title"] = "تعمّق البطاقة";
    Layout = "_DashboardLayout";
}

<style>
    .wd-breadcrumb {
        display: flex; flex-wrap: wrap; align-items: center; gap: var(--sp-2);
        margin-bottom: var(--sp-4); font-size: 14px;
        animation: wdFadeUp var(--dur-norm) var(--ease) both;
    }
    .wd-breadcrumb__item {
        color: var(--c-text-muted); text-decoration: none; font-weight: 600;
        padding: 4px 10px; border-radius: var(--radius-full);
        transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
    }
    .wd-breadcrumb__item:not(.is-current):hover { background: var(--c-surface-muted); color: var(--c-primary); }
    .wd-breadcrumb__item.is-current { color: var(--c-primary); background: var(--c-surface-muted); }
    .wd-breadcrumb__sep { color: var(--c-text-muted); font-weight: 700; }

    .wd-card--drill { min-height: 320px; animation: wdFadeUp var(--dur-norm) var(--ease) both; }
    .wd-card--drill .wd-card__body { min-height: 0; }
</style>

<div class="wd-page-head">
    <div>
        <h2 class="wd-page-title">تعمّق البطاقة</h2>
        <span class="wd-card__type" id="wd-drill-subtitle"></span>
    </div>
    <a class="wd-btn wd-btn--ghost wd-btn--sm" href="/">
        <span aria-hidden="true">⟵</span> لوحة المعلومات
    </a>
</div>

<nav class="wd-breadcrumb" id="wd-breadcrumb" aria-label="مسار التعمّق"></nav>

<section class="wd-drill-stage">
    <div id="wd-drill-host" class="wd-card wd-card--drill">
        <div class="wd-card__body">
            <div class="wd-skeleton-wrap"><div class="wd-skel wd-skel--tall"></div></div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Server-provided metadata (config via EF Core — no data queries here).
        window.WD_DRILL = {
            cardId: @Model.CardId,
            cardTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CardTitle)),
            configError: @Model.ConfigError.ToString().ToLowerInvariant(),
            levels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Levels.Select(l => new { level = l.Level, displayName = l.DisplayName, chartType = l.ChartType })))
        };

        (function () {
            var D = window.WD_DRILL;
            var PALETTE = window.WD_PALETTE || ['#1F4E79', '#163A5A', '#2E6DA4', '#0A2540', '#8FBCDE', '#5B7A99'];

            // Shared utilities (toNum, isNum, formatNum, escapeHtml, showToast,
            // wdEmptyHtml, wdErrorHtml) are provided by ~/js/dashboard-utils.js.

            // Drill-specific override: always shows a retry button that calls wdReloadLevel().
            function wdErrorHtml(msg) {
                return '<div class="wd-empty wd-empty--error"><div class="wd-empty__icon">\u26A0</div>' +
                    '<h3>\u062A\u0639\u0630\u0631 \u062A\u062D\u0645\u064A\u0644 \u0627\u0644\u0645\u0633\u062A\u0648\u064A</h3>' +
                    '<p>' + escapeHtml(msg || '\u062D\u062F\u062B \u062E\u0637\u0623 \u063A\u064A\u0631 \u0645\u062A\u0648\u0642\u0639.') + '</p>' +
                    '<button type="button" class="wd-btn wd-btn--ghost wd-btn--sm" onclick="wdReloadLevel()">\u0625\u0639\u0627\u062F\u0629 \u0627\u0644\u0645\u062D\u0627\u0648\u0644\u0629</button></div>';
            }

            function wdKpiHtml(val, hasNext) {
                var click = hasNext ? ' style="cursor:pointer" role="button" tabindex="0" onclick="wdDrillCurrentKpi()" onkeydown="if(event.key===\'Enter\')wdDrillCurrentKpi()"' : '';
                return '<div class="wd-kpi"' + click + '><div class="wd-kpi__value">' + escapeHtml(formatNum(val)) + '</div>' +
                    '<div class="wd-kpi__label">' + (hasNext ? 'انقر للتعمّق' : 'قيمة المؤشر') + '</div></div>';
            }

            // ---------- URL / chain helpers ----------
            function getParams() {
                var p = new URLSearchParams(window.location.search);
                var level = parseInt(p.get('level') || '1', 10);
                if (isNaN(level) || level < 1) level = 1;
                var pv = p.get('pv') || '';
                return { level: level, pv: pv };
            }
            function currentChain() {
                var pv = getParams().pv;
                return pv ? pv.split('|') : [];
            }
            function parentValueFor(level, chain) {
                if (level <= 1) return null;
                var idx = level - 2;
                return (chain.length > idx) ? chain[idx] : (chain.length ? chain[chain.length - 1] : null);
            }
            function wdDrillInto(value) {
                var params = getParams();
                var next = params.level + 1;
                if (next > D.levels.length) return;
                var chain = currentChain();
                chain.push(value == null ? '' : String(value));
                var url = '/Dashboard/Drill/' + D.cardId + '?level=' + next + '&pv=' + encodeURIComponent(chain.join('|'));
                window.location.href = url;
            }
            window.wdDrillCurrentKpi = function () {
                // The KPI value for the current level was stored when rendered.
                if (window.WD_KPI_VALUE !== undefined) wdDrillInto(window.WD_KPI_VALUE);
            };
            window.wdReloadLevel = function () { loadLevel(); };

            // ---------- breadcrumb ----------
            function buildBreadcrumb() {
                var nav = document.getElementById('wd-breadcrumb');
                if (!nav) return;
                var params = getParams();
                var level = params.level;
                var chain = currentChain();

                var rootUrl = '/Dashboard/Drill/' + D.cardId;
                var items = [];
                items.push({ label: D.cardTitle || ('البطاقة #' + D.cardId), url: rootUrl, current: level === 1 });

                for (var k = 1; k < level; k++) {
                    var lvl = D.levels[k - 1];
                    if (!lvl) break;
                    var seg = chain.slice(0, k - 1).join('|');
                    var url = k === 1 ? rootUrl : (rootUrl + '?level=' + k + '&pv=' + encodeURIComponent(seg));
                    items.push({ label: lvl.displayName, url: url, current: false });
                }
                if (level > 1) {
                    var cur = D.levels[level - 1];
                    items.push({ label: cur ? cur.displayName : ('المستوى ' + level), url: null, current: true });
                }

                nav.innerHTML = '';
                items.forEach(function (it, i) {
                    if (i > 0) {
                        var sep = document.createElement('span');
                        sep.className = 'wd-breadcrumb__sep';
                        sep.textContent = '›';
                        nav.appendChild(sep);
                    }
                    var a = document.createElement(it.url ? 'a' : 'span');
                    a.className = 'wd-breadcrumb__item' + (it.current ? ' is-current' : '');
                    a.textContent = it.label;
                    if (it.url) {
                        a.href = it.url;
                        a.setAttribute('aria-label', 'الذهاب إلى ' + it.label);
                    } else {
                        a.setAttribute('aria-current', 'page');
                    }
                    nav.appendChild(a);
                });
            }

            // ---------- renderers (mirror Index.cshtml pattern) ----------
            function renderChart(viz, data) {
                var cols = data.columns;
                var rows = (data.rows || []).map(function (r) { return { label: r[cols[0]], value: toNum(r[cols[1]]) }; });
                var typeMap = { Bar: 'Column', Line: 'Line', Pie: 'Pie' };
                var type = typeMap[data.chartType] || 'Column';
                var isPie = data.chartType === 'Pie';
                var chart = new ej.charts.Chart({
                    theme: 'Bootstrap5', palette: PALETTE,
                    primaryXAxis: { valueType: 'Category', labelStyle: { color: '#5B7A99' }, lineStyle: { color: '#D4E2F0' }, majorGridLines: { width: 0 }, title: isPie ? '' : (cols[0] || '') },
                    primaryYAxis: { labelStyle: { color: '#5B7A99' }, lineStyle: { color: '#D4E2F0' }, majorGridLines: { color: '#D4E2F0', width: 0.5 } },
                    legendSettings: { visible: isPie, position: 'Bottom', textStyle: { color: '#5B7A99' } },
                    tooltip: { enable: true, fill: '#0A2540', textStyle: { color: '#ffffff' } },
                    series: [{
                        type: type, dataSource: rows, xName: 'label', yName: 'value', name: data.displayName,
                        cornerRadius: data.chartType === 'Bar' ? { topLeft: 4, topRight: 4 } : undefined,
                        marker: data.chartType === 'Line' ? { visible: true, width: 2, height: 6 } : undefined,
                        dataLabel: isPie ? { visible: true, position: 'Outside' } : { visible: false },
                        width: data.chartType === 'Line' ? 2 : undefined
                    }],
                    pointClick: data.hasNextLevel ? function (args) { wdDrillInto(args.point ? args.point.x : null); } : undefined,
                    width: '100%', height: '100%'
                });
                chart.appendTo(viz);
            }
            function renderGauge(viz, data) {
                var val = toNum(data.kpiValue);
                var max = val <= 0 ? 100 : (val <= 100 ? 100 : Math.ceil(val * 1.2));
                var gauge = new ej.circulargauge.CircularGauge({
                    theme: 'Bootstrap5',
                    axes: [{
                        minimum: 0, maximum: max, radius: '100%', startAngle: 200, endAngle: 160,
                        pointers: [{ value: val, type: 'RangeBar', radius: '100%', pointerWidth: 6, color: '#1F4E79', cap: { radius: 0 }, animation: { enable: true, duration: 900 } }],
                        lineStyle: { width: 8, color: '#D4E2F0' }, majorTicks: { color: '#D4E2F0', height: 0 }, minorTicks: { height: 0 },
                        labelStyle: { color: '#5B7A99', font: { size: '12px' } },
                        ranges: [{ start: 0, end: val, startWidth: 8, endWidth: 8, color: '#2E6DA4', radius: '100%' }]
                    }],
                    annotations: [{ content: '<div style="font-size:22px;font-weight:700;color:#102A43">' + escapeHtml(formatNum(val)) + '</div>', radius: '0%', angle: 0, zIndex: '1' }],
                    pointerClick: data.hasNextLevel ? function () { wdDrillInto(val); } : undefined,
                    width: '100%', height: '100%'
                });
                gauge.appendTo(viz);
            }
            function renderGrid(viz, data) {
                var cols = (data.columns || []).map(function (c) {
                    var sample = data.rows && data.rows.length ? data.rows[0][c] : null;
                    return { field: c, headerText: c, textAlign: isNum(sample) ? 'Right' : 'Left', width: 120 };
                });
                if (data.hasNextLevel) {
                    cols.push({ headerText: '', width: 96, commands: [{ type: 'Drill', buttonOption: { content: 'تعمّق', cssClass: 'e-info' } }] });
                }
                var grid = new ej.grids.Grid({
                    theme: 'Bootstrap5', dataSource: data.rows || [], columns: cols,
                    allowPaging: (data.rows || []).length > 10, pageSize: 10, allowSorting: true,
                    gridLines: 'Horizontal', cssClass: 'wd-sync-grid', width: '100%', height: '100%',
                    rowSelected: data.hasNextLevel ? function (args) { wdDrillInto(args.data[data.columns[0]]); } : undefined
                });
                if (data.hasNextLevel) {
                    grid.commandClicked = function (args) {
                        if (args.commandColumn && args.commandColumn.type === 'Drill') {
                            wdDrillInto(args.rowData[data.columns[0]]);
                        }
                    };
                }
                grid.appendTo(viz);
            }
            function renderLevel(data) {
                var host = document.getElementById('wd-drill-host');
                if (!host) return;

                var headerHtml = '<div class="wd-card__header">' +
                    '<h3 class="wd-card__title">' + escapeHtml(data.displayName || ('المستوى ' + data.level)) + '</h3>' +
                    '<span class="wd-card__type">' + escapeHtml(data.chartType) + '</span></div>';
                var body = document.createElement('div');
                body.className = 'wd-card__body';

                host.innerHTML = headerHtml;
                host.appendChild(body);

                try {
                    if (data.status === 'empty') { body.innerHTML = wdEmptyHtml(); return; }
                    if (data.status === 'none') { body.innerHTML = wdEmptyHtml('لا يوجد مستوى', data.errorMessage || 'لم يتم تكوين مستوى تعمّق بهذا الترتيب.'); return; }
                    if (data.status === 'error') { body.innerHTML = wdErrorHtml(data.errorMessage); return; }

                    if (data.chartType === 'KPI') {
                        window.WD_KPI_VALUE = data.kpiValue;
                        body.innerHTML = wdKpiHtml(data.kpiValue, data.hasNextLevel);
                        return;
                    }
                    if (!data.columns || data.columns.length < 1) { body.innerHTML = wdEmptyHtml(); return; }

                    var viz = document.createElement('div');
                    viz.style.width = '100%'; viz.style.height = '100%'; viz.style.minHeight = '220px';
                    body.appendChild(viz);

                    if (data.chartType === 'Table') { renderGrid(viz, data); return; }
                    if (data.chartType === 'Gauge') { renderGauge(viz, data); return; }
                    renderChart(viz, data);
                } catch (e) {
                    body.innerHTML = wdErrorHtml('تعذر عرض العنصر: ' + (e && e.message ? e.message : e));
                }
            }

            // ---------- data load ----------
            function loadLevel() {
                if (D.configError) {
                    var host = document.getElementById('wd-drill-host');
                    if (host) host.innerHTML = '<div class="wd-card__body">' + wdErrorHtml('تعذر الاتصال بقاعدة بيانات الإعدادات. تأكد من ضبط متغيّر البيئة SQL_PASSWORD.') + '</div>';
                    return;
                }
                var params = getParams();
                var chain = currentChain();
                var parentValue = parentValueFor(params.level, chain);

                buildBreadcrumb();
                document.getElementById('wd-drill-subtitle').textContent = 'المستوى ' + params.level + ' من ' + D.levels.length;

                // Skeleton while loading.
                var host = document.getElementById('wd-drill-host');
                if (host) {
                    host.innerHTML = '<div class="wd-card__header"><h3 class="wd-card__title">جارٍ التحميل…</h3>' +
                        '<span class="wd-card__type">' + escapeHtml(params.level) + '</span></div>' +
                        '<div class="wd-card__body"><div class="wd-skeleton-wrap"><div class="wd-skel wd-skel--tall"></div></div></div>';
                }

                var url = '/api/dashboard/drill/' + D.cardId + '/' + params.level +
                    (parentValue != null ? '?parentValue=' + encodeURIComponent(parentValue) : '');

                fetch(url, { headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data && data.status === 'error') showToast('error', 'تعذر تحميل المستوى ' + params.level);
                        renderLevel(data);
                    })
                    .catch(function (err) {
                        var h = document.getElementById('wd-drill-host');
                        if (h) h.innerHTML = '<div class="wd-card__body">' + wdErrorHtml('تعذر الاتصال بالخادم: ' + (err && err.message ? err.message : '')) + '</div>';
                        showToast('error', 'تعذر تحميل المستوى ' + params.level);
                    });
            }

            document.addEventListener('DOMContentLoaded', loadLevel);
        })();
    </script>
}
