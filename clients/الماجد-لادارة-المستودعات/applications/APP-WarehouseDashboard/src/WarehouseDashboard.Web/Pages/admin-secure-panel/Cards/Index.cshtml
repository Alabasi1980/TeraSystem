@page
@model IndexModel
@{
    ViewData["Title"] = "إدارة البطاقات";
}

<div class="wd-breadcrumb-row">
    <span>البطاقات</span>
</div>

<div class="wd-page-head">
    <h2 class="wd-page-title">بطاقات لوحة المعلومات</h2>
    <a href="/admin-secure-panel/Cards/Create" class="wd-btn wd-btn--primary">+ بطاقة جديدة</a>
</div>

@if (Model.Cards.Count == 0)
{
    <div class="wd-card wd-empty">
        <div class="wd-empty__icon">▦</div>
        <h3>لا توجد بطاقات بعد</h3>
        <p>ابدأ بإضافة بطاقة جديدة لعرضها في لوحة المعلومات.</p>
        <a href="/admin-secure-panel/Cards/Create" class="wd-btn wd-btn--primary">+ إضافة بطاقة</a>
    </div>
}
else
{
    <div class="wd-grid-wrap" id="wdGridWrap">
        <ejs-grid id="cardsGrid" dataSource="@Model.Cards" allowPaging="true" allowSorting="true"
                  gridLines="Horizontal" cssClass="wd-sync-grid" created="wdOnGridCreated">
            <e-grid-columns>
                <e-grid-column field="Title" headerText="العنوان" width="170"></e-grid-column>
                <e-grid-column field="ChartType" headerText="النوع" width="90" textAlign="Left"></e-grid-column>
                <e-grid-column field="DataSourceType" headerText="المصدر" width="100"></e-grid-column>
                <e-grid-column field="IsActive" headerText="نشط" width="80" template="#isActiveTpl"></e-grid-column>
                <e-grid-column field="GridPositionX" headerText="X" width="60" textAlign="Right"></e-grid-column>
                <e-grid-column field="GridPositionY" headerText="Y" width="60" textAlign="Right"></e-grid-column>
                <e-grid-column field="GridWidth" headerText="العرض" width="75" textAlign="Right"></e-grid-column>
                <e-grid-column field="GridHeight" headerText="الارتفاع" width="75" textAlign="Right"></e-grid-column>
                <e-grid-column field="RefreshInterval" headerText="تحديث (ث)" width="95" textAlign="Right"></e-grid-column>
                <e-grid-column headerText="إجراءات" width="150" template="#rowActions" textAlign="Center"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>

    <div class="wd-skeleton-wrap" id="wdSkeleton" aria-hidden="true">
        @for (var i = 0; i < 6; i++)
        {
            <div class="wd-skel-row">
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
                <div class="wd-skel"></div>
            </div>
        }
    </div>
}

<form id="wdDeleteForm" method="post" asp-page-handler="Delete" class="wd-hidden">
    <input type="hidden" name="id" id="wdDeleteId" />
</form>

<script id="isActiveTpl" type="text/x-template">
${if(IsActive)}
<span class="wd-badge wd-badge--on">نعم</span>
${else}
<span class="wd-badge wd-badge--off">لا</span>
${/if}
</script>

<script id="rowActions" type="text/x-template">
    <a class="wd-link" href="/admin-secure-panel/Cards/Edit?id=${Id}">تعديل</a>
    <button type="button" class="wd-link wd-link--danger" onclick="wdConfirmDelete(${Id})">حذف</button>
</script>

@section Scripts {
    <script>
        function wdConfirmDelete(id) {
            if (window.confirm('هل أنت متأكد من حذف هذه البطاقة؟ سيتم حذف مستويات التنقيح المرتبطة بها تلقائياً.')) {
                document.getElementById('wdDeleteId').value = id;
                document.getElementById('wdDeleteForm').submit();
            }
        }
        function wdHideSkeleton() {
            var sk = document.getElementById('wdSkeleton');
            var grid = document.getElementById('wdGridWrap');
            if (sk) sk.style.display = 'none';
            if (grid) grid.style.display = 'block';
        }
        function wdOnGridCreated() { wdHideSkeleton(); }
        // Fallback: never let the shimmer stick if Syncfusion scripts are slow/unavailable.
        window.addEventListener('load', function () { setTimeout(wdHideSkeleton, 700); });
    </script>
}

@section Toast {
    @if (!string.IsNullOrEmpty(Model.ToastMessage))
    {
        <div class="wd-toast wd-toast--@Model.ToastType" role="status">
            <span class="wd-toast__icon">@(Model.ToastType == "success" ? "✓" : "✕")</span>
            <span class="wd-toast__msg">@Model.ToastMessage</span>
        </div>
    }
}
